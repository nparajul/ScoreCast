@page "/data-sync"

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudText Typo="Typo.h4" Class="mb-1">Data Sync</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">Sync football data from football-data.org</MudText>

    <MudText Typo="Typo.h6" Class="mb-3">Sync New Competition</MudText>
    <MudPaper Elevation="1" Class="pa-4 mb-6 rounded-lg">
        <div class="d-flex align-center gap-3">
            <MudTextField @bind-Value="_newCompetitionCode"
                          Placeholder="e.g. PL, BL1, SA, PD..."
                          Label="Competition Code"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Immediate="true" />
            <MudButton Variant="Variant.Filled"
                       Color="Color.Tertiary"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Add"
                       Disabled="@(string.IsNullOrWhiteSpace(_newCompetitionCode))"
                       OnClick="SyncNewCompetitionAsync">
                Sync
            </MudButton>
        </div>
    </MudPaper>

    <MudText Typo="Typo.h6" Class="mb-3">Competitions</MudText>

    @if (_competitions.Count == 0)
    {
        <MudAlert Severity="Severity.Info">No competitions found in the database.</MudAlert>
    }
    else
    {
        <MudStack Spacing="3">
            @foreach (var competition in _competitions)
            {
                <MudPaper Elevation="1" Class="pa-4 rounded-lg">
                    <div class="d-flex align-center justify-space-between">
                        <div>
                            <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@competition.Name</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Code: @competition.Code</MudText>
                        </div>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Tertiary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Sync"
                                   OnClick="@(() => SyncCompetitionAsync(competition))">
                            Sync
                        </MudButton>
                    </div>
                </MudPaper>
            }
        </MudStack>
    }
</MudContainer>
