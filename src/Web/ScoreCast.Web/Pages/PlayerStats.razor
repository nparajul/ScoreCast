@page "/player-stats"

<PageGuard>
<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4">
    <MudText Typo="Typo.h5" Class="mb-3" Style="font-weight:700;">Player Stats</MudText>

    <CompetitionFilter OnStateChanged="OnFilterChanged" />

    <MudTextField @bind-Value="_search" Placeholder="Search player or team..." Variant="Variant.Outlined"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                  Style="max-width:300px;" Margin="Margin.Dense" Immediate="true" DebounceInterval="300" Class="mb-3" />
</MudContainer>

<MudContainer MaxWidth="MaxWidth.Large">

    @if (_rows.Count > 0)
    {
        <MudTable Items="@SortedRows" Dense="true" Hover="true" Striped="true" Elevation="1" Style="border-radius:8px;"
                  RowsPerPage="25">
            <HeaderContent>
                <MudTh Style="width:50px;">#</MudTh>
                <MudTh>Player</MudTh>
                <MudTh>Team</MudTh>
                <MudTh Style="cursor:pointer;" @onclick="@(() => SortBy("Goals"))">
                    ⚽ Goals
                    @if (SortIcon("Goals") != "")
                    {
                        <MudIcon Icon="@SortIcon("Goals")" Size="Size.Small" />
                    }
                </MudTh>
                <MudTh Style="cursor:pointer;" @onclick="@(() => SortBy("Assists"))">
                    🅰️ Assists
                    @if (SortIcon("Assists") != "")
                    {
                        <MudIcon Icon="@SortIcon("Assists")" Size="Size.Small" />
                    }
                </MudTh>
                <MudTh Style="cursor:pointer;" @onclick="@(() => SortBy("YellowCards"))">
                    🟨 Yellows
                    @if (SortIcon("YellowCards") != "")
                    {
                        <MudIcon Icon="@SortIcon("YellowCards")" Size="Size.Small" />
                    }
                </MudTh>
                <MudTh Style="cursor:pointer;" @onclick="@(() => SortBy("RedCards"))">
                    🟥 Reds
                    @if (SortIcon("RedCards") != "")
                    {
                        <MudIcon Icon="@SortIcon("RedCards")" Size="Size.Small" />
                    }
                </MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@(SortedRows.ToList().IndexOf(context) + 1)</MudTd>
                <MudTd Style="font-weight:600;">
                    <div class="d-flex align-center gap-2">
                        <MudAvatar Size="Size.Medium">
                            @if (context.PlayerImageUrl is not null)
                            {
                                <MudImage Src="@context.PlayerImageUrl" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Person" />
                            }
                        </MudAvatar>
                        @context.PlayerName
                    </div>
                </MudTd>
                <MudTd>
                    <div class="d-flex align-center gap-2">
                        @if (context.TeamLogo is not null)
                        {
                            <MudImage Src="@context.TeamLogo" Width="20" Height="20" ObjectFit="ObjectFit.Contain" />
                        }
                        @context.TeamName
                    </div>
                </MudTd>
                <MudTd Style="font-weight:700;">
                    @(context.Goals + context.PenaltyGoals)
                    @if (context.PenaltyGoals > 0)
                    {
                        <span style="font-size:12px;color:var(--mud-palette-text-secondary);"> (@context.PenaltyGoals pen)</span>
                    }
                </MudTd>
                <MudTd>@context.Assists</MudTd>
                <MudTd>@context.YellowCards</MudTd>
                <MudTd>@context.RedCards</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new[] { 25, 50, 100 }" />
            </PagerContent>
        </MudTable>
    }
    else if (_selectedSeason is not null && !Loading.IsLoading)
    {
        <MudAlert Severity="Severity.Info">No player stats available. Sync match events first.</MudAlert>
    }
</MudContainer>
</PageGuard>
