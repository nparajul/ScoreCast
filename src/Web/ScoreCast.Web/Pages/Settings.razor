@page "/settings"

<PageGuard>
<MudContainer MaxWidth="MaxWidth.Small" Class="py-4">

    @if (_profile is not null)
    {
        <div class="d-flex flex-column align-center mb-5">
            <MudAvatar Size="Size.Large" Color="Color.Primary" Class="mb-2">
                @(_profile.DisplayName?[0].ToString().ToUpper() ?? "?")
            </MudAvatar>
            <MudText Typo="Typo.h6" Style="font-weight:700;">@(_profile.DisplayName ?? _profile.UserId)</MudText>
            <MudText Typo="Typo.caption" Style="opacity:0.6;">@_profile.Email</MudText>
        </div>

        <MudPaper Elevation="1" Class="pa-4 rounded-lg mb-4">
            <MudText Typo="Typo.overline" Style="font-weight:600;" Class="mb-3">Stats</MudText>
            <div class="d-flex justify-space-around text-center">
                <div>
                    <MudText Typo="Typo.h5" Color="Color.Tertiary" Style="font-weight:700;">@_profile.TotalPoints</MudText>
                    <MudText Typo="Typo.caption" Style="opacity:0.6;">Points</MudText>
                </div>
                <div>
                    <MudText Typo="Typo.h5" Color="Color.Tertiary" Style="font-weight:700;">@_profile.CurrentStreak</MudText>
                    <MudText Typo="Typo.caption" Style="opacity:0.6;">Streak</MudText>
                </div>
                <div>
                    <MudText Typo="Typo.h5" Color="Color.Tertiary" Style="font-weight:700;">@_profile.LongestStreak</MudText>
                    <MudText Typo="Typo.caption" Style="opacity:0.6;">Best Streak</MudText>
                </div>
            </div>
        </MudPaper>

        <MudPaper Elevation="1" Class="pa-4 rounded-lg mb-4">
            <MudText Typo="Typo.overline" Style="font-weight:600;" Class="mb-3">Profile</MudText>

            <MudTextField @bind-Value="_displayName"
                          Label="Display Name"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          MaxLength="30"
                          Class="mb-3" />

            <MudTextField @bind-Value="_favoriteTeam"
                          Label="Favourite Team"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          Class="mb-3" />

            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                       Disabled="@(!HasChanges)" OnClick="SaveProfile">
                Save Changes
            </MudButton>
        </MudPaper>

        <MudButton Variant="Variant.Outlined" Color="Color.Error" FullWidth="true"
                   StartIcon="@Icons.Material.Filled.Logout" OnClick="Logout" Class="mt-2">
            Log Out
        </MudButton>
    }

</MudContainer>
</PageGuard>
