@page "/dashboard/{LeagueId:long}"

<PageGuard>
<MudContainer MaxWidth="MaxWidth.Medium" Class="py-4">
    @if (_standings is not null)
    {
        <div class="d-flex flex-column flex-sm-row justify-space-between align-start align-sm-center gap-2 mb-4">
            <div>
                <MudText Typo="Typo.h5" Style="font-weight:700;">@_standings.LeagueName</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@_standings.Standings.Count member@(_standings.Standings.Count != 1 ? "s" : "")@(_standings.StartingGameweekNumber > 1 ? $" · Since GW{_standings.StartingGameweekNumber}" : "")</MudText>
            </div>
            <MudButton Variant="Variant.Filled" Color="Color.Tertiary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Edit"
                       OnClick="NavigateToPredict">
                Make Predictions
            </MudButton>
        </div>

        <MudSimpleTable Dense="true" Elevation="1" Style="border-radius:12px;">
            <thead>
                <tr style="font-size:0.65rem;color:var(--mud-palette-text-secondary);">
                    <th style="padding:6px 4px;text-align:left;width:20px;">#</th>
                    <th style="padding:6px 4px;text-align:left;">Player</th>
                    <th style="padding:6px 8px;text-align:center;font-weight:700;"><MudTooltip Text="Points" Arrow="true" Placement="Placement.Top" ShowOnClick="true">Pts</MudTooltip></th>
                    <th style="padding:6px 8px;text-align:center;"><MudTooltip Text="@($"GW{_standings.Standings.FirstOrDefault()?.GameweekNumber} Points")" Arrow="true" Placement="Placement.Top" ShowOnClick="true">GW</MudTooltip></th>
                    <th style="padding:6px 8px;text-align:center;"><MudTooltip Text="Exact Scorelines" Arrow="true" Placement="Placement.Top" ShowOnClick="true">Exact</MudTooltip></th>
                    <th style="padding:6px 8px;text-align:center;"><MudTooltip Text="Correct Results" Arrow="true" Placement="Placement.Top" ShowOnClick="true">Correct</MudTooltip></th>
                    <th style="padding:6px 8px;text-align:center;"><MudTooltip Text="Matchweeks Played" Arrow="true" Placement="Placement.Top" ShowOnClick="true">MP</MudTooltip></th>
                </tr>
            </thead>
            <tbody>
                @{ var rank = 0; }
                @foreach (var row in _standings.Standings)
                {
                    rank++;
                    <tr style="font-size:0.8rem;border-bottom:1px solid var(--mud-palette-lines-default);">
                        <td style="padding:8px 4px;font-weight:600;">@rank</td>
                        <td style="padding:8px 4px;">
                            <div class="d-flex align-center gap-2">
                                <MudAvatar Size="Size.Small" Style="width:28px;height:28px;font-size:14px;">
                                    @if (row.AvatarUrl is not null)
                                    {
                                        <MudImage Src="@row.AvatarUrl" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                                    }
                                </MudAvatar>
                                <span @onclick="@(() => Nav.NavigateTo($"/dashboard/{LeagueId}/player/{row.UserId}"))"
                                      style="font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:@(IsMobile ? "100px" : "none");cursor:pointer;text-decoration:underline;text-decoration-color:var(--mud-palette-text-secondary);text-underline-offset:2px;">@row.DisplayName</span>
                            </div>
                        </td>
                        <td style="padding:8px 8px;text-align:center;font-weight:700;font-size:15px;">@row.TotalPoints</td>
                        <td style="padding:8px 8px;text-align:center;font-weight:600;color:#FF6B35;">@row.GameweekPoints</td>
                        <td style="padding:8px 8px;text-align:center;">@row.ExactScores</td>
                        <td style="padding:8px 8px;text-align:center;">@row.CorrectResults</td>
                        <td style="padding:8px 8px;text-align:center;">@row.PredictionCount</td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
</MudContainer>
</PageGuard>
