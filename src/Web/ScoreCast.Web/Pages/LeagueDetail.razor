@page "/dashboard/{LeagueId:long}"

<PageGuard>
<MudContainer MaxWidth="MaxWidth.Medium" Class="py-4">
    <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
               OnClick="@(() => Nav.NavigateTo("/dashboard"))" Class="mb-2">
        Back to Dashboard
    </MudButton>

    @if (_standings is not null)
    {
        <div class="d-flex flex-column flex-sm-row justify-space-between align-start align-sm-center gap-2 mb-4">
            <div>
                <MudText Typo="Typo.h5" Style="font-weight:700;">@_standings.LeagueName</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@_standings.Standings.Count member@(_standings.Standings.Count != 1 ? "s" : "")</MudText>
            </div>
            <MudButton Variant="Variant.Filled" Color="Color.Tertiary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Edit"
                       OnClick="NavigateToPredict">
                Make Predictions
            </MudButton>
        </div>

        <MudSimpleTable Dense="true" Elevation="1" Style="border-radius:12px;">
            <thead>
                <tr style="font-size:0.65rem;color:var(--mud-palette-text-secondary);">
                    <th style="padding:6px 2px;text-align:left;width:16px;">#</th>
                    <th style="padding:6px 2px;text-align:left;">Player</th>
                    <th style="padding:6px 2px;text-align:center;width:28px;font-weight:700;">Pts</th>
                    <th style="padding:6px 2px;text-align:center;width:28px;">Exact</th>
                    <th style="padding:6px 2px;text-align:center;width:34px;">Correct</th>
                    <th style="padding:6px 2px;text-align:center;width:28px;">Preds</th>
                </tr>
            </thead>
            <tbody>
                @{ var rank = 0; }
                @foreach (var row in _standings.Standings)
                {
                    rank++;
                    <tr style="font-size:0.8rem;border-bottom:1px solid var(--mud-palette-lines-default);">
                        <td style="padding:8px 2px;font-weight:600;">@rank</td>
                        <td style="padding:8px 2px;">
                            <div class="d-flex align-center gap-2">
                                <MudAvatar Size="Size.Small" Style="width:28px;height:28px;font-size:14px;">
                                    @if (row.AvatarUrl is not null)
                                    {
                                        <MudImage Src="@row.AvatarUrl" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                                    }
                                </MudAvatar>
                                <span style="font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:@(IsMobile ? "100px" : "none");">@row.DisplayName</span>
                            </div>
                        </td>
                        <td style="padding:8px 2px;text-align:center;font-weight:700;font-size:15px;">@row.TotalPoints</td>
                        <td style="padding:8px 2px;text-align:center;">@row.ExactScores</td>
                        <td style="padding:8px 2px;text-align:center;">@row.CorrectResults</td>
                        <td style="padding:8px 2px;text-align:center;">@row.PredictionCount</td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
</MudContainer>
</PageGuard>
