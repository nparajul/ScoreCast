@page "/data-sync"

<PageGuard>
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-1">Master Data Sync</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">Import and refresh competitions, teams, players, and match data from external sources</MudText>

    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-6">
        <strong>Step 1:</strong> Sync a competition to import its country, seasons, and historical winners.<br/>
        <strong>Step 2:</strong> Sync teams to pull in squads and player profiles for the current season.<br/>
        <strong>Step 3:</strong> Sync matches to import fixtures, results, and scores across all seasons.<br/>
        <strong>Step 4:</strong> For Premier League, sync PL Events to import goals, assists, cards, and subs from Pulse.
    </MudAlert>

    <MudText Typo="Typo.h6" Class="mb-3">Add New Competition</MudText>
    <MudPaper Elevation="1" Class="pa-4 mb-6 rounded-lg">
        <div class="d-flex align-center gap-3 flex-wrap">
            <MudTextField @bind-Value="_newCompetitionCode"
                          Placeholder="e.g. PL, BL1, SA, PD..."
                          Label="Competition Code"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Style="min-width:200px;flex:1;max-width:350px;"
                          Immediate="true" />
            <MudButton Variant="Variant.Filled"
                       Color="Color.Tertiary"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Add"
                       Disabled="@(string.IsNullOrWhiteSpace(_newCompetitionCode))"
                       OnClick="SyncNewCompetitionAsync">
                Sync
            </MudButton>
        </div>
    </MudPaper>

    <MudText Typo="Typo.h6" Class="mb-3">Synced Competitions</MudText>

    @if (_competitions.Count == 0)
    {
        <MudAlert Severity="Severity.Info">No competitions synced yet.</MudAlert>
    }
    else
    {
        <MudStack Spacing="3">
            @foreach (var competition in _competitions)
            {
                <MudPaper Elevation="1" Class="pa-4 rounded-lg">
                    <div class="d-flex flex-wrap align-center justify-space-between gap-3">
                        <div>
                            <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@competition.Name</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Code: @competition.Code</MudText>
                        </div>
                        <div class="d-flex gap-2 flex-wrap">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Tertiary"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Sync"
                                       OnClick="@(() => SyncCompetitionAsync(competition))">
                                Sync Competition
                            </MudButton>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Groups"
                                       OnClick="@(() => SyncTeamsAsync(competition))">
                                Sync Teams
                            </MudButton>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Secondary"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.SportsSoccer"
                                       OnClick="@(() => SyncMatchesAsync(competition))">
                                Sync Matches
                            </MudButton>
                            @if (competition.ExternalSources.Contains("Fpl"))
                            {
                            <MudButton Variant="Variant.Filled"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Assessment"
                                       Style="background:#38003c;color:#00ff85;font-weight:700;"
                                       Disabled="_pulseSyncing"
                                       OnClick="@(() => SyncFplDataAsync(competition))">
                                Sync PL Events
                            </MudButton>
                            }
                        </div>
                    </div>
                    @if (_pulseSyncing && competition.ExternalSources.Contains("Fpl"))
                    {
                        <div class="mt-3">
                            <MudProgressLinear Color="Color.Success" Value="@(_pulseTotal > 0 ? (double)_pulseProcessed / _pulseTotal * 100 : 0)" Class="my-2" Rounded="true" Size="Size.Medium">
                                <MudText Typo="Typo.caption">@_pulseProcessed / @_pulseTotal matches</MudText>
                            </MudProgressLinear>
                        </div>
                    }
                </MudPaper>
            }
        </MudStack>
    }
</MudContainer>
</PageGuard>
