@page "/leagues"

<PageGuard>
<MudContainer MaxWidth="MaxWidth.Medium" Class="py-4">

    @if (_predictionTiles.Count > 0)
    {
        <MudText Typo="Typo.h5" Style="font-weight:700;text-align:center;" Class="mb-3">Predictions</MudText>
        <div class="d-flex flex-wrap justify-center gap-4 mb-6">
            @foreach (var tile in _predictionTiles)
            {
                <MudPaper Elevation="3" Class="pa-5 rounded-xl"
                          Style="width:240px;text-align:center;background:linear-gradient(135deg, var(--mud-palette-tertiary) 0%, var(--mud-palette-primary) 100%);color:white;">
                    @if (tile.LogoUrl is not null)
                    {
                        <MudAvatar Size="Size.Large" Class="mb-2 mx-auto" Style="background:white;">
                            <MudImage Src="@tile.LogoUrl" Width="36" Height="36" />
                        </MudAvatar>
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Style="font-size:40px;opacity:0.9;" Class="mb-2" />
                    }
                    <MudText Typo="Typo.subtitle1" Style="font-weight:800;color:white;">@tile.CompetitionName</MudText>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.7);" Class="mb-3">@tile.SeasonName</MudText>
                    <MudButton Variant="Variant.Filled" Size="Size.Small"
                               Style="background:white;color:var(--mud-palette-tertiary);font-weight:700;"
                               StartIcon="@Icons.Material.Filled.Edit"
                               OnClick="@(() => NavigateToPredict(tile.CompetitionCode, tile.SeasonId))">
                        Predict Now
                    </MudButton>
                </MudPaper>
            }

            <MudPaper Elevation="1" Class="pa-5 rounded-xl d-flex flex-column align-center justify-center"
                      Style="width:240px;text-align:center;border:2px dashed var(--mud-palette-lines-default);cursor:pointer;"
                      @onclick="@(() => _showAddPredictionDialog = true)">
                <MudIcon Icon="@Icons.Material.Filled.Add" Style="font-size:40px;color:var(--mud-palette-text-secondary);" Class="mb-2" />
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Add Competition</MudText>
            </MudPaper>
        </div>
    }
    else if (_initialized && _leagues.Count > 0)
    {
        <div class="d-flex justify-center mb-6">
            <MudPaper Elevation="1" Class="pa-5 rounded-xl d-flex flex-column align-center justify-center"
                      Style="width:240px;text-align:center;border:2px dashed var(--mud-palette-lines-default);cursor:pointer;"
                      @onclick="@(() => _showAddPredictionDialog = true)">
                <MudIcon Icon="@Icons.Material.Filled.Add" Style="font-size:40px;color:var(--mud-palette-text-secondary);" Class="mb-2" />
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Start Predicting</MudText>
            </MudPaper>
        </div>
    }

    <div class="d-flex justify-space-between align-center mb-4">
        <MudText Typo="Typo.h5" Style="font-weight:700;">My Leagues</MudText>
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Login" OnClick="@(() => _showJoinDialog = true)">
                Join League
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Tertiary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => _showCreateDialog = true)">
                Create League
            </MudButton>
        </div>
    </div>

    @if (_initialized && _leagues.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            You haven't joined any prediction leagues yet. Create one or join with an invite code!
        </MudAlert>
    }
    else
    {
        <MudStack Spacing="3">
            @foreach (var league in _leagues)
            {
                <MudPaper Elevation="1" Class="pa-4 rounded-lg">
                    <div class="d-flex justify-space-between align-center" style="cursor:pointer;" @onclick="@(() => NavigateToLeague(league.Id))">
                        <div>
                            <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@league.Name</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @league.CompetitionName · @league.SeasonName · @league.MemberCount member@(league.MemberCount != 1 ? "s" : "") · Created by @league.OwnerDisplayName
                            </MudText>
                        </div>
                        <div class="d-flex align-center gap-2" @onclick:stopPropagation="true">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">@league.InviteCode</MudChip>
                            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                                           OnClick="@(() => CopyInviteCode(league.InviteCode))" />
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" />
                    </div>
                </MudPaper>
            }
        </MudStack>
    }
</MudContainer>
</PageGuard>

<MudDialog @bind-Visible="_showCreateDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>Create Prediction League</TitleContent>
    <DialogContent>
        <MudSelect T="CompetitionResult" @bind-Value="_selectedCompetition" Label="Competition" Variant="Variant.Outlined"
                   ToStringFunc="@(c => c?.Name ?? "")" Class="mb-3">
            @foreach (var comp in _competitions)
            {
                <MudSelectItem T="CompetitionResult" Value="comp">@comp.Name</MudSelectItem>
            }
        </MudSelect>
        <MudTextField @bind-Value="_newLeagueName" Label="League Name" Variant="Variant.Outlined"
                      Placeholder="e.g. The Lads" Immediate="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showCreateDialog = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Tertiary"
                   Disabled="@(string.IsNullOrWhiteSpace(_newLeagueName) || _selectedCompetition is null)"
                   OnClick="CreateLeagueAsync">Create</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_showJoinDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>Join a League</TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_inviteCode" Label="Invite Code" Variant="Variant.Outlined"
                      Placeholder="e.g. ABC123" Immediate="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showJoinDialog = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(string.IsNullOrWhiteSpace(_inviteCode))"
                   OnClick="JoinLeagueAsync">Join</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_showAddPredictionDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>Add Competition Predictions</TitleContent>
    <DialogContent>
        <MudSelect T="CompetitionResult" @bind-Value="_selectedCompetition" Label="Competition" Variant="Variant.Outlined"
                   ToStringFunc="@(c => c?.Name ?? "")">
            @foreach (var comp in _competitions)
            {
                var isActive = _predictionTiles.Any(t => t.CompetitionId == comp.Id);
                <MudSelectItem T="CompetitionResult" Value="comp" Disabled="isActive">
                    @comp.Name @(isActive ? "(Already Active)" : "")
                </MudSelectItem>
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showAddPredictionDialog = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Tertiary"
                   Disabled="@(_selectedCompetition is null)"
                   OnClick="AddPredictionForCompetition">Go</MudButton>
    </DialogActions>
</MudDialog>
