@page "/"
@attribute [Authorize]

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">

    <MudGrid Justify="Justify.Center">
        <MudItem xs="12" Class="d-flex flex-column align-center mb-6">
            <MudIcon Icon="@Icons.Material.Filled.SportsSoccer" Size="Size.Large" Color="Color.Secondary" />
            <MudText Typo="Typo.h3" Class="mt-2" Align="Align.Center">Welcome to ScoreCast</MudText>
            <MudText Typo="Typo.subtitle1" Color="Color.Secondary" Align="Align.Center">
                Premier League Predictions
            </MudText>
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="4" Justify="Justify.Center">
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="3" Class="rounded-lg" Style="height:100%;">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudAvatar Color="Color.Primary"><MudIcon Icon="@Icons.Material.Filled.EmojiEvents" /></MudAvatar>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Predict</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2">Submit your match predictions before kickoff and earn points for correct results.</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="3" Class="rounded-lg" Style="height:100%;">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudAvatar Color="Color.Secondary"><MudIcon Icon="@Icons.Material.Filled.Leaderboard" /></MudAvatar>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Compete</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2">Climb the leaderboard and compete against friends in private leagues.</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="3" Class="rounded-lg" Style="height:100%;">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudAvatar Color="Color.Tertiary"><MudIcon Icon="@Icons.Material.Filled.TrendingUp" /></MudAvatar>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Track</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2">Track your streaks, accuracy, and performance across the season.</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    <AuthorizeView>
        <Authorized>
            <MudGrid Justify="Justify.Center" Class="mt-8">
                <MudItem xs="12" sm="8" md="6">
                    <MudPaper Elevation="0" Class="d-flex flex-column align-center pa-6 rounded-lg mud-theme-primary" Style="opacity:0.9;">
                        <MudText Typo="Typo.h6" Color="Color.Surface">Ready, @context.User.Identity?.Name?</MudText>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Secondary"
                                   Size="Size.Large"
                                   Class="mt-4"
                                   StartIcon="@Icons.Material.Filled.PlayArrow">
                            Start Predicting
                        </MudButton>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </Authorized>
    </AuthorizeView>

</MudContainer>
