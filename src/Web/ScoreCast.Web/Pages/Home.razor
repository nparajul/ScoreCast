@page "/"

@if (!_isAuthenticated)
{
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">

    <AuthorizeView>
        <NotAuthorized>
            @* Hero *@
            <MudGrid Justify="Justify.Center" Class="mb-8">
                <MudItem xs="12" sm="10" md="8" Class="d-flex flex-column align-center">
                    <MudImage Src="scorecast-logo.svg" Alt="ScoreCast" Width="360" Class="mb-2" />
                    <MudText Typo="Typo.h5" Color="Color.Secondary" Align="Align.Center" Class="mt-2" Style="font-weight:700;">
                        Predict. Compete. Prove You Know Football.
                    </MudText>
                    <MudText Typo="Typo.body1" Align="Align.Center" Class="mt-2" Style="max-width:500px; color:var(--mud-palette-text-secondary);">
                        Predict exact scorelines, compete with friends in private leagues, and spice things up with risk plays — all for free, no betting involved.
                    </MudText>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Tertiary"
                               Size="Size.Large"
                               Class="mt-4"
                               StartIcon="@Icons.Material.Filled.Login"
                               Href="/login">
                        Get Started Free
                    </MudButton>

                    <div style="margin-top:24px;padding:12px 20px;border-radius:10px;border:1px solid var(--mud-palette-lines-default);background:var(--mud-palette-surface);max-width:500px;text-align:center;">
                        <MudText Typo="Typo.caption" Style="font-weight:700;color:var(--mud-palette-text-secondary);letter-spacing:0.5px;">
                            🚫 NOT A BETTING SITE
                        </MudText>
                        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);margin-top:2px;">
                            ScoreCast is a free prediction game for fun among friends. We do not facilitate, encourage, or endorse gambling or betting of any kind.
                        </MudText>
                    </div>
                </MudItem>
            </MudGrid>

            @* Features *@
            <MudGrid Spacing="4" Justify="Justify.Center" Class="mb-10">
                <MudItem xs="12" Class="d-flex flex-column align-center mb-2">
                    <MudText Typo="Typo.h4" Align="Align.Center" Style="font-weight:700;">What You Get</MudText>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="3" Class="rounded-lg" Style="height:100%;">
                        <MudCardHeader>
                            <CardHeaderAvatar><MudAvatar Color="Color.Tertiary">🏆</MudAvatar></CardHeaderAvatar>
                            <CardHeaderContent><MudText Typo="Typo.h6">Score Predictions</MudText></CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body2">Predict exact scorelines for every match. Earn points for correct results, bonus for exact scores.</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="3" Class="rounded-lg" Style="height:100%;">
                        <MudCardHeader>
                            <CardHeaderAvatar><MudAvatar Color="Color.Secondary">⚽</MudAvatar></CardHeaderAvatar>
                            <CardHeaderContent><MudText Typo="Typo.h6">Live Scores</MudText></CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body2">Follow every match in real time — goals, cards, substitutions, and minute-by-minute updates.</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="3" Class="rounded-lg" Style="height:100%;">
                        <MudCardHeader>
                            <CardHeaderAvatar><MudAvatar Color="Color.Primary">✨</MudAvatar></CardHeaderAvatar>
                            <CardHeaderContent><MudText Typo="Typo.h6">AI Insights</MudText></CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body2">AI-generated match previews with form analysis, head-to-head stats, and predicted outcomes to help you decide.</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="3" Class="rounded-lg" Style="height:100%;">
                        <MudCardHeader>
                            <CardHeaderAvatar><MudAvatar Color="Color.Secondary">👥</MudAvatar></CardHeaderAvatar>
                            <CardHeaderContent><MudText Typo="Typo.h6">Private Leagues</MudText></CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body2">Create a league, invite your mates, and compete head-to-head across the season. Your group, your rules.</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="3" Class="rounded-lg" Style="height:100%;">
                        <MudCardHeader>
                            <CardHeaderAvatar><MudAvatar Style="background:linear-gradient(135deg,#7c4dff,#651fff);color:#fff;">🎲</MudAvatar></CardHeaderAvatar>
                            <CardHeaderContent><MudText Typo="Typo.h6">Risk Plays</MudText></CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body2">Feeling brave? Place optional side bets each gameweek — Double Down, Exact Score Boost, Clean Sheet, and more. Earn bonus points or pay the price. No real money involved.</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="3" Class="rounded-lg" Style="height:100%;">
                        <MudCardHeader>
                            <CardHeaderAvatar><MudAvatar Color="Color.Primary">📊</MudAvatar></CardHeaderAvatar>
                            <CardHeaderContent><MudText Typo="Typo.h6">Tables & Stats</MudText></CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body2">League tables, player stats, top scorers, form guides — everything to follow the season at a glance.</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="3" Class="rounded-lg" Style="height:100%;">
                        <MudCardHeader>
                            <CardHeaderAvatar><MudAvatar Color="Color.Tertiary">🛡️</MudAvatar></CardHeaderAvatar>
                            <CardHeaderContent><MudText Typo="Typo.h6">Team Profiles</MudText></CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body2">Detailed team pages with squads, recent results, upcoming fixtures, and competition history.</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>

            @* Competitions *@
            <MudGrid Justify="Justify.Center" Class="mb-10">
                <MudItem xs="12" Class="d-flex flex-column align-center mb-4">
                    <MudText Typo="Typo.h4" Align="Align.Center" Style="font-weight:700;">Supported Competitions</MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center" Style="color:var(--mud-palette-text-secondary);">More coming soon</MudText>
                </MudItem>
                <MudItem xs="6" sm="3" Class="d-flex flex-column align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Shield" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Typo="Typo.subtitle1" Class="mt-2" Style="font-weight:600;">Premier League</MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center" Style="color:var(--mud-palette-text-secondary);">38 matchweeks, full season</MudText>
                </MudItem>
                <MudItem xs="6" sm="3" Class="d-flex flex-column align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Public" Size="Size.Large" Color="Color.Tertiary" />
                    <MudText Typo="Typo.subtitle1" Class="mt-2" Style="font-weight:600;">FIFA World Cup 2026</MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center" Style="color:var(--mud-palette-text-secondary);">Groups + knockout bracket</MudText>
                </MudItem>
            </MudGrid>

            @* How it works *@
            <MudGrid Justify="Justify.Center" Class="mt-6 mb-10">
                <MudItem xs="12" Class="d-flex flex-column align-center mb-4">
                    <MudText Typo="Typo.h4" Align="Align.Center" Style="font-weight:700;">How It Works</MudText>
                </MudItem>
                <MudItem xs="12" sm="4" Class="d-flex flex-column align-center">
                    <MudAvatar Color="Color.Secondary" Size="Size.Large"><MudText Typo="Typo.h5">1</MudText></MudAvatar>
                    <MudText Typo="Typo.subtitle1" Class="mt-2" Style="font-weight:600;">Sign Up</MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Inherit">Create your free account with email or Google sign-in.</MudText>
                </MudItem>
                <MudItem xs="12" sm="4" Class="d-flex flex-column align-center">
                    <MudAvatar Color="Color.Tertiary" Size="Size.Large"><MudText Typo="Typo.h5">2</MudText></MudAvatar>
                    <MudText Typo="Typo.subtitle1" Class="mt-2" Style="font-weight:600;">Predict</MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Inherit">Submit your exact scoreline for every match before kickoff.</MudText>
                </MudItem>
                <MudItem xs="12" sm="4" Class="d-flex flex-column align-center">
                    <MudAvatar Color="Color.Secondary" Size="Size.Large"><MudText Typo="Typo.h5">3</MudText></MudAvatar>
                    <MudText Typo="Typo.subtitle1" Class="mt-2" Style="font-weight:600;">Dominate</MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Inherit">Earn points, climb the leaderboard, and settle the debate once and for all.</MudText>
                </MudItem>
            </MudGrid>

            @* FAQ *@
            <MudGrid Justify="Justify.Center" Class="mb-10">
                <MudItem xs="12" sm="10" md="7">
                    <MudText Typo="Typo.h4" Align="Align.Center" Style="font-weight:700;" Class="mb-4">FAQ</MudText>

                    <MudExpansionPanels MultiExpansion="true" Elevation="1" Class="rounded-lg">
                        <MudExpansionPanel Text="Is ScoreCast a betting or gambling site?">
                            <MudText Typo="Typo.body2">No. ScoreCast is a free prediction game played purely for fun and bragging rights. There is no real money involved — no stakes, no wagers, no payouts. We do not facilitate, encourage, support, or endorse gambling or betting in any form. Terms like "risk plays" and "bonus points" refer only to in-game scoring mechanics with zero monetary value.</MudText>
                        </MudExpansionPanel>
                        <MudExpansionPanel Text="Is ScoreCast free?">
                            <MudText Typo="Typo.body2">Yes — ScoreCast is free, always and forever. No hidden fees, no catches. Just sign up and play.</MudText>
                        </MudExpansionPanel>
                        <MudExpansionPanel Text="What does beta mean?">
                            <MudText Typo="Typo.body2">I'm a full-time developer building ScoreCast in my spare time. Core features work — predictions, live scores, leagues, insights — but you may run into occasional bugs or rough edges. If you find any issues, please report them on <MudLink Href="https://github.com/nparajul/ScoreCast/issues" Target="_blank">GitHub Issues</MudLink> — it really helps!</MudText>
                        </MudExpansionPanel>
                        <MudExpansionPanel Text="How does scoring work?">
                            <MudText Typo="Typo.body2">You earn points based on how close your prediction is to the actual result. Exact scorelines earn 10 points, correct result and goal difference earns 7, correct result earns 5, and correct goal difference earns 3. You can also place optional risk plays each gameweek for bonus points (or penalties if you get them wrong).</MudText>
                        </MudExpansionPanel>
                        <MudExpansionPanel Text="What are Risk Plays?">
                            <MudText Typo="Typo.body2">Risk plays are optional side challenges you can add to your predictions each gameweek. Choose from Double Down, Exact Score Boost, Clean Sheet Bet, First Goal Team, or Over/Under 2.5 Goals. Get them right for bonus points, get them wrong and you lose points. They're purely for fun — no real money is involved.</MudText>
                        </MudExpansionPanel>
                        <MudExpansionPanel Text="Can I play with friends?">
                            <MudText Typo="Typo.body2">Absolutely. Create a private league, share the invite code, and compete against your group. You can join multiple leagues at once.</MudText>
                        </MudExpansionPanel>
                        <MudExpansionPanel Text="What competitions are supported?">
                            <MudText Typo="Typo.body2">Currently the Premier League (full 38-matchweek season) and the FIFA World Cup 2026 (groups + knockout). More competitions are on the roadmap.</MudText>
                        </MudExpansionPanel>
                        <MudExpansionPanel Text="What are AI Insights?">
                            <MudText Typo="Typo.body2">Before each gameweek, our AI analyzes form, head-to-head records, and recent results to generate match previews and predicted outcomes. Use them to inform your predictions — or ignore them and trust your gut.</MudText>
                        </MudExpansionPanel>
                        <MudExpansionPanel Text="Will my data be safe?">
                            <MudText Typo="Typo.body2">Authentication is handled by Google Firebase. We don't store passwords. Your predictions and profile data are stored securely and never shared with third parties.</MudText>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                </MudItem>
            </MudGrid>

            @* Final CTA *@
            <MudGrid Justify="Justify.Center" Class="mb-10">
                <MudItem xs="12" Class="d-flex flex-column align-center">
                    <MudText Typo="Typo.h5" Align="Align.Center" Style="font-weight:700;">Ready to prove you know football?</MudText>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Tertiary"
                               Size="Size.Large"
                               Class="mt-3"
                               StartIcon="@Icons.Material.Filled.RocketLaunch"
                               Href="/login">
                        Join the Beta
                    </MudButton>
                </MudItem>
            </MudGrid>
        </NotAuthorized>
    </AuthorizeView>

</MudContainer>
}
