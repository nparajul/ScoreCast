@page "/dashboard"

<PageGuard>
<div class="dashboard">

    @* ── Hero Card ── *@
    @if (_stats is not null && _stats.TotalPredictions > 0 && _stats.LastGameweek is not null)
    {
        var gw = _stats.LastGameweek;
        <div class="hero-card">
            <div class="hero-gw">Gameweek @gw.GameweekNumber</div>
            <div class="hero-stats">
                <div class="hero-stat">
                    <span class="hero-stat-value">@gw.UserCorrect/@gw.UserTotal</span>
                    <span class="hero-stat-label">You</span>
                </div>
                <div class="hero-stat hero-stat-main">
                    <span class="hero-stat-value">@gw.BeatPct<span style="font-size:0.5em;">%</span></span>
                    <span class="hero-stat-label">Beaten →</span>
                </div>
                <div class="hero-stat">
                    <span class="hero-stat-value">@gw.CommunityAvgCorrect/@gw.CommunityAvgTotal</span>
                    <span class="hero-stat-label">Average</span>
                </div>
            </div>

            @if (_stats.CurrentStreak >= 2)
            {
                <div class="hero-streak">🔥 @_stats.CurrentStreak-match streak</div>
            }

            @if (DeadlineUrgency is not null)
            {
                <div class="hero-deadline">@DeadlineUrgency</div>
            }

            @if (_userSeasons.Count > 0)
            {
                var first = _userSeasons[0];
                <button class="hero-btn" @onclick="@(() => Nav.NavigateTo($"/predict/{first.SeasonId}"))">
                    ⚽ Predict Now
                </button>
            }
        </div>
    }
    else if (DeadlineUrgency is not null)
    {
        <div class="hero-card hero-card-slim">
            <div class="hero-deadline" style="margin:0;">@DeadlineUrgency</div>
            @if (_userSeasons.Count > 0)
            {
                var first = _userSeasons[0];
                <button class="hero-btn" @onclick="@(() => Nav.NavigateTo($"/predict/{first.SeasonId}"))">
                    ⚽ Predict Now
                </button>
            }
        </div>
    }

    @* ── Achievements ── *@
    @if (_stats is not null && _stats.Achievements.Count > 0)
    {
        <div class="badge-row">
            @foreach (var badge in _stats.Achievements)
            {
                <span class="badge">@badge</span>
            }
        </div>
    }

    @* ── Competitions ── *@
    <div class="section">
        <div class="section-header">
            <span class="section-title">Competitions</span>
            @if (_userSeasons.Count > 1)
            {
                <button class="text-btn" @onclick="ToggleReorder">
                    @(_reordering ? "✓ Done" : "Reorder")
                </button>
            }
        </div>

        @if (_reordering)
        {
            @foreach (var us in _userSeasons)
            {
                var idx = _userSeasons.IndexOf(us);
                <div class="list-row reorder-row">
                    <MudIcon Icon="@Icons.Material.Filled.DragIndicator" Style="color:rgba(255,255,255,0.5);font-size:20px;" />
                    @if (us.CompetitionLogoUrl is not null)
                    {
                        <div class="reorder-logo">
                            <img src="@us.CompetitionLogoUrl" width="24" height="24" alt="" />
                        </div>
                    }
                    <span style="flex:1;font-weight:600;color:white;">@us.CompetitionName</span>
                    <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp" Size="Size.Small"
                                   Style="color:white;" Disabled="@(idx == 0)"
                                   OnClick="@(() => MoveItem(idx, idx - 1))" />
                    <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small"
                                   Style="color:white;" Disabled="@(idx == _userSeasons.Count - 1)"
                                   OnClick="@(() => MoveItem(idx, idx + 1))" />
                </div>
            }
        }
        else
        {
            @foreach (var us in _userSeasons)
            {
                <div class="list-row" @onclick="@(() => Nav.NavigateTo($"/predict/{us.SeasonId}"))">
                    @if (us.CompetitionLogoUrl is not null)
                    {
                        <img src="@us.CompetitionLogoUrl" width="32" height="32" alt="" style="object-fit:contain;" />
                    }
                    <div style="flex:1;">
                        <div class="list-row-title">@us.CompetitionName</div>
                        <div class="list-row-sub">@us.SeasonName Season</div>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Style="color:var(--mud-palette-text-secondary);font-size:20px;" />
                </div>
            }

            <div class="list-row list-row-add" @onclick="@(() => _showAddPredictionDialog = true)">
                <MudIcon Icon="@Icons.Material.Filled.Add" Style="color:var(--mud-palette-tertiary);font-size:20px;" />
                <span class="list-row-title" style="color:var(--mud-palette-tertiary);">Add Competition</span>
            </div>
        }
    </div>

    @* ── Leagues ── *@
    <div class="section">
        <div class="section-header">
            <span class="section-title">My Leagues</span>
            <div class="d-flex gap-2">
                <button class="text-btn" @onclick="@(() => _showJoinDialog = true)">Join</button>
                <button class="pill-btn" @onclick="@(() => _showCreateDialog = true)">+ Create</button>
            </div>
        </div>

        @if (_initialized && _leagues.Count == 0)
        {
            <div class="empty-hint">Create a league or join with an invite code</div>
        }
        else
        {
            @foreach (var league in _leagues)
            {
                <div class="list-row" @onclick="@(() => NavigateToLeague(league.Id))">
                    <div style="flex:1;min-width:0;">
                        <div class="list-row-title">@league.Name</div>
                        <div class="list-row-sub">@league.CompetitionName · @league.MemberCount members</div>
                    </div>
                    <div class="d-flex align-center gap-1" @onclick:stopPropagation="true">
                        <span class="invite-code">@league.InviteCode</span>
                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                                       Style="color:var(--mud-palette-text-secondary);"
                                       OnClick="@(() => CopyInviteCode(league.InviteCode))" />
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Style="color:var(--mud-palette-text-secondary);font-size:20px;" />
                </div>
            }
        }
    </div>

    @if (_initialized && _userSeasons.Count == 0 && _leagues.Count == 0)
    {
        <div class="section">
            <div class="list-row" @onclick='@(() => Nav.NavigateTo("/how-to-play"))'>
                <MudIcon Icon="@Icons.Material.Filled.HelpOutline" Style="color:var(--mud-palette-text-secondary);font-size:20px;" />
                <span class="list-row-title">How to Play</span>
                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Style="color:var(--mud-palette-text-secondary);font-size:20px;" />
            </div>
        </div>
    }

</div>
</PageGuard>

<MudDialog @bind-Visible="_showCreateDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>Create Prediction League</TitleContent>
    <DialogContent>
        <MudSelect T="CompetitionResult" @bind-Value="_selectedCompetition" Label="Competition" Variant="Variant.Outlined"
                   ToStringFunc="@(c => c?.Name ?? "")" Class="mb-3">
            @foreach (var comp in _competitions)
            {
                <MudSelectItem T="CompetitionResult" Value="comp">@comp.Name</MudSelectItem>
            }
        </MudSelect>
        <MudTextField @bind-Value="_newLeagueName" Label="League Name" Variant="Variant.Outlined"
                      Placeholder="e.g. The Lads" Immediate="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showCreateDialog = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Tertiary"
                   Disabled="@(string.IsNullOrWhiteSpace(_newLeagueName) || _selectedCompetition is null)"
                   OnClick="CreateLeagueAsync">Create</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_showJoinDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>Join a League</TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_inviteCode" Label="Invite Code" Variant="Variant.Outlined"
                      Placeholder="e.g. ABC123" Immediate="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showJoinDialog = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(string.IsNullOrWhiteSpace(_inviteCode))"
                   OnClick="JoinLeagueAsync">Join</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_showAddPredictionDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>Add Competition</TitleContent>
    <DialogContent>
        <MudSelect T="CompetitionResult" @bind-Value="_selectedCompetition" Label="Competition" Variant="Variant.Outlined"
                   ToStringFunc="@(c => c?.Name ?? "")">
            @foreach (var comp in _competitions)
            {
                var isActive = _userSeasons.Any(us => us.CompetitionId == comp.Id);
                <MudSelectItem T="CompetitionResult" Value="comp" Disabled="isActive">
                    @comp.Name @(isActive ? "(Active)" : "")
                </MudSelectItem>
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showAddPredictionDialog = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Tertiary"
                   Disabled="@(_selectedCompetition is null)"
                   OnClick="AddPredictionForCompetition">Go</MudButton>
    </DialogActions>
</MudDialog>
