@page "/dashboard"

<PageGuard>
<MudContainer MaxWidth="MaxWidth.Medium" Class="py-4">

    <div class="d-flex justify-end mb-2">
        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.HelpOutline"
                   Href="/how-to-play">
            How to Play
        </MudButton>
    </div>

    @if (DeadlineUrgency is not null)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Dense="true" Class="mb-3"
                  Style="border-radius:10px;font-weight:600;">
            @DeadlineUrgency
        </MudAlert>
    }

    @if (_stats is not null && _stats.TotalPredictions > 0)
    {
        @* Streak Banner *@
        @if (_stats.CurrentStreak >= 2)
        {
            <MudPaper Class="pa-3 mb-3" Elevation="1" Style="border-radius:10px;background:linear-gradient(135deg,#ff6b35,#ff8f00);color:white;text-align:center;">
                <MudText Typo="Typo.h6" Style="font-weight:800;color:white;">🔥 @_stats.CurrentStreak-match streak!</MudText>
                <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.8);">
                    @(_stats.StreakType == "exact" ? "Including exact scores!" : "Keep it going!")
                    Best ever: @_stats.BestStreak
                </MudText>
            </MudPaper>
        }

        @* You vs Community *@
        @if (_stats.LastGameweek is not null)
        {
            var gw = _stats.LastGameweek;
            <MudPaper Class="pa-3 mb-3" Elevation="1" Style="border-radius:10px;">
                <MudText Typo="Typo.subtitle2" Style="font-weight:700;">📊 GW@(gw.GameweekNumber) Recap</MudText>
                <div class="d-flex justify-space-around text-center mt-2">
                    <div>
                        <MudText Typo="Typo.h5" Style="font-weight:800;color:#FF6B35;">@gw.UserCorrect/@gw.UserTotal</MudText>
                        <MudText Typo="Typo.caption" Style="opacity:0.6;">Your results</MudText>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Style="font-weight:800;">@gw.CommunityAvgCorrect/@gw.CommunityAvgTotal</MudText>
                        <MudText Typo="Typo.caption" Style="opacity:0.6;">Community avg</MudText>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Style="@($"font-weight:800;color:{(gw.BeatPct >= 50 ? "#4CAF50" : "#f44336")}")">@(gw.BeatPct)%</MudText>
                        <MudText Typo="Typo.caption" Style="opacity:0.6;">Beaten</MudText>
                    </div>
                </div>
            </MudPaper>
        }

        @* Achievements *@
        @if (_stats.Achievements.Count > 0)
        {
            <div class="d-flex flex-wrap gap-1 mb-3">
                @foreach (var badge in _stats.Achievements)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                             Style="background:rgba(255,107,53,0.15);color:#FF6B35;font-weight:600;font-size:0.7rem;">
                        @badge
                    </MudChip>
                }
            </div>
        }
    }

    @if (_userSeasons.Count > 0)
    {
        <MudText Typo="Typo.h5" Style="font-weight:700;text-align:center;" Class="mb-3">Predictions</MudText>
        <div id="tile-container" class="d-flex flex-wrap justify-center gap-3 mb-6">
            @foreach (var us in _userSeasons)
            {
                var idx = _userSeasons.IndexOf(us);
                <MudPaper Elevation="@(_dragIndex == idx ? 6 : 3)"
                          Class="rounded-xl overflow-hidden d-flex flex-column prediction-tile"
                          Style="@($"text-align:center;color:white;transition:transform 0.15s,box-shadow 0.15s;position:relative;{(_dragIndex == idx ? "transform:scale(1.05);opacity:0.7;" : "")}")"
                          draggable="true"
                          data-drag-idx="@idx"
                          @ondragstart="@(() => _dragIndex = idx)"
                          @ondragover:preventDefault
                          @ondragenter="@(() => OnDragEnter(idx))"
                          @ondragend="OnDragEnd">
                    @if (us.CompetitionLogoUrl is not null)
                    {
                        <div style="background:rgba(255,255,255,0.95);padding:12px 0;display:flex;align-items:center;justify-content:center;">
                            <MudImage Src="@us.CompetitionLogoUrl" Width="56" Height="56" ObjectFit="ObjectFit.Contain" />
                        </div>
                    }
                    else
                    {
                        <div style="background:rgba(255,255,255,0.1);padding:12px 0;display:flex;align-items:center;justify-content:center;">
                            <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Style="font-size:48px;opacity:0.9;" />
                        </div>
                    }
                    <div class="pa-3 d-flex flex-column align-center flex-grow-1"
                         style="background:linear-gradient(135deg, var(--mud-palette-tertiary) 0%, var(--mud-palette-primary) 100%);">
                        <MudText Typo="Typo.body2" Style="font-weight:700;color:white;line-height:1.2;">@us.CompetitionName</MudText>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                 Style="color:rgba(255,255,255,0.85);border-color:rgba(255,255,255,0.4);font-weight:600;font-size:0.7rem;"
                                 Class="mt-1 mb-2">
                            @us.SeasonName Season
                        </MudChip>
                        <MudButton Variant="Variant.Filled" Size="Size.Small" FullWidth="true"
                                   Style="background:white;color:var(--mud-palette-tertiary);font-weight:700;border-radius:8px;font-size:0.75rem;"
                                   StartIcon="@Icons.Material.Filled.SportsSoccer"
                                   OnClick="@(() => Nav.NavigateTo($"/predict/{us.SeasonId}"))">
                            Predict
                        </MudButton>
                    </div>
                </MudPaper>
            }

            <MudPaper Elevation="1" Class="pa-4 rounded-xl d-flex flex-column align-center justify-center prediction-tile"
                      Style="text-align:center;border:2px dashed var(--mud-palette-lines-default);cursor:pointer;"
                      @onclick="@(() => _showAddPredictionDialog = true)">
                <MudIcon Icon="@Icons.Material.Filled.Add" Style="font-size:32px;color:var(--mud-palette-text-secondary);" Class="mb-1" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">Add Competition</MudText>
            </MudPaper>
        </div>
    }
    else if (_initialized)
    {
        <MudText Typo="Typo.h5" Style="font-weight:700;text-align:center;" Class="mb-1">Predictions</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Style="text-align:center;" Class="mb-3">Pick a competition to start predicting scores</MudText>
        <div class="d-flex justify-center mb-6">
            <MudPaper Elevation="1" Class="pa-4 rounded-xl d-flex flex-column align-center justify-center prediction-tile"
                      Style="text-align:center;border:2px dashed var(--mud-palette-lines-default);cursor:pointer;"
                      @onclick="@(() => _showAddPredictionDialog = true)">
                <MudIcon Icon="@Icons.Material.Filled.Add" Style="font-size:32px;color:var(--mud-palette-text-secondary);" Class="mb-1" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">Add Competition</MudText>
            </MudPaper>
        </div>
    }

    <div class="d-flex flex-column flex-sm-row justify-space-between align-start align-sm-center gap-2 mb-4">
        <MudText Typo="Typo.h5" Style="font-weight:700;">My Leagues</MudText>
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Login" OnClick="@(() => _showJoinDialog = true)">
                Join League
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Tertiary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => _showCreateDialog = true)">
                Create League
            </MudButton>
        </div>
    </div>

    @if (_initialized && _leagues.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            You haven't joined any prediction leagues yet. Create one or join with an invite code!
        </MudAlert>
    }
    else
    {
        <MudStack Spacing="3">
            @foreach (var league in _leagues)
            {
                <MudPaper Elevation="1" Class="pa-4 rounded-lg">
                    <div class="d-flex justify-space-between align-center" style="cursor:pointer;" @onclick="@(() => NavigateToLeague(league.Id))">
                        <div>
                            <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@league.Name</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @league.CompetitionName · @league.SeasonName · @league.MemberCount member@(league.MemberCount != 1 ? "s" : "") · Created by @league.OwnerDisplayName
                            </MudText>
                        </div>
                        <div class="d-flex align-center gap-2" @onclick:stopPropagation="true">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">@league.InviteCode</MudChip>
                            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                                           OnClick="@(() => CopyInviteCode(league.InviteCode))" />
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" />
                    </div>
                </MudPaper>
            }
        </MudStack>
    }
</MudContainer>
</PageGuard>

<MudDialog @bind-Visible="_showCreateDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>Create Prediction League</TitleContent>
    <DialogContent>
        <MudSelect T="CompetitionResult" @bind-Value="_selectedCompetition" Label="Competition" Variant="Variant.Outlined"
                   ToStringFunc="@(c => c?.Name ?? "")" Class="mb-3">
            @foreach (var comp in _competitions)
            {
                <MudSelectItem T="CompetitionResult" Value="comp">@comp.Name</MudSelectItem>
            }
        </MudSelect>
        <MudTextField @bind-Value="_newLeagueName" Label="League Name" Variant="Variant.Outlined"
                      Placeholder="e.g. The Lads" Immediate="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showCreateDialog = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Tertiary"
                   Disabled="@(string.IsNullOrWhiteSpace(_newLeagueName) || _selectedCompetition is null)"
                   OnClick="CreateLeagueAsync">Create</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_showJoinDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>Join a League</TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_inviteCode" Label="Invite Code" Variant="Variant.Outlined"
                      Placeholder="e.g. ABC123" Immediate="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showJoinDialog = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(string.IsNullOrWhiteSpace(_inviteCode))"
                   OnClick="JoinLeagueAsync">Join</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_showAddPredictionDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>Add Competition Predictions</TitleContent>
    <DialogContent>
        <MudSelect T="CompetitionResult" @bind-Value="_selectedCompetition" Label="Competition" Variant="Variant.Outlined"
                   ToStringFunc="@(c => c?.Name ?? "")">
            @foreach (var comp in _competitions)
            {
                var isActive = _userSeasons.Any(us => us.CompetitionId == comp.Id);
                <MudSelectItem T="CompetitionResult" Value="comp" Disabled="isActive">
                    @comp.Name @(isActive ? "(Already Active)" : "")
                </MudSelectItem>
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showAddPredictionDialog = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Tertiary"
                   Disabled="@(_selectedCompetition is null)"
                   OnClick="AddPredictionForCompetition">Go</MudButton>
    </DialogActions>
</MudDialog>
