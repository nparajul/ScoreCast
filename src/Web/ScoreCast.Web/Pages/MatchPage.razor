@page "/matches/{MatchId:long}"

<PageGuard>
@if (_loaded && _match is not null)
{
<div>
    <MudContainer MaxWidth="MaxWidth.Medium" Style="padding-top:12px;padding-bottom:100px;">

        @* Scoreboard *@
        <MudPaper Elevation="1" Style="border-radius:12px;overflow:hidden;padding:20px 16px;text-align:center;">
            @if (_match.Status == nameof(MatchStatus.Live))
            {
                <div class="d-flex align-center justify-center gap-2 mb-2">
                    <span class="live-pulse"></span>
                    <span style="font-size:12px;font-weight:700;color:#f44336;letter-spacing:1px;">LIVE</span>
                    @if (_clockDisplay is not null)
                    {
                        <span style="font-size:13px;font-weight:700;font-variant-numeric:tabular-nums;">@_clockDisplay</span>
                    }
                </div>
            }
            else if (_match.Status == nameof(MatchStatus.Finished))
            {
                <div style="font-size:12px;font-weight:700;color:var(--mud-palette-text-secondary);margin-bottom:8px;">FULL TIME</div>
            }
            else if (_match.KickoffTime.HasValue)
            {
                <div style="font-size:12px;color:var(--mud-palette-text-secondary);margin-bottom:8px;">
                    @FormatLocal(_match.KickoffTime.Value, "ddd dd MMM yyyy, HH:mm")
                </div>
            }

            <div class="d-flex align-center justify-center" style="gap:@(IsMobile ? "12" : "24")px;">
                <a href="/teams/@_match.HomeTeamId" style="text-decoration:none;color:inherit;text-align:center;flex:1;">
                    @if (_match.HomeTeamLogo is not null)
                    {
                        <img src="@_match.HomeTeamLogo" alt="" style="width:@(IsMobile ? "48" : "64")px;height:@(IsMobile ? "48" : "64")px;display:block;margin:0 auto 6px;" />
                    }
                    <div style="font-weight:700;font-size:@(IsMobile ? "13" : "15")px;">@_match.HomeTeamShortName</div>
                </a>

                <div style="min-width:80px;">
                    @if (_match.Status is nameof(MatchStatus.Live) or nameof(MatchStatus.Finished))
                    {
                        <div style="font-size:@(IsMobile ? "28" : "36")px;font-weight:800;font-variant-numeric:tabular-nums;color:@(_match.Status == nameof(MatchStatus.Live) ? "#4caf50" : "inherit");">
                            @(_match.HomeScore ?? 0) - @(_match.AwayScore ?? 0)
                        </div>
                        @if (_match.HalfTimeHomeScore is not null && _match.Phase is not (PulseApi.Phase.FirstHalf or PulseApi.Phase.HalfTime))
                        {
                            <div style="font-size:11px;color:var(--mud-palette-text-secondary);">HT: @_match.HalfTimeHomeScore - @_match.HalfTimeAwayScore</div>
                        }
                    }
                    else
                    {
                        <div style="font-size:20px;font-weight:700;color:var(--mud-palette-text-secondary);">vs</div>
                    }
                </div>

                <a href="/teams/@_match.AwayTeamId" style="text-decoration:none;color:inherit;text-align:center;flex:1;">
                    @if (_match.AwayTeamLogo is not null)
                    {
                        <img src="@_match.AwayTeamLogo" alt="" style="width:@(IsMobile ? "48" : "64")px;height:@(IsMobile ? "48" : "64")px;display:block;margin:0 auto 6px;" />
                    }
                    <div style="font-weight:700;font-size:@(IsMobile ? "13" : "15")px;">@_match.AwayTeamShortName</div>
                </a>
            </div>

            <div style="margin-top:10px;font-size:12px;color:var(--mud-palette-text-secondary);">
                <div class="d-flex align-center justify-center gap-1 mb-1">
                    @if (_match.CompetitionLogo is not null) { <img src="@_match.CompetitionLogo" alt="" style="width:14px;height:14px;" /> }
                    <span style="font-weight:600;">@_match.CompetitionName</span>
                </div>
                @if (_match.Venue is not null) { <div>🏟️ @_match.Venue</div> }
                @if (_match.Referee is not null) { <div>🧑‍⚖️ @_match.Referee</div> }
            </div>
        </MudPaper>

        @* Tabs *@
        <div style="display:flex;background:var(--mud-palette-dark);border-radius:28px;padding:3px;margin:12px 0;">
            @foreach (var tab in new[] { "Events", "Lineups", "Stats", "Table" })
            {
                var isActive = _activeTab == tab;
                <div @onclick="@(() => { _activeTab = tab; if (tab == "Stats" && _extras is null) _ = LoadExtrasAsync(); })"
                     style="flex:1;text-align:center;padding:8px 0;border-radius:24px;font-size:0.8rem;font-weight:700;cursor:pointer;
                            background:@(isActive ? "var(--mud-palette-surface)" : "transparent");
                            color:@(isActive ? "var(--mud-palette-primary)" : "rgba(255,255,255,0.7)");">
                    @tab
                </div>
            }
        </div>

        @* Events Tab *@
        @if (_activeTab == "Events")
        {
            <MudPaper Elevation="1" Style="border-radius:12px;overflow:hidden;">
                @if (OrderedEvents.Count > 0 || _match.Status != nameof(MatchStatus.Scheduled))
                {
                    var isLive = _match.Status == nameof(MatchStatus.Live);
                    var isFinished = _match.Status == nameof(MatchStatus.Finished);

                    @* Kick Off — top for finished, bottom for live *@
                    @if (isFinished)
                    {
                        @RenderDivider("⏱️ Kick Off")
                    }

                    var events = OrderedEvents;
                    var htShown = false;
                    var pastHalfTime = _match.Phase is PulseApi.Phase.HalfTime or PulseApi.Phase.SecondHalf || isFinished;
                    @foreach (var evt in events)
                    {
                        if (!htShown && pastHalfTime && (isLive ? !IsSecondHalf(evt.Minute) : IsSecondHalf(evt.Minute)))
                        {
                            htShown = true;
                            @RenderDivider($"HT {(_match.HalfTimeHomeScore is not null ? $"{_match.HalfTimeHomeScore} - {_match.HalfTimeAwayScore}" : "")}")
                        }

                        var isSub = evt.EventType == EventTypes.SubIn;
                        <div style="display:flex;align-items:center;padding:6px 8px;gap:0;border-bottom:1px solid var(--mud-palette-divider);">
                            @* Left side (home) *@
                            <div style="flex:1;text-align:right;padding-right:6px;">
                                @if (evt.IsHome)
                                {
                                    @if (isSub)
                                    {
                                        <div style="font-size:11px;font-weight:600;color:#4caf50;">@evt.PlayerName</div>
                                        <div style="font-size:11px;color:#f44336;">@evt.PlayerOff</div>
                                    }
                                    else
                                    {
                                        <div style="font-weight:600;font-size:12px;">
                                            @evt.PlayerName
                                            @if (evt.RunningScore is not null) { <span style="color:var(--mud-palette-text-secondary);font-size:10px;">(@((MarkupString)FormatRunningScore(evt.RunningScore, true)))</span> }
                                        </div>
                                        @if (evt.EventType == EventTypes.OwnGoal) { <div style="font-size:10px;color:var(--mud-palette-text-secondary);">Own goal</div> }
                                        @if (evt.EventType == EventTypes.PenaltyGoal) { <div style="font-size:10px;color:var(--mud-palette-text-secondary);">Penalty</div> }
                                        @if (evt.AssistName is not null) { <div style="font-size:10px;color:var(--mud-palette-text-secondary);">@evt.AssistName</div> }
                                    }
                                }
                            </div>

                            @* Center: icon + minute *@
                            <div style="display:flex;flex-direction:column;align-items:center;min-width:44px;">
                                <span style="font-size:13px;">@((MarkupString)EventIcon(evt.EventType))</span>
                                <span style="font-size:11px;font-weight:800;">@evt.Minute</span>
                            </div>

                            @* Right side (away) *@
                            <div style="flex:1;padding-left:6px;">
                                @if (!evt.IsHome)
                                {
                                    @if (isSub)
                                    {
                                        <div style="font-size:11px;font-weight:600;color:#4caf50;">@evt.PlayerName</div>
                                        <div style="font-size:11px;color:#f44336;">@evt.PlayerOff</div>
                                    }
                                    else
                                    {
                                        <div style="font-weight:600;font-size:12px;">
                                            @evt.PlayerName
                                            @if (evt.RunningScore is not null) { <span style="color:var(--mud-palette-text-secondary);font-size:10px;">(@((MarkupString)FormatRunningScore(evt.RunningScore, false)))</span> }
                                        </div>
                                        @if (evt.EventType == EventTypes.OwnGoal) { <div style="font-size:10px;color:var(--mud-palette-text-secondary);">Own goal</div> }
                                        @if (evt.EventType == EventTypes.PenaltyGoal) { <div style="font-size:10px;color:var(--mud-palette-text-secondary);">Penalty</div> }
                                        @if (evt.AssistName is not null) { <div style="font-size:10px;color:var(--mud-palette-text-secondary);">@evt.AssistName</div> }
                                    }
                                }
                            </div>
                        </div>
                    }

                    @* Kick Off — bottom for live *@
                    @if (isLive)
                    {
                        @RenderDivider("⏱️ Kick Off")
                    }

                    @* Full Time — bottom for finished *@
                    @if (isFinished)
                    {
                        @RenderDivider($"FT {_match.HomeScore} - {_match.AwayScore}")
                    }
                }
                else
                {
                    <div style="padding:24px;text-align:center;color:var(--mud-palette-text-secondary);font-size:13px;">
                        @if (_match.Status == nameof(MatchStatus.Scheduled))
                        {
                            @if (_match.HomeFormation is not null)
                            {
                                <text>✅ Lineups confirmed — match hasn't kicked off yet</text>
                            }
                            else
                            {
                                <text>Match hasn't started yet</text>
                            }
                        }
                        else
                        {
                            <text>No events recorded</text>
                        }
                    </div>
                }
            </MudPaper>
        }

        @* Lineups Tab *@
        @if (_activeTab == "Lineups")
        {
            @if (_match.HomeLineup.Count > 0 || _match.AwayLineup.Count > 0)
            {
                @if (_match.HomeFormation is not null || _match.AwayFormation is not null)
                {
                    @if (IsMobile)
                    {
                        var showHome = _lineupTab == "home";
                        var activeRows = showHome
                            ? (_match.HomeFormation is not null ? GetFormationRows(_match.HomeLineup, _match.HomeFormation, false) : new List<List<MatchPageLineupPlayer>>())
                            : (_match.AwayFormation is not null ? GetFormationRows(_match.AwayLineup, _match.AwayFormation, true, mirrorRows: true) : new List<List<MatchPageLineupPlayer>>());
                        var activeFormation = showHome ? _match.HomeFormation : _match.AwayFormation;

                        @* Team toggle *@
                        <div class="d-flex" style="gap:4px;margin-bottom:4px;">
                            <button @onclick='() => { _lineupTab = "home"; }'
                                    style="flex:1;padding:8px 6px;border:none;border-radius:8px;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:2px;
                                           background:@(showHome ? "var(--mud-palette-primary)" : "var(--mud-palette-surface)");
                                           color:@(showHome ? "white" : "inherit");font-family:inherit;">
                                <span style="display:flex;align-items:center;gap:5px;font-weight:700;font-size:13px;">
                                    @if (_match.HomeTeamLogo is not null) { <img src="@_match.HomeTeamLogo" alt="" style="width:16px;height:16px;" /> }
                                    @_match.HomeTeamShortName
                                </span>
                                <span style="font-size:11px;font-weight:500;opacity:0.6;">@_match.HomeFormation</span>
                            </button>
                            <button @onclick='() => { _lineupTab = "away"; }'
                                    style="flex:1;padding:8px 6px;border:none;border-radius:8px;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:2px;
                                           background:@(!showHome ? "var(--mud-palette-primary)" : "var(--mud-palette-surface)");
                                           color:@(!showHome ? "white" : "inherit");font-family:inherit;">
                                <span style="display:flex;align-items:center;gap:5px;font-weight:700;font-size:13px;">
                                    @if (_match.AwayTeamLogo is not null) { <img src="@_match.AwayTeamLogo" alt="" style="width:16px;height:16px;" /> }
                                    @_match.AwayTeamShortName
                                </span>
                                <span style="font-size:11px;font-weight:500;opacity:0.6;">@_match.AwayFormation</span>
                            </button>
                        </div>

                        @* Single-team pitch *@
                        <MudPaper Elevation="1" Style="border-radius:12px;overflow:hidden;background:linear-gradient(180deg, #1b5e20 0%, #2e7d32 100%);position:relative;">
                            <div style="position:absolute;inset:0;pointer-events:none;">
                                <div style="position:absolute;@(showHome ? "top" : "bottom"):0;left:50%;transform:translateX(-50%);width:55%;height:50px;border:1px solid rgba(255,255,255,0.15);border-@(showHome ? "top" : "bottom"):none;"></div>
                                <div style="position:absolute;@(showHome ? "top" : "bottom"):0;left:50%;transform:translateX(-50%);width:22%;height:20px;border:1px solid rgba(255,255,255,0.25);border-@(showHome ? "top" : "bottom"):none;"></div>
                            </div>
                            <div style="display:flex;flex-direction:column;justify-content:space-evenly;min-height:380px;padding:4px 0 12px 0;">
                                @foreach (var row in activeRows)
                                {
                                    <div style="display:flex;justify-content:space-evenly;">
                                        @foreach (var p in row) { @RenderPlayerCard(p, 38) }
                                    </div>
                                }
                            </div>
                        </MudPaper>
                    }
                    else
                    {
                        @* Desktop: side-by-side headers *@
                        <div class="d-flex" style="margin-bottom:4px;gap:4px;">
                            <MudPaper Elevation="1" Style="flex:1;border-radius:8px;padding:6px 10px;text-align:center;">
                                <div class="d-flex align-center justify-center gap-2">
                                    @if (_match.HomeTeamLogo is not null) { <img src="@_match.HomeTeamLogo" alt="" style="width:18px;height:18px;" /> }
                                    <span style="font-size:12px;font-weight:700;">@_match.HomeTeamShortName</span>
                                    <span style="font-size:11px;color:var(--mud-palette-text-secondary);font-weight:600;">@_match.HomeFormation</span>
                                </div>
                            </MudPaper>
                            <MudPaper Elevation="1" Style="flex:1;border-radius:8px;padding:6px 10px;text-align:center;">
                                <div class="d-flex align-center justify-center gap-2">
                                    @if (_match.AwayTeamLogo is not null) { <img src="@_match.AwayTeamLogo" alt="" style="width:18px;height:18px;" /> }
                                    <span style="font-size:12px;font-weight:700;">@_match.AwayTeamShortName</span>
                                    <span style="font-size:11px;color:var(--mud-palette-text-secondary);font-weight:600;">@_match.AwayFormation</span>
                                </div>
                            </MudPaper>
                        </div>
                        @* Desktop: side-by-side, teams facing each other *@
                        <MudPaper Elevation="1" Style="border-radius:12px;overflow:hidden;background:linear-gradient(90deg, #1b5e20 0%, #2e7d32 50%, #1b5e20 100%);position:relative;padding:16px 0;">
                            <div style="position:absolute;inset:0;pointer-events:none;">
                                <div style="position:absolute;left:50%;top:8%;bottom:8%;width:1px;background:rgba(255,255,255,0.15);"></div>
                                <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:70px;height:70px;border:1px solid rgba(255,255,255,0.15);border-radius:50%;"></div>
                                @* Home penalty area (left) *@
                                <div style="position:absolute;left:0;top:50%;transform:translateY(-50%);width:50px;height:50%;border:1px solid rgba(255,255,255,0.15);border-left:none;"></div>
                                <div style="position:absolute;left:0;top:50%;transform:translateY(-50%);width:20px;height:22%;border:1px solid rgba(255,255,255,0.25);border-left:none;"></div>
                                @* Away penalty area (right) *@
                                <div style="position:absolute;right:0;top:50%;transform:translateY(-50%);width:50px;height:50%;border:1px solid rgba(255,255,255,0.15);border-right:none;"></div>
                                <div style="position:absolute;right:0;top:50%;transform:translateY(-50%);width:20px;height:22%;border:1px solid rgba(255,255,255,0.25);border-right:none;"></div>
                            </div>
                            <div class="d-flex align-center" style="min-height:360px;">
                                @* Home (left half): GK left → FWD right *@
                                <div style="flex:1;display:flex;justify-content:space-evenly;align-items:center;padding:0 4px;">
                                    @if (_match.HomeFormation is not null)
                                    {
                                        @foreach (var row in GetFormationRows(_match.HomeLineup, _match.HomeFormation, false))
                                        {
                                            <div style="display:flex;flex-direction:column;align-items:center;gap:4px;">
                                                @foreach (var p in row) { @RenderPlayerCard(p, 40) }
                                            </div>
                                        }
                                    }
                                </div>
                                @* Away (right half): FWD left → GK right *@
                                <div style="flex:1;display:flex;justify-content:space-evenly;align-items:center;padding:0 4px;">
                                    @if (_match.AwayFormation is not null)
                                    {
                                        @foreach (var row in GetFormationRows(_match.AwayLineup, _match.AwayFormation, true, mirrorRows: true))
                                        {
                                            <div style="display:flex;flex-direction:column;align-items:center;gap:4px;">
                                                @foreach (var p in row) { @RenderPlayerCard(p, 40) }
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        </MudPaper>
                    }
                }

                @* Coaches *@
                @if (_match.HomeCoach is not null || _match.AwayCoach is not null)
                {
                    <MudPaper Elevation="1" Style="border-radius:12px;overflow:hidden;margin-top:12px;">
                        <div class="d-flex" style="padding:10px 14px;">
                            <div class="d-flex align-center gap-2" style="flex:1;">
                                @if (_match.HomeCoachPhoto is not null)
                                {
                                    <img src="@_match.HomeCoachPhoto" alt="" style="width:36px;height:36px;border-radius:50%;object-fit:cover;" />
                                }
                                <div>
                                    <div style="font-size:10px;color:var(--mud-palette-text-secondary);font-weight:700;">COACH</div>
                                    <div style="font-size:13px;font-weight:600;">@(_match.HomeCoach ?? "—")</div>
                                    <div style="font-size:10px;color:var(--mud-palette-text-secondary);">@_match.HomeTeamShortName</div>
                                </div>
                            </div>
                            <div style="width:1px;background:var(--mud-palette-divider);margin:0 10px;"></div>
                            <div class="d-flex align-center gap-2" style="flex:1;justify-content:flex-end;">
                                <div style="text-align:right;">
                                    <div style="font-size:10px;color:var(--mud-palette-text-secondary);font-weight:700;">COACH</div>
                                    <div style="font-size:13px;font-weight:600;">@(_match.AwayCoach ?? "—")</div>
                                    <div style="font-size:10px;color:var(--mud-palette-text-secondary);">@_match.AwayTeamShortName</div>
                                </div>
                                @if (_match.AwayCoachPhoto is not null)
                                {
                                    <img src="@_match.AwayCoachPhoto" alt="" style="width:36px;height:36px;border-radius:50%;object-fit:cover;" />
                                }
                            </div>
                        </div>
                    </MudPaper>
                }

                @* Substitutes *@
                @if (_match.HomeSubs.Count > 0 || _match.AwaySubs.Count > 0)
                {
                    <MudText Typo="Typo.subtitle2" Style="font-weight:700;margin:12px 0 6px;">Substitutes</MudText>
                    <MudPaper Elevation="1" Style="border-radius:12px;overflow:hidden;">
                        <div class="d-flex" style="gap:0;">
                            <div style="flex:1;padding:10px;">
                                <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px 4px;">
                                    @foreach (var p in _match.HomeSubs.OrderByDescending(x => x.SubMinute is not null))
                                    {
                                        @RenderSubCard(p)
                                    }
                                </div>
                            </div>
                            <div style="width:1px;background:var(--mud-palette-divider);"></div>
                            <div style="flex:1;padding:10px;">
                                <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px 4px;">
                                    @foreach (var p in _match.AwaySubs.OrderByDescending(x => x.SubMinute is not null))
                                    {
                                        @RenderSubCard(p)
                                    }
                                </div>
                            </div>
                        </div>
                    </MudPaper>
                }
            }
            else
            {
                <MudPaper Elevation="1" Style="border-radius:12px;padding:24px;text-align:center;">
                    <MudText Typo="Typo.body2" Style="color:var(--mud-palette-text-secondary);">Lineups not available yet</MudText>
                </MudPaper>
            }
        }

        @* Stats Tab *@
        @if (_activeTab == "Stats")
        {
            @if (_extras is null)
            {
                <div style="text-align:center;padding:32px;">
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                </div>
            }
            else
            {
                @* Your Prediction *@
                @if (_extras.MyPrediction is not null)
                {
                    <MudPaper Elevation="1" Style="border-radius:12px;padding:14px;margin-bottom:10px;">
                        <MudText Typo="Typo.subtitle2" Style="font-weight:700;margin-bottom:8px;">🎯 Your Prediction</MudText>
                        <div class="d-flex align-center justify-center gap-4">
                            <div style="text-align:center;">
                                <div style="font-size:28px;font-weight:800;">@_extras.MyPrediction.PredictedHome - @_extras.MyPrediction.PredictedAway</div>
                                @if (_extras.MyPrediction.Outcome is not null)
                                {
                                    <div style="margin-top:4px;">
                                        <span style="font-size:11px;font-weight:700;padding:3px 10px;border-radius:12px;
                                            background:@(PredictionBg(_extras.MyPrediction.Outcome));color:white;">
                                            @_extras.MyPrediction.Outcome?.Replace("CorrectResultAndGoalDifference","Result + GD")
                                                .Replace("CorrectResult","Result ✓").Replace("ExactScore","Exact! 🎯")
                                                .Replace("CorrectGoalDifference","GD ✓").Replace("Incorrect","✗")
                                            — @_extras.MyPrediction.Points pts
                                        </span>
                                    </div>
                                }
                            </div>
                        </div>
                    </MudPaper>
                }

                @* Community Predictions *@
                @if (_extras.Community.TotalPredictions > 0)
                {
                    <MudPaper Elevation="1" Style="border-radius:12px;padding:14px;margin-bottom:10px;">
                        <MudText Typo="Typo.subtitle2" Style="font-weight:700;margin-bottom:8px;">👥 Community (@_extras.Community.TotalPredictions predictions)</MudText>
                        <div class="d-flex justify-space-around text-center" style="margin-bottom:8px;">
                            <div>
                                <div style="font-size:20px;font-weight:800;">@(_extras.Community.HomeWinPct)%</div>
                                <div style="font-size:11px;color:var(--mud-palette-text-secondary);">Home</div>
                            </div>
                            <div>
                                <div style="font-size:20px;font-weight:800;">@(_extras.Community.DrawPct)%</div>
                                <div style="font-size:11px;color:var(--mud-palette-text-secondary);">Draw</div>
                            </div>
                            <div>
                                <div style="font-size:20px;font-weight:800;">@(_extras.Community.AwayWinPct)%</div>
                                <div style="font-size:11px;color:var(--mud-palette-text-secondary);">Away</div>
                            </div>
                        </div>
                        @if (_extras.Community.MostPopularScore is not null)
                        {
                            <div style="text-align:center;font-size:12px;color:var(--mud-palette-text-secondary);">
                                Most predicted: <span style="font-weight:700;color:var(--mud-palette-text-primary);">@_extras.Community.MostPopularScore</span>
                                (@_extras.Community.MostPopularScorePct%)
                            </div>
                        }
                    </MudPaper>
                }

                @* Head to Head *@
                @if (_extras.HeadToHead.Count > 0)
                {
                    <MudPaper Elevation="1" Style="border-radius:12px;overflow:hidden;margin-bottom:10px;">
                        <div style="padding:10px 14px;font-weight:700;font-size:13px;">⚔️ Head to Head</div>
                        @foreach (var h in _extras.HeadToHead)
                        {
                            <div style="display:flex;align-items:center;padding:6px 14px;border-top:1px solid var(--mud-palette-divider);font-size:12px;">
                                <span style="width:80px;color:var(--mud-palette-text-secondary);font-size:11px;">@h.KickoffTime.ToString("MMM yyyy")</span>
                                <div style="flex:1;display:flex;align-items:center;justify-content:flex-end;gap:4px;">
                                    @if (h.HomeLogo is not null) { <img src="@h.HomeLogo" alt="" style="width:16px;height:16px;" /> }
                                    <span style="font-weight:600;">@h.HomeTeam</span>
                                </div>
                                <span style="min-width:50px;text-align:center;font-weight:800;">@h.HomeScore - @h.AwayScore</span>
                                <div style="flex:1;display:flex;align-items:center;gap:4px;">
                                    <span style="font-weight:600;">@h.AwayTeam</span>
                                    @if (h.AwayLogo is not null) { <img src="@h.AwayLogo" alt="" style="width:16px;height:16px;" /> }
                                </div>
                            </div>
                        }
                    </MudPaper>
                }

                @* Form *@
                @if (_extras.HomeForm.Count > 0 || _extras.AwayForm.Count > 0)
                {
                    <MudPaper Elevation="1" Style="border-radius:12px;overflow:hidden;margin-bottom:10px;">
                        <div style="padding:10px 14px;font-weight:700;font-size:13px;">📊 Form (Last 5)</div>
                        <div class="d-flex" style="border-top:1px solid var(--mud-palette-divider);">
                            <div style="flex:1;padding:8px 10px;">
                                <div style="font-size:11px;font-weight:700;color:var(--mud-palette-text-secondary);margin-bottom:6px;">@_match.HomeTeamShortName</div>
                                <div class="d-flex gap-1">
                                    @foreach (var f in _extras.HomeForm)
                                    {
                                        <span style="width:24px;height:24px;border-radius:6px;display:flex;align-items:center;justify-content:center;
                                            font-size:10px;font-weight:800;color:white;background:@FormColor(f.Result);">@f.Result</span>
                                    }
                                </div>
                            </div>
                            <div style="width:1px;background:var(--mud-palette-divider);"></div>
                            <div style="flex:1;padding:8px 10px;">
                                <div style="font-size:11px;font-weight:700;color:var(--mud-palette-text-secondary);margin-bottom:6px;">@_match.AwayTeamShortName</div>
                                <div class="d-flex gap-1">
                                    @foreach (var f in _extras.AwayForm)
                                    {
                                        <span style="width:24px;height:24px;border-radius:6px;display:flex;align-items:center;justify-content:center;
                                            font-size:10px;font-weight:800;color:white;background:@FormColor(f.Result);">@f.Result</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </MudPaper>
                }

                @* Player Season Stats *@
                @if (_extras.HomePlayerStats.Count > 0 || _extras.AwayPlayerStats.Count > 0)
                {
                    <MudPaper Elevation="1" Style="border-radius:12px;overflow:hidden;margin-bottom:10px;">
                        <div style="padding:10px 14px;font-weight:700;font-size:13px;">⭐ Season Stats</div>
                        <div class="d-flex" style="border-top:1px solid var(--mud-palette-divider);">
                            <div style="flex:1;padding:8px 10px;">
                                @foreach (var p in _extras.HomePlayerStats.Take(5))
                                {
                                    <div class="d-flex align-center gap-2" style="margin-bottom:4px;">
                                        @if (p.PhotoUrl is not null)
                                        {
                                            <img src="@p.PhotoUrl" alt="" style="width:22px;height:22px;border-radius:50%;object-fit:cover;" />
                                        }
                                        else
                                        {
                                            <div style="width:22px;height:22px;border-radius:50%;background:#555;"></div>
                                        }
                                        <div style="flex:1;min-width:0;">
                                            <div style="font-size:11px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@p.Name</div>
                                            <div style="font-size:10px;color:var(--mud-palette-text-secondary);">
                                                @if (p.Goals > 0) { <span>⚽@p.Goals</span> }
                                                @if (p.Assists > 0) { <span> 👟@p.Assists</span> }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                            <div style="width:1px;background:var(--mud-palette-divider);"></div>
                            <div style="flex:1;padding:8px 10px;">
                                @foreach (var p in _extras.AwayPlayerStats.Take(5))
                                {
                                    <div class="d-flex align-center gap-2" style="margin-bottom:4px;">
                                        @if (p.PhotoUrl is not null)
                                        {
                                            <img src="@p.PhotoUrl" alt="" style="width:22px;height:22px;border-radius:50%;object-fit:cover;" />
                                        }
                                        else
                                        {
                                            <div style="width:22px;height:22px;border-radius:50%;background:#555;"></div>
                                        }
                                        <div style="flex:1;min-width:0;">
                                            <div style="font-size:11px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@p.Name</div>
                                            <div style="font-size:10px;color:var(--mud-palette-text-secondary);">
                                                @if (p.Goals > 0) { <span>⚽@p.Goals</span> }
                                                @if (p.Assists > 0) { <span> 👟@p.Assists</span> }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </MudPaper>
                }
            }
        }

        @* Table Tab *@
        @if (_activeTab == "Table")
        {
            @if (_table is not null && _table.Groups.Count > 0)
            {
                @foreach (var group in _table.Groups)
                {
                    @if (_table.Groups.Count > 1 && group.GroupName is not null)
                    {
                        <MudText Typo="Typo.subtitle2" Style="font-weight:700;margin:8px 0 4px;">@group.GroupName</MudText>
                    }
                    <MudPaper Elevation="1" Style="border-radius:12px;overflow:hidden;margin-bottom:12px;">
                        <LeagueTableView Rows="group.Rows" Zones="_zones"
                            HighlightTeamNames="@(new List<string> { _match.HomeTeamName, _match.AwayTeamName })" />
                    </MudPaper>
                }
            }
            else
            {
                <MudPaper Elevation="1" Style="border-radius:12px;padding:24px;text-align:center;">
                    <MudText Typo="Typo.body2" Style="color:var(--mud-palette-text-secondary);">Table not available</MudText>
                </MudPaper>
            }
        }

    </MudContainer>
</div>
}
</PageGuard>
