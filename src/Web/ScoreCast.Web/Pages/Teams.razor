@page "/teams"

<PageGuard>
<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-1">
    <MudText Typo="Typo.h5" Class="mb-2" Style="font-weight:700;">Teams</MudText>

    <MudTextField @bind-Value="_search" Placeholder="Search teams..." Variant="Variant.Outlined"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                  Immediate="true" DebounceInterval="300" TextChanged="OnSearchChanged"
                  Style="margin-bottom:12px;" />

    @if (_teams.Count > 0)
    {
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(@(IsMobile ? "100px" : "160px"),1fr));gap:8px;">
            @foreach (var team in _teams)
            {
                <MudPaper Class="pa-2" Elevation="1" Style="border-radius:10px;cursor:pointer;text-align:center;" @onclick="() => GoToTeam(team.Id)">
                    @if (team.LogoUrl is not null)
                    {
                        <img src="@team.LogoUrl" alt="" style="width:@(IsMobile ? "32" : "48")px;height:@(IsMobile ? "32" : "48")px;margin-bottom:4px;" />
                    }
                    <div style="font-weight:600;font-size:@(IsMobile ? "11" : "14")px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                        @(team.ShortName ?? team.Name)
                    </div>
                </MudPaper>
            }
        </div>

        @if (_hasMore)
        {
            <div class="d-flex justify-center mt-4 mb-2">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           OnClick="LoadMoreAsync" Disabled="_loadingMore">
                    @if (_loadingMore)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Load More
                </MudButton>
            </div>
        }
    }
    else if (!Loading.IsLoading)
    {
        <MudText Typo="Typo.body2" Align="Align.Center" Style="color:var(--mud-palette-text-secondary);">
            @(string.IsNullOrWhiteSpace(_search) ? "Search for a team to get started" : "No teams found")
        </MudText>
    }
</MudContainer>
</PageGuard>
