@page "/scores"

<style>
    .live-pulse {
        width: 8px;
        height: 8px;
        background: #f44336;
        border-radius: 50%;
        animation: pulse 1.2s ease-in-out infinite;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
    }
</style>

<PageGuard>
<MudContainer MaxWidth="MaxWidth.Medium" Class="py-4">
    <MudText Typo="Typo.h5" Class="mb-3" Style="font-weight:700;">Scores & Fixtures</MudText>

    <div class="d-flex gap-3 mb-4 flex-wrap">
        <MudSelect T="string" Label="Country" Value="_selectedCountry" ValueChanged="OnCountryChanged" Variant="Variant.Outlined" Dense="true" Style="max-width:200px;">
            @foreach (var country in _countries)
            {
                <MudSelectItem Value="@country">@country</MudSelectItem>
            }
        </MudSelect>
        <MudSelect T="CompetitionResult" Label="Competition" Value="_selectedCompetition" ValueChanged="OnCompetitionChanged" Variant="Variant.Outlined" Dense="true" Style="max-width:250px;" ToStringFunc="@(c => c?.Name ?? "")">
            @foreach (var comp in _filteredCompetitions)
            {
                <MudSelectItem Value="@comp">@comp.Name</MudSelectItem>
            }
        </MudSelect>
        <MudSelect T="SeasonResult" Label="Season" Value="_selectedSeason" ValueChanged="OnSeasonChanged" Variant="Variant.Outlined" Dense="true" Style="max-width:180px;" ToStringFunc="@(s => s is null ? "" : $"{s.StartDate.Year}/{s.EndDate.Year}")">
            @foreach (var season in _seasons)
            {
                <MudSelectItem Value="@season">@season.StartDate.Year/@season.EndDate.Year</MudSelectItem>
            }
        </MudSelect>
    </div>

    @if (_gameweek is not null)
    {
        <div class="d-flex align-center justify-center gap-2 mb-4">
            <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" OnClick="PreviousGameweek"
                           Disabled="@(_gameweek.GameweekNumber <= 1)" Size="Size.Large" />
            <MudChip T="string" Color="Color.Primary" Style="font-weight:700;font-size:15px;">
                Matchweek @_gameweek.GameweekNumber
            </MudChip>
            <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" OnClick="NextGameweek"
                           Disabled="@(_gameweek.GameweekNumber >= _gameweek.TotalGameweeks)" Size="Size.Large" />
        </div>

        @if (_gameweek.StartDate.HasValue)
        {
            <MudText Typo="Typo.body2" Align="Align.Center" Class="mb-3" Style="color:var(--mud-palette-text-secondary);">
                @_gameweek.StartDate.Value.ToString("dd MMM yyyy")
                @if (_gameweek.EndDate.HasValue && _gameweek.EndDate != _gameweek.StartDate)
                {
                    <text> - @_gameweek.EndDate.Value.ToString("dd MMM yyyy")</text>
                }
            </MudText>
        }

        @foreach (var match in _gameweek.Matches)
        {
            <MudPaper Class="mb-2" Elevation="1" Style="overflow:hidden;border-radius:8px;">
                <div @onclick="() => ToggleMatch(match.MatchId)" style="cursor:pointer;padding:12px 16px;">
                    <div class="d-flex align-center justify-space-between">
                        <div class="d-flex align-center gap-2" style="flex:1;justify-content:flex-end;">
                            <MudText Style="font-weight:600;font-size:14px;text-align:right;">@match.HomeTeamShortName</MudText>
                            @if (match.HomeTeamLogo is not null)
                            {
                                <MudImage Src="@match.HomeTeamLogo" Width="24" Height="24" ObjectFit="ObjectFit.Contain" />
                            }
                        </div>
                        <div style="min-width:80px;text-align:center;">
                            @if (match.Status == "Finished")
                            {
                                <MudText Style="font-weight:700;font-size:16px;">@match.HomeScore - @match.AwayScore</MudText>
                            }
                            else if (match.Status == "Live")
                            {
                                <MudText Style="font-weight:700;font-size:16px;color:#4caf50;">@(match.HomeScore ?? 0) - @(match.AwayScore ?? 0)</MudText>
                                <div style="display:flex;align-items:center;justify-content:center;gap:4px;margin-top:2px;">
                                    <span class="live-pulse"></span>
                                    <span style="font-size:10px;font-weight:700;color:#f44336;letter-spacing:1px;">LIVE</span>
                                </div>
                            }
                            else
                            {
                                <MudText Style="font-size:13px;color:var(--mud-palette-text-secondary);">
                                    @(match.KickoffTime?.ToLocalTime().ToString("HH:mm") ?? "TBD")
                                </MudText>
                            }
                        </div>
                        <div class="d-flex align-center gap-2" style="flex:1;">
                            @if (match.AwayTeamLogo is not null)
                            {
                                <MudImage Src="@match.AwayTeamLogo" Width="24" Height="24" ObjectFit="ObjectFit.Contain" />
                            }
                            <MudText Style="font-weight:600;font-size:14px;">@match.AwayTeamShortName</MudText>
                        </div>
                    </div>
                    <div class="d-flex align-center justify-center gap-1" style="margin-top:4px;">
                        <MudIcon Icon="@(_expandedMatches.Contains(match.MatchId) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Size="Size.Small" Style="color:var(--mud-palette-text-secondary);" />
                        <MudText Style="font-size:11px;color:var(--mud-palette-text-secondary);">
                            @(_expandedMatches.Contains(match.MatchId) ? "collapse" : "expand for more")
                        </MudText>
                    </div>
                </div>

                @if (_expandedMatches.Contains(match.MatchId))
                {
                    <MudDivider />
                    <div style="padding:12px 16px;background:var(--mud-palette-background-grey);">
                        @if (match.Venue is not null || match.Referee is not null || match.KickoffTime.HasValue)
                        {
                            <div style="text-align:center;margin-bottom:10px;font-size:13px;color:var(--mud-palette-text-primary);opacity:0.85;">
                                @if (match.Venue is not null)
                                {
                                    <div>🏟️ @match.Venue</div>
                                }
                                @if (match.KickoffTime.HasValue)
                                {
                                    <div>🕐 @match.KickoffTime.Value.ToLocalTime().ToString("ddd dd MMM yyyy, HH:mm")</div>
                                }
                                @if (match.Referee is not null)
                                {
                                    <div><MudIcon Icon="@Icons.Material.Filled.RecordVoiceOver" Size="Size.Small" Style="vertical-align:middle;" /> @match.Referee</div>
                                }
                            </div>
                        }

                        @if (match.Events.Count > 0)
                        {
                            <div class="d-flex" style="gap:16px;">
                                <div style="flex:1;text-align:right;">
                                    @foreach (var line in GetDisplayLines(match.Events, true))
                                    {
                                        <div style="font-size:13px;margin-bottom:2px;@(line.Bold ? "font-weight:700;" : "")">
                                            @line.Text @(line.Minute is not null ? $" {line.Minute}" : "")
                                        </div>
                                    }
                                </div>
                                <div style="width:1px;background:var(--mud-palette-divider);"></div>
                                <div style="flex:1;text-align:left;">
                                    @foreach (var line in GetDisplayLines(match.Events, false))
                                    {
                                        <div style="font-size:13px;margin-bottom:2px;@(line.Bold ? "font-weight:700;" : "")">
                                            @(line.Minute is not null ? $"{line.Minute} " : "")@line.Text
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        else if (match.Status == "Finished")
                        {
                            <MudText Typo="Typo.body2" Align="Align.Center" Style="color:var(--mud-palette-text-secondary);">
                                No event data available
                            </MudText>
                        }
                    </div>
                }
            </MudPaper>
        }
    }
    else if (_selectedSeason is not null)
    {
        <MudAlert Severity="Severity.Info">No match data available. Sync matches first.</MudAlert>
    }
</MudContainer>
</PageGuard>
