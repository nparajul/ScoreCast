@page "/scores"

<PageGuard>
<div>
    <div style="position:sticky;top:var(--mud-appbar-height);z-index:10;background:var(--mud-palette-background);padding:8px 0 4px;">
        <MudContainer MaxWidth="MaxWidth.Medium">
            <MudText Typo="Typo.h6" Style="font-weight:700;">Scores & Fixtures</MudText>
        </MudContainer>
    </div>

    <MudContainer MaxWidth="MaxWidth.Medium" Style="padding-top:8px;padding-bottom:100px;">
        @if (_loaded)
        {
            @foreach (var comp in _sections)
            {
                <MudPaper Class="mb-3" Elevation="1" Style="border-radius:10px;overflow:hidden;">
                    <div style="display:flex;align-items:center;gap:10px;padding:12px 14px;">
                        <a href="/competitions/@comp.Competition.Id" style="display:flex;align-items:center;gap:10px;flex:1;text-decoration:none;color:inherit;">
                            @if (!string.IsNullOrEmpty(comp.Competition.LogoUrl))
                            {
                                <img src="@comp.Competition.LogoUrl" alt="" style="width:24px;height:24px;object-fit:contain;" />
                            }
                            <MudText Typo="Typo.subtitle1" Style="font-weight:700;">@comp.Competition.Name</MudText>
                        </a>
                        <MudIconButton Icon="@(comp.Expanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                       Size="Size.Small" OnClick="@(() => ToggleSection(comp))" />
                    </div>

                    @if (comp.Expanded)
                    {
                        <MudDivider />

                        @if (comp.Loading)
                        {
                            <div class="d-flex justify-center pa-4">
                                <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                            </div>
                        }
                        else if (comp.TodayMatches.Count > 0)
                        {
                            <div style="padding:6px 10px 2px;font-weight:700;font-size:13px;text-align:center;color:var(--mud-palette-text-secondary);">
                                Today
                            </div>
                            @foreach (var match in comp.TodayMatches)
                            {
                                <MatchTile Match="MatchTileModel.From(match)" IsExpanded="_expandedMatches.Contains(match.MatchId)" OnToggle="() => ToggleMatch(match.MatchId)" />
                                @if (match != comp.TodayMatches.Last()) { <MudDivider /> }
                            }
                        }
                        else
                        {
                            @if (comp.LastGwMatches.Count > 0)
                            {
                                <div style="padding:6px 10px 2px;font-weight:700;font-size:13px;text-align:center;color:var(--mud-palette-text-secondary);">
                                    Matchweek @comp.LastGwNumber — Results
                                </div>
                                @foreach (var match in comp.LastGwMatches)
                                {
                                    <MatchTile Match="MatchTileModel.From(match)" IsExpanded="_expandedMatches.Contains(match.MatchId)" OnToggle="() => ToggleMatch(match.MatchId)" />
                                    @if (match != comp.LastGwMatches.Last()) { <MudDivider /> }
                                }
                            }

                            @if (comp.NextGwMatches.Count > 0)
                            {
                                @if (comp.LastGwMatches.Count > 0)
                                {
                                    <MudDivider Class="my-1" />
                                }
                                <div style="padding:6px 10px 2px;font-weight:700;font-size:13px;text-align:center;color:var(--mud-palette-text-secondary);">
                                    Matchweek @comp.NextGwNumber — Upcoming
                                </div>
                                @foreach (var match in comp.NextGwMatches)
                                {
                                    <div style="padding:10px 14px;display:flex;align-items:center;gap:8px;">
                                        <div style="flex:1;text-align:right;">
                                            <span style="font-weight:600;font-size:14px;">@match.HomeTeamShortName</span>
                                        </div>
                                        @if (!string.IsNullOrEmpty(match.HomeTeamLogo))
                                        {
                                            <img src="@match.HomeTeamLogo" alt="" style="width:24px;height:24px;" />
                                        }
                                        <div style="min-width:60px;text-align:center;">
                                            <div style="font-size:12px;font-weight:600;color:var(--mud-palette-text-secondary);">
                                                @if (match.KickoffTime.HasValue)
                                                {
                                                    @FormatDate(match.KickoffTime.Value)
                                                }
                                                else
                                                {
                                                    <text>TBD</text>
                                                }
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(match.AwayTeamLogo))
                                        {
                                            <img src="@match.AwayTeamLogo" alt="" style="width:24px;height:24px;" />
                                        }
                                        <div style="flex:1;">
                                            <span style="font-weight:600;font-size:14px;">@match.AwayTeamShortName</span>
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(match.Venue))
                                    {
                                        <div style="text-align:center;font-size:11px;color:var(--mud-palette-text-secondary);margin-top:-6px;padding-bottom:6px;">
                                            📍 @match.Venue
                                        </div>
                                    }
                                    @if (match != comp.NextGwMatches.Last()) { <MudDivider /> }
                                }
                            }

                            @if (comp.LastGwMatches.Count == 0 && comp.NextGwMatches.Count == 0)
                            {
                                <div style="padding:16px;text-align:center;color:var(--mud-palette-text-secondary);font-size:13px;">
                                    No matches available
                                </div>
                            }
                        }
                    }
                </MudPaper>
            }
        }
    </MudContainer>
</div>
</PageGuard>
