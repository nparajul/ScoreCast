@page "/scores"

<style>
    .scores-header {
        position: sticky;
        top: var(--mud-appbar-height);
        z-index: 10;
        background: var(--mud-palette-background);
        padding: 10px 0 6px;
        border-bottom: 1px solid var(--mud-palette-lines-default);
    }
    .comp-header {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 14px;
        cursor: pointer;
        transition: background 0.15s;
    }
    .comp-header:active { background: rgba(255,255,255,0.04); }
    .comp-logo { width: 22px; height: 22px; object-fit: contain; }
    .comp-name { font-weight: 700; font-size: 15px; }
    .comp-name:hover { text-decoration: underline; text-underline-offset: 3px; }
    .section-label {
        display: inline-block;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        padding: 3px 10px;
        border-radius: 12px;
        margin: 8px auto 4px;
    }
    .section-label-results { background: rgba(76,175,80,0.12); color: #4caf50; }
    .section-label-upcoming { background: rgba(33,150,243,0.12); color: #2196f3; }
    .section-label-today { background: rgba(255,107,53,0.15); color: #FF6B35; }
    .match-row-upcoming {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 10px 14px;
        transition: background 0.12s;
        cursor: pointer;
    }
    .match-row-upcoming:active { background: rgba(255,255,255,0.04); }
    .team-name { font-weight: 600; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .team-logo { width: 22px; height: 22px; flex-shrink: 0; }
    .kickoff-time {
        font-size: 12px;
        font-weight: 600;
        color: var(--mud-palette-text-secondary);
        min-width: 56px;
        text-align: center;
        line-height: 1.3;
    }
    .kickoff-date { font-size: 10px; opacity: 0.7; }
    .pp-badge {
        font-size: 11px;
        font-weight: 800;
        color: #f44336;
        background: rgba(244,67,54,0.1);
        padding: 2px 8px;
        border-radius: 6px;
    }
    .venue-line {
        text-align: center;
        font-size: 11px;
        color: var(--mud-palette-text-secondary);
        padding: 0 14px 8px;
        margin-top: -4px;
    }
    .no-matches {
        padding: 24px 16px;
        text-align: center;
        color: var(--mud-palette-text-secondary);
        font-size: 13px;
    }
    .comp-card {
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 12px;
        border: 1px solid var(--mud-palette-lines-default);
    }
    @@media (max-width: 599px) {
        .team-name { font-size: 13px; }
        .team-logo { width: 20px; height: 20px; }
        .match-row-upcoming { padding: 8px 10px; }
    }
</style>

<PageGuard>
<div>
    <div class="scores-header">
        <MudContainer MaxWidth="MaxWidth.Medium">
            <MudText Typo="Typo.h6" Style="font-weight:800;letter-spacing:-0.02em;">Scores & Fixtures</MudText>
        </MudContainer>
    </div>

    <MudContainer MaxWidth="MaxWidth.Medium" Style="padding-top:10px;padding-bottom:100px;">
        @if (_loaded)
        {
            @foreach (var comp in _sections)
            {
                <div class="comp-card">
                    <div class="comp-header" @onclick="@(() => ToggleSection(comp))">
                        <a href="/competitions/@comp.Competition.Id" style="display:flex;align-items:center;gap:8px;text-decoration:none;color:inherit;" @onclick:stopPropagation>
                            @if (!string.IsNullOrEmpty(comp.Competition.LogoUrl))
                            {
                                <img src="@comp.Competition.LogoUrl" alt="" class="comp-logo" />
                            }
                            <span class="comp-name">@comp.Competition.Name</span>
                        </a>
                        @if (!string.IsNullOrEmpty(comp.Competition.CountryFlagUrl))
                        {
                            <img src="@comp.Competition.CountryFlagUrl" alt="" style="width:18px;height:12px;object-fit:cover;border-radius:2px;opacity:0.6;" />
                        }
                        <div style="flex:1;"></div>
                        <MudIcon Icon="@(comp.Expanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                 Size="Size.Small" Style="opacity:0.35;" />
                    </div>

                    @if (comp.Expanded)
                    {
                        @if (comp.Loading)
                        {
                            <div class="d-flex justify-center pa-4">
                                <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                            </div>
                        }
                        else if (comp.TodayMatches.Count > 0)
                        {
                            <div style="text-align:center;">
                                <span class="section-label section-label-today">⚽ Today</span>
                            </div>
                            @foreach (var match in comp.TodayMatches)
                            {
                                <MatchTile Match="MatchTileModel.From(match)" IsExpanded="_expandedMatches.Contains(match.MatchId)" OnToggle="() => ToggleMatch(match.MatchId)" />
                            }
                        }
                        else
                        {
                            @if (comp.LastGwMatches.Count > 0)
                            {
                                <div style="text-align:center;">
                                    <span class="section-label section-label-results">✓ MW @comp.LastGwNumber Results</span>
                                </div>
                                @foreach (var match in comp.LastGwMatches)
                                {
                                    <MatchTile Match="MatchTileModel.From(match)" IsExpanded="_expandedMatches.Contains(match.MatchId)" OnToggle="() => ToggleMatch(match.MatchId)" />
                                }
                            }

                            @if (comp.NextGwMatches.Count > 0)
                            {
                                <div style="text-align:center;">
                                    <span class="section-label section-label-upcoming">📅 MW @comp.NextGwNumber Upcoming</span>
                                </div>
                                @foreach (var match in comp.NextGwMatches)
                                {
                                    <div class="match-row-upcoming" style="@(match.Status == nameof(MatchStatus.Postponed) ? "opacity:0.4;" : "")"
                                         @onclick="@(() => Nav.NavigateTo($"/matches/{match.MatchId}"))">
                                        <a href="/teams/@match.HomeTeamId" @onclick:stopPropagation style="flex:1;text-align:right;display:flex;align-items:center;justify-content:flex-end;gap:4px;color:inherit;text-decoration:none;">
                                            <span class="team-name">@match.HomeTeamShortName</span>
                                            @if (!string.IsNullOrEmpty(match.HomeTeamLogo))
                                            {
                                                <img src="@match.HomeTeamLogo" alt="" class="team-logo" />
                                            }
                                        </a>
                                        @if (match.Status == nameof(MatchStatus.Postponed))
                                        {
                                            <div style="min-width:56px;text-align:center;">
                                                <span class="pp-badge">PP</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="kickoff-time">
                                                @if (match.KickoffTime.HasValue)
                                                {
                                                    @FormatDate(match.KickoffTime.Value)
                                                }
                                                else
                                                {
                                                    <text>TBD</text>
                                                }
                                            </div>
                                        }
                                        <a href="/teams/@match.AwayTeamId" @onclick:stopPropagation style="flex:1;display:flex;align-items:center;gap:4px;color:inherit;text-decoration:none;">
                                            @if (!string.IsNullOrEmpty(match.AwayTeamLogo))
                                            {
                                                <img src="@match.AwayTeamLogo" alt="" class="team-logo" />
                                            }
                                            <span class="team-name">@match.AwayTeamShortName</span>
                                        </a>
                                    </div>
                                    @if (!string.IsNullOrEmpty(match.Venue))
                                    {
                                        <div class="venue-line">📍 @match.Venue</div>
                                    }
                                }
                            }

                            @if (comp.LastGwMatches.Count == 0 && comp.NextGwMatches.Count == 0)
                            {
                                <div class="no-matches">No matches available</div>
                            }
                        }
                    }
                </div>
            }
        }
    </MudContainer>
</div>
</PageGuard>
