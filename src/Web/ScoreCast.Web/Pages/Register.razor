@page "/register"

<PageTitle>Create Account — ScoreCast</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8 mt-md-16">
    <MudPaper Elevation="3" Class="pa-6 pa-md-8 rounded-lg">
        <div class="d-flex flex-column align-center mb-6">
            <MudImage Src="scorecast-icon.svg" Alt="ScoreCast" Width="64" Height="64" Class="mb-2" />
            <MudText Typo="Typo.h5" Style="font-weight:700;">Create Account</MudText>
            <MudText Typo="Typo.body2" Style="opacity:0.6;">Join the prediction game</MudText>
        </div>

        @if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4" Variant="Variant.Filled">@_error</MudAlert>
        }

        <EditForm Model="_model" OnValidSubmit="HandleRegister">
            <MudTextField @bind-Value="_model.Email"
                          Label="Email"
                          Variant="Variant.Outlined"
                          InputType="InputType.Email"
                          Required="true"
                          Class="mb-4"
                          Disabled="_loading" />

            <MudTextField @bind-Value="_model.Username"
                          Label="Username"
                          Variant="Variant.Outlined"
                          Required="true"
                          Class="mb-4"
                          Disabled="_loading" />

            <MudTextField @bind-Value="_model.Password"
                          Label="Password"
                          Variant="Variant.Outlined"
                          InputType="InputType.Password"
                          Required="true"
                          Class="mb-2"
                          Disabled="_loading" />

            <MudTextField @bind-Value="_model.ConfirmPassword"
                          Label="Confirm Password"
                          Variant="Variant.Outlined"
                          InputType="InputType.Password"
                          Required="true"
                          Class="mb-2"
                          Disabled="_loading" />

            <MudText Typo="Typo.caption" Style="opacity:0.5;" Class="mb-4">
                At least 8 characters, 1 uppercase, 1 lowercase, 1 digit, and 1 special character.
                Cannot contain your username or email.
            </MudText>

            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Tertiary"
                       FullWidth="true"
                       Size="Size.Large"
                       Disabled="_loading"
                       Class="mb-4">
                @if (_loading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Create Account
            </MudButton>
        </EditForm>

        <MudDivider Class="my-4" />

        <div class="d-flex flex-column align-center">
            <MudText Typo="Typo.body2" Style="opacity:0.6;" Class="mb-2">Already have an account?</MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true" Href="/login">
                Log In
            </MudButton>
        </div>
    </MudPaper>
</MudContainer>
