@page "/predict/{SeasonId:long}"

<style>
    .predict-row { padding: 8px 6px; border-bottom: 1px solid var(--mud-palette-lines-default); }
    .predict-input {
        width: 28px; height: 28px; text-align: center; font-size: 15px; font-weight: 700;
        border: 1px solid var(--mud-palette-lines-default); border-radius: 6px;
        background: var(--mud-palette-surface); color: var(--mud-palette-text-primary);
        pointer-events: none; -moz-appearance: textfield;
    }
    .predict-input::-webkit-outer-spin-button,
    .predict-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
    .predict-input:disabled { opacity: 0.5; }
    .predict-stepper {
        display: flex; align-items: center; justify-content: center;
        width: 24px; height: 24px; border: 1px solid var(--mud-palette-lines-default); border-radius: 50%;
        background: var(--mud-palette-background-grey); color: var(--mud-palette-text-primary);
        font-size: 16px; font-weight: 700; cursor: pointer;
        -webkit-tap-highlight-color: transparent;
        transition: transform 0.25s cubic-bezier(0.34,1.56,0.64,1), background 0.2s;
        user-select: none; line-height: 1;
    }
    .predict-stepper:active { transform: scale(0.85); background: var(--mud-palette-action-default); }
    .predict-stepper:disabled { opacity: 0.3; pointer-events: none; }
    .predict-incomplete { border-color: #f44336 !important; }
    .predict-exact { background: rgba(46, 125, 50, 0.25); }
    .predict-result-gd { background: rgba(0, 131, 143, 0.25); }
    .predict-correct { background: rgba(255, 179, 0, 0.25); }
    .predict-gd { background: rgba(156, 39, 176, 0.2); }
    .predict-wrong { background: rgba(211, 47, 47, 0.2); }
    .predict-none { background: rgba(158, 158, 158, 0.15); }
</style>

<PageGuard>
<MudContainer MaxWidth="MaxWidth.Medium" Class="py-4">
    <MudText Typo="Typo.h5" Style="font-weight:700;" Class="mb-1">Make Predictions</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">Predict the score for each match</MudText>

    @if (_gameweek is not null)
    {
        @if (_matches.All(m => m.IsLocked) && !_matches.Any(m => m.HasSavedPrediction))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Text" Dense="true" Class="mb-2">
                You missed this gameweek! No predictions were submitted before the deadline.
            </MudAlert>
        }
        else if (!_matches.All(m => m.IsLocked) && _matches.Any(m => m.HasSavedPrediction))
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Text" Dense="true" Class="mb-2">
                You've already submitted predictions for this gameweek. You can still edit them before kickoff.
            </MudAlert>
        }
        else if (!_matches.All(m => m.IsLocked) && !_matches.Any(m => m.HasSavedPrediction))
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Text" Dense="true" Class="mb-2">
                No predictions made yet for this gameweek. Enter your scores below!
            </MudAlert>
        }

        <div class="d-flex align-center justify-center gap-3 mb-4">
            <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" Size="Size.Small"
                           Disabled="@(_gameweek.GameweekNumber <= 1)"
                           OnClick="PreviousGameweek" />
            <MudText Typo="Typo.h6">Gameweek @_gameweek.GameweekNumber</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small"
                           Disabled="@(_gameweek.GameweekNumber >= _gameweek.CurrentGameweek)"
                           OnClick="NextGameweek" />
        </div>

        @if (_stats is not null && _stats.CurrentStreak >= 2 && _matches.Any(m => !m.IsLocked))
        {
            <div style="text-align:center;margin-bottom:12px;">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                         Style="background:linear-gradient(135deg,#ff6b35,#ff8f00);color:white;font-weight:700;">
                    🔥 @_stats.CurrentStreak-match streak — keep it going!
                </MudChip>
            </div>
        }

        var showPoints = _matches.All(m => m.IsLocked) && _matches.Any(m => m.HasPrediction);

        @if (showPoints)
        {
            var breakdown = ScoringBreakdown.Calculate(_matches, _scoringRules);
            var total = breakdown.Sum(b => b.Total);
            var riskBonus = _riskPlays.Where(r => r.BonusPoints.HasValue).Sum(r => r.BonusPoints!.Value);
            var grandTotal = total + riskBonus;
            var totalPossible = _matches.Count(m => m.Status == nameof(MatchStatus.Finished) && m.HasPrediction) * _scoringRules.Max(r => r.Points);
            var maxRiskBonus = _riskPlays.Sum(r => r.MaxBonus(_scoringRules.Max(sr => sr.Points)));

            <MudPaper Elevation="1" Class="pa-3 rounded-lg mb-3" Style="text-align:center;">
                <MudText Typo="Typo.h4" Style="font-weight:800;">@grandTotal</MudText>
                <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">out of @totalPossible + @maxRiskBonus possible</MudText>
                <div class="mt-2">
                    <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary"
                               EndIcon="@Icons.Material.Filled.KeyboardArrowDown"
                               OnClick="@(() => _showBreakdown = !_showBreakdown)">
                        @(_showBreakdown ? "Hide" : "Show") Breakdown
                    </MudButton>
                </div>
            </MudPaper>

            @if (_showBreakdown)
            {
                <MudPaper Elevation="1" Class="pa-3 rounded-lg mb-3" id="points-breakdown">
                    <MudText Typo="Typo.subtitle2" Style="font-weight:700;" Class="mb-2">Points Breakdown</MudText>
                    @foreach (var row in breakdown)
                    {
                        <div class="@row.CssClass" style="border-radius:6px;margin-bottom:4px;">
                            <div class="d-flex align-center justify-space-between" style="padding:6px 8px;cursor:@(row.Count > 0 ? "pointer" : "default");"
                                 @onclick="@(() => { if (row.Count > 0) ToggleRule(row.Label); })">
                                <span style="font-size:13px;">@row.Label</span>
                                <div class="d-flex align-center gap-2">
                                    <span style="font-size:12px;color:var(--mud-palette-text-secondary);">@row.Points × @row.Count</span>
                                    <span style="font-weight:700;font-size:13px;min-width:28px;text-align:right;">@row.Total</span>
                                    @if (row.Count > 0)
                                    {
                                        <MudIcon Icon="@(_expandedRules.Contains(row.Label) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Size="Size.Small" />
                                    }
                                </div>
                            </div>
                            @if (row.Count > 0 && _expandedRules.Contains(row.Label))
                            {
                                <div style="padding:0 8px 6px;">
                                    @foreach (var m in row.Matches)
                                    {
                                        <div class="d-flex align-center justify-space-between" style="padding:3px 0;font-size:12px;border-top:1px solid rgba(128,128,128,0.2);">
                                            <div class="d-flex align-center gap-1" style="flex:1;min-width:0;">
                                                @if (m.HomeLogo is not null) { <img src="@m.HomeLogo" alt="" style="width:14px;height:14px;" /> }
                                                <span style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><a href="/teams/@m.HomeTeamId" style="color:inherit;text-decoration:underline;text-underline-offset:2px;text-decoration-color:var(--mud-palette-text-secondary);">@m.Home</a> vs <a href="/teams/@m.AwayTeamId" style="color:inherit;text-decoration:underline;text-underline-offset:2px;text-decoration-color:var(--mud-palette-text-secondary);">@m.Away</a></span>
                                            </div>
                                            <div class="d-flex align-center gap-2" style="flex-shrink:0;">
                                                <span style="color:var(--mud-palette-text-secondary);">@m.PredHome-@m.PredAway</span>
                                                <span style="font-weight:600;">(@m.ActualHome-@m.ActualAway)</span>
                                                <span style="font-weight:700;color:var(--mud-palette-primary);">+@m.Points</span>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    @* Risk Plays in breakdown *@
                    @if (_riskPlays.Any(r => r.BonusPoints.HasValue))
                    {
                        <div style="margin-top:6px;padding-top:6px;border-top:1px dashed var(--mud-palette-lines-default);">
                            <div style="font-size:12px;font-weight:700;padding:0 8px 4px;color:var(--mud-palette-text-secondary);">🎲 Risk Plays</div>
                            @foreach (var rp in _riskPlays.Where(r => r.BonusPoints.HasValue))
                            {
                                var rpColor = rp.IsWon == true ? "#4caf50" : "#f44336";
                                <div class="d-flex align-center justify-space-between" style="padding:4px 8px;font-size:12px;">
                                    <div class="d-flex align-center gap-1">
                                        <span>@rp.Icon</span>
                                        <span>@rp.Label</span>
                                        <span style="color:var(--mud-palette-text-secondary);">· @MatchLabel(rp.MatchId!.Value)</span>
                                    </div>
                                    <span style="font-weight:700;color:@rpColor;">
                                        @(rp.BonusPoints > 0 ? "+" : "")@rp.BonusPoints
                                        @if (rp.IsResolved != true) { <span style="font-size:10px;opacity:0.7;">(live)</span> }
                                    </span>
                                </div>
                            }
                        </div>
                    }

                    <div style="border-top:2px solid var(--mud-palette-lines-default);padding:6px 8px;margin-top:4px;">
                        <div class="d-flex justify-space-between">
                            <span style="font-weight:700;">Total</span>
                            <span style="font-weight:700;font-size:16px;">@grandTotal / @totalPossible + @maxRiskBonus</span>
                        </div>
                    </div>
                </MudPaper>
            }
        }

        @* You vs Community for finished gameweeks *@
        @if (showPoints && _stats?.LastGameweek is not null && _stats.LastGameweek.GameweekNumber == _gameweek.GameweekNumber)
        {
            var gw = _stats.LastGameweek;
            <MudPaper Elevation="1" Class="pa-3 rounded-lg mb-3" Style="text-align:center;">
                <MudText Typo="Typo.subtitle2" Style="font-weight:700;">You vs Community</MudText>
                <div class="d-flex justify-space-around mt-2">
                    <div>
                        <MudText Typo="Typo.h6" Style="font-weight:800;color:#FF6B35;">@gw.UserCorrect/@gw.UserTotal</MudText>
                        <MudText Typo="Typo.caption" Style="opacity:0.6;">You</MudText>
                    </div>
                    <div>
                        <MudText Typo="Typo.h6" Style="font-weight:800;">@gw.CommunityAvgCorrect/@gw.CommunityAvgTotal</MudText>
                        <MudText Typo="Typo.caption" Style="opacity:0.6;">Avg</MudText>
                    </div>
                    <div>
                        <MudText Typo="Typo.h6" Style="@($"font-weight:800;color:{(gw.BeatPct >= 50 ? "#4CAF50" : "#f44336")}")">Beat @(gw.BeatPct)%</MudText>
                        <MudText Typo="Typo.caption" Style="opacity:0.6;">of predictors</MudText>
                    </div>
                </div>
            </MudPaper>
        }

        <div style="width:100%;max-width:600px;margin:0 auto;border:1px solid var(--mud-palette-lines-default);border-radius:8px;overflow:hidden;">
                @foreach (var match in _matches)
                {
                    <div class="predict-row @match.GetRowClass()">
                        <div class="d-flex align-center justify-space-between">
                            <div class="d-flex align-center gap-1" style="flex:1;min-width:0;justify-content:flex-end;overflow:hidden;">
                                <span style="font-weight:600;font-size:@(IsMobile ? "12" : "15")px;text-align:right;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@match.HomeTeamShortName</span>
                                @if (match.HomeTeamLogo is not null)
                                {
                                    <img src="@match.HomeTeamLogo" alt="" style="width:@(IsMobile ? "18" : "22")px;height:@(IsMobile ? "18" : "22")px;flex-shrink:0;" />
                                }
                            </div>
                            <div class="d-flex align-center justify-center" style="flex-shrink:0;padding:0 2px;gap:2px;">
                                <button class="predict-stepper" disabled="@match.IsLocked" @onclick="@(() => Decrement(match, true))">−</button>
                                <input type="number" value="@match.PredictedHomeScore" disabled class="predict-input" />
                                <button class="predict-stepper" disabled="@match.IsLocked" @onclick="@(() => Increment(match, true))">+</button>
                                <span style="font-weight:700;font-size:11px;padding:0 1px;">-</span>
                                <button class="predict-stepper" disabled="@match.IsLocked" @onclick="@(() => Decrement(match, false))">−</button>
                                <input type="number" value="@match.PredictedAwayScore" disabled class="predict-input" />
                                <button class="predict-stepper" disabled="@match.IsLocked" @onclick="@(() => Increment(match, false))">+</button>
                            </div>
                            <div class="d-flex align-center gap-1" style="flex:1;min-width:0;overflow:hidden;">
                                @if (match.AwayTeamLogo is not null)
                                {
                                    <img src="@match.AwayTeamLogo" alt="" style="width:@(IsMobile ? "18" : "22")px;height:@(IsMobile ? "18" : "22")px;flex-shrink:0;" />
                                }
                                <span style="font-weight:600;font-size:@(IsMobile ? "12" : "15")px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@match.AwayTeamShortName</span>
                            </div>
                        </div>
                        <div style="text-align:center;font-size:11px;font-weight:600;color:var(--mud-palette-text-secondary);margin-top:2px;">
                            @if (match.Status == nameof(MatchStatus.Finished)) { <text>FT @match.HomeScore-@match.AwayScore</text> }
                            else if (match.KickoffTime.HasValue) { @ClientTime.ToLocal(match.KickoffTime.Value).ToString("dd MMM HH:mm") }
                        </div>
                        @{ var confidence = GetConfidenceText(match); }
                        @if (confidence is not null)
                        {
                            <div style="text-align:center;font-size:10px;color:#FF6B35;font-weight:600;margin-top:2px;">@confidence</div>
                        }
                    </div>
                }
            </div>

        @* Risk Plays Section *@
        @if (_riskPlays.Count > 0)
        {
            <div style="width:100%;max-width:600px;margin:12px auto 0;">
                <div @onclick="@(() => _showRiskPlays = !_showRiskPlays)"
                     class="d-flex align-center justify-space-between"
                     style="cursor:pointer;padding:10px 12px;background:linear-gradient(135deg,#7c4dff,#651fff);border-radius:10px;color:#fff;">
                    <div class="d-flex align-center gap-2">
                        <span style="font-size:18px;">🎲</span>
                        <div>
                            <div style="font-weight:700;font-size:14px;">Risk Plays</div>
                            <div style="font-size:11px;opacity:0.8;">
                                @if (AllLocked)
                                {
                                    var won = _riskPlays.Count(r => r.IsWon == true);
                                    var lost = _riskPlays.Count(r => r.IsWon == false);
                                    @($"{won} won · {lost} lost")
                                }
                                else
                                {
                                    @($"{_riskPlays.Count(r => r.IsActive)} active")
                                }
                            </div>
                        </div>
                    </div>
                    <MudIcon Icon="@(_showRiskPlays ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Style="color:#fff;" />
                </div>

                @if (_showRiskPlays)
                {
                    <div style="border:1px solid var(--mud-palette-lines-default);border-top:none;border-radius:0 0 10px 10px;overflow:hidden;">
                        @foreach (var rp in _riskPlays)
                        {
                            var statusColor = rp.IsResolved == true
                                ? (rp.IsWon == true ? "#4caf50" : "#f44336")
                                : rp.BonusPoints.HasValue ? "#ff9800" : "var(--mud-palette-text-secondary)";
                            <div style="padding:10px 12px;border-bottom:1px solid var(--mud-palette-lines-default);">
                                <div class="d-flex align-center justify-space-between mb-1">
                                    <div class="d-flex align-center gap-1">
                                        <span>@rp.Icon</span>
                                        <span style="font-weight:700;font-size:13px;">@rp.Label</span>
                                    </div>
                                    @if (rp.BonusPoints.HasValue)
                                    {
                                        <span style="font-weight:700;font-size:13px;color:@statusColor;">
                                            @(rp.BonusPoints > 0 ? "+" : "")@rp.BonusPoints
                                            @if (rp.IsResolved != true) { <span style="font-size:10px;opacity:0.7;"> (live)</span> }
                                        </span>
                                    }
                                </div>
                                <div style="font-size:11px;color:var(--mud-palette-text-secondary);margin-bottom:6px;">@rp.Description</div>

                                @{
                                    var rpMatchLocked = rp.MatchId.HasValue && _matches.FirstOrDefault(x => x.MatchId == rp.MatchId)?.IsLocked == true;
                                }
                                @if (!rpMatchLocked && !AllLocked)
                                {
                                    @* Match selector *@
                                    <MudSelect T="long?" @bind-Value="rp.MatchId" Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined"
                                               Placeholder="— Select match —" Style="font-size:12px;" Class="mb-1">
                                        @foreach (var m in UnlockedMatches)
                                        {
                                            <MudSelectItem T="long?" Value="@m.MatchId">
                                                <div class="d-flex align-center gap-1">
                                                    @if (m.HomeTeamLogo is not null) { <img src="@m.HomeTeamLogo" alt="" style="width:16px;height:16px;" /> }
                                                    <span>@m.HomeTeamShortName vs @m.AwayTeamShortName</span>
                                                    @if (m.AwayTeamLogo is not null) { <img src="@m.AwayTeamLogo" alt="" style="width:16px;height:16px;" /> }
                                                </div>
                                            </MudSelectItem>
                                        }
                                    </MudSelect>

                                    @* Type-specific selection *@
                                    @if (rp.MatchId.HasValue)
                                    {
                                        var selMatch = _matches.FirstOrDefault(x => x.MatchId == rp.MatchId);
                                        @if (rp.RiskType == RiskPlayType.CleanSheetBet && selMatch is not null)
                                        {
                                            <MudSelect T="string" @bind-Value="rp.Selection" Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined"
                                                       Placeholder="— Pick team —" Style="font-size:12px;">
                                                <MudSelectItem T="string" Value="@selMatch.HomeTeamId.ToString()">
                                                    <div class="d-flex align-center gap-1">@if (selMatch.HomeTeamLogo is not null) { <img src="@selMatch.HomeTeamLogo" alt="" style="width:16px;height:16px;" /> } <span>@selMatch.HomeTeamShortName</span></div>
                                                </MudSelectItem>
                                                <MudSelectItem T="string" Value="@selMatch.AwayTeamId.ToString()">
                                                    <div class="d-flex align-center gap-1">@if (selMatch.AwayTeamLogo is not null) { <img src="@selMatch.AwayTeamLogo" alt="" style="width:16px;height:16px;" /> } <span>@selMatch.AwayTeamShortName</span></div>
                                                </MudSelectItem>
                                            </MudSelect>
                                        }
                                        else if (rp.RiskType == RiskPlayType.FirstGoalTeam && selMatch is not null)
                                        {
                                            <MudSelect T="string" @bind-Value="rp.Selection" Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined"
                                                       Placeholder="— Pick team —" Style="font-size:12px;">
                                                <MudSelectItem T="string" Value="@selMatch.HomeTeamId.ToString()">
                                                    <div class="d-flex align-center gap-1">@if (selMatch.HomeTeamLogo is not null) { <img src="@selMatch.HomeTeamLogo" alt="" style="width:16px;height:16px;" /> } <span>@selMatch.HomeTeamShortName</span></div>
                                                </MudSelectItem>
                                                <MudSelectItem T="string" Value="@selMatch.AwayTeamId.ToString()">
                                                    <div class="d-flex align-center gap-1">@if (selMatch.AwayTeamLogo is not null) { <img src="@selMatch.AwayTeamLogo" alt="" style="width:16px;height:16px;" /> } <span>@selMatch.AwayTeamShortName</span></div>
                                                </MudSelectItem>
                                            </MudSelect>
                                        }
                                        else if (rp.RiskType == RiskPlayType.OverUnderGoals)
                                        {
                                            <MudSelect T="string" @bind-Value="rp.Selection" Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined"
                                                       Placeholder="— Pick —" Style="font-size:12px;">
                                                <MudSelectItem T="string" Value="@("Over")">Over 2.5 goals</MudSelectItem>
                                                <MudSelectItem T="string" Value="@("Under")">Under 2.5 goals</MudSelectItem>
                                            </MudSelect>
                                        }
                                    }
                                }
                                else if (rp.IsActive)
                                {
                                    <div style="font-size:12px;font-weight:600;">@MatchLabel(rp.MatchId!.Value)
                                        @if (rp.Selection is not null)
                                        {
                                            var selMatch = _matches.FirstOrDefault(x => x.MatchId == rp.MatchId);
                                            @if (rp.RiskType is RiskPlayType.CleanSheetBet or RiskPlayType.FirstGoalTeam && selMatch is not null)
                                            {
                                                <span style="color:var(--mud-palette-text-secondary);"> · @(rp.Selection == selMatch.HomeTeamId.ToString() ? selMatch.HomeTeamShortName : selMatch.AwayTeamShortName)</span>
                                            }
                                            else if (rp.RiskType == RiskPlayType.OverUnderGoals)
                                            {
                                                <span style="color:var(--mud-palette-text-secondary);"> · @rp.Selection 2.5</span>
                                            }
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }

        @if (_matches.Any(m => !m.IsLocked))
        {
            <div class="d-flex justify-center mt-4 gap-2">
                <MudButton Variant="Variant.Filled" Color="Color.Tertiary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Save"
                           OnClick="SubmitPredictionsAsync">
                    Save Predictions
                </MudButton>
                @if (_showConfidence)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Share"
                               OnClick="SharePredictions">
                        Share
                    </MudButton>
                }
            </div>
        }
    }
</MudContainer>
</PageGuard>
