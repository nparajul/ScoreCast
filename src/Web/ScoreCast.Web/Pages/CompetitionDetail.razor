@page "/competitions/{CompetitionId:long}"
@using ScoreCast.Shared.Enums

<PageGuard>
<div>
    @if (_competition is not null)
    {
        @* Banner *@
        <div style="padding:24px 16px;margin-bottom:0;">
            <MudContainer MaxWidth="MaxWidth.Medium">
                <div class="d-flex align-center gap-3">
                    @if (!string.IsNullOrEmpty(_competition.LogoUrl))
                    {
                        <img src="@_competition.LogoUrl" alt="" style="width:48px;height:48px;object-fit:contain;" />
                    }
                    <div>
                        <MudText Typo="Typo.h5" Style="font-weight:700;">@_competition.Name</MudText>
                        <div class="d-flex align-center gap-1">
                            @if (!string.IsNullOrEmpty(_competition.CountryFlagUrl))
                            {
                                <img src="@_competition.CountryFlagUrl" alt="" style="width:16px;height:12px;" />
                            }
                            <MudText Typo="Typo.caption">@_competition.CountryName</MudText>
                        </div>
                    </div>
                    <MudSpacer />
                    @if (_seasons.Count > 0)
                    {
                        <select @onchange="OnSeasonChanged" style="background:var(--mud-palette-surface);color:var(--mud-palette-text-primary);border:1px solid var(--mud-palette-lines-default);border-radius:8px;padding:6px 10px;font-size:13px;">
                            @foreach (var s in _seasons)
                            {
                                <option value="@s.Id" selected="@(s.Id == _selectedSeason?.Id)">@s.Name</option>
                            }
                        </select>
                    }
                </div>
            </MudContainer>
        </div>

        @* Tabs *@
        <div style="position:sticky;top:var(--mud-appbar-height);z-index:10;background:var(--mud-palette-background);">
            <MudContainer MaxWidth="MaxWidth.Medium">
                <div style="display:flex;overflow-x:auto;gap:0;border-bottom:2px solid var(--mud-palette-lines-default);">
                    @foreach (var tab in _tabs)
                    {
                        var active = tab == _activeTab;
                        <div @onclick="@(() => SwitchTab(tab))"
                             style="padding:10px 16px;font-size:13px;font-weight:@(active ? "700" : "500");cursor:pointer;white-space:nowrap;
                                    border-bottom:@(active ? "2px solid var(--mud-palette-primary)" : "2px solid transparent");
                                    color:@(active ? "var(--mud-palette-primary)" : "var(--mud-palette-text-secondary)");">
                            @tab
                        </div>
                    }
                </div>
            </MudContainer>
        </div>

        <MudContainer MaxWidth="MaxWidth.Medium" Style="padding-top:12px;padding-bottom:100px;">
            @switch (_activeTab)
            {
                case "Table":
                    @if (_table is not null && _table.Groups.Count > 0)
                    {
                        @if (_table.Format is CompetitionFormat.GroupAndKnockout)
                        {
                            @if (IsMobile)
                            {
                                <div style="display:flex;background:var(--mud-palette-dark);border-radius:20px;padding:3px;margin-bottom:12px;">
                                    @foreach (var tab in new[] { "Groups", "Best 3rd", "Knockout" })
                                    {
                                        var isActive = _groupTab == tab;
                                        <div @onclick="@(() => _groupTab = tab)"
                                             style="flex:1;text-align:center;padding:5px 0;border-radius:17px;font-size:0.75rem;font-weight:600;cursor:pointer;
                                                    background:@(isActive ? "var(--mud-palette-surface)" : "transparent");
                                                    color:@(isActive ? "var(--mud-palette-primary)" : "rgba(255,255,255,0.7)");">
                                            @tab
                                        </div>
                                    }
                                </div>

                                @if (_groupTab == "Groups")
                                {
                                    <GroupStageView Groups="_table.Groups" Zones="_zones" />
                                }
                                else if (_groupTab == "Best 3rd")
                                {
                                    <BestThirdPlacedTable Rows="_table.BestThirdPlaced" />
                                }
                                else
                                {
                                    <KnockoutBracket Bracket="_bracket" />
                                }
                            }
                            else
                            {
                                <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" Class="mt-0">
                                    <MudTabPanel Text="Group Stage" Icon="@Icons.Material.Filled.Groups">
                                        <GroupStageView Groups="_table.Groups" Zones="_zones" />
                                    </MudTabPanel>
                                    <MudTabPanel Text="Best 3rd Placed" Icon="@Icons.Material.Filled.EmojiEvents">
                                        <BestThirdPlacedTable Rows="_table.BestThirdPlaced" />
                                    </MudTabPanel>
                                    <MudTabPanel Text="Knockout" Icon="@Icons.Material.Filled.AccountTree">
                                        <KnockoutBracket Bracket="_bracket" />
                                    </MudTabPanel>
                                </MudTabs>
                            }
                        }
                        else
                        {
                            <LeagueTableView Rows="_table.Groups[0].Rows" Zones="_zones" />
                        }
                    }
                    else if (_table is not null)
                    {
                        <MudAlert Severity="Severity.Info">No table data available.</MudAlert>
                    }
                    break;

                case "Scores":
                    @if (_gameweek is not null)
                    {
                        <div class="d-flex align-center justify-center gap-1 mb-3">
                            <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" OnClick="PrevGw"
                                           Disabled="@(_gameweek.GameweekNumber <= 1)" Size="Size.Small" />
                            <MudChip T="string" Color="Color.Primary" Size="Size.Small" Style="font-weight:700;">
                                MW @_gameweek.GameweekNumber
                            </MudChip>
                            <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" OnClick="NextGw"
                                           Disabled="@(_gameweek.GameweekNumber >= _gameweek.TotalGameweeks)" Size="Size.Small" />
                        </div>
                        @foreach (var group in GetMatchesByDate())
                        {
                            <MudPaper Class="mb-3" Elevation="1" Style="border-radius:10px;overflow:hidden;">
                                <div style="padding:8px 10px 4px;font-weight:700;font-size:13px;text-align:center;">@group.Label</div>
                                <MudDivider />
                                @foreach (var match in group.Matches)
                                {
                                    <MatchTile Match="MatchTileModel.From(match)" IsExpanded="_expandedMatches.Contains(match.MatchId)" OnToggle="() => ToggleMatch(match.MatchId)" />
                                    @if (match != group.Matches.Last()) { <MudDivider /> }
                                }
                            </MudPaper>
                        }
                    }
                    break;

                case "Players":
                    @if (_playerStats is not null)
                    {
                        @if (IsMobile)
                        {
                            <div style="display:flex;background:var(--mud-palette-dark);border-radius:28px;padding:3px;margin-bottom:12px;overflow-x:auto;">
                                @foreach (var tab in new[] { "Overall", "Goals", "Assists", "Discipline" })
                                {
                                    var isActive = _playerStatTab == tab;
                                    <div @onclick="@(() => _playerStatTab = tab)"
                                         style="flex:1;text-align:center;padding:5px 8px;border-radius:24px;font-size:0.65rem;font-weight:700;cursor:pointer;white-space:nowrap;
                                                background:@(isActive ? "var(--mud-palette-surface)" : "transparent");
                                                color:@(isActive ? "var(--mud-palette-primary)" : "rgba(255,255,255,0.7)");">
                                        @tab
                                    </div>
                                }
                            </div>
                            var mobileRows = MobileTabRows.Take(50).ToList();
                            <MudSimpleTable Dense="true" Elevation="0" Style="background:transparent;border:none;">
                                <thead>
                                    <tr style="font-size:0.75rem;color:var(--mud-palette-text-secondary);">
                                        <th style="padding:8px 2px;width:20px;">#</th>
                                        <th style="padding:8px 2px;">Player</th>
                                        @if (_playerStatTab == "Overall")
                                        {
                                            <th style="padding:8px 2px;text-align:center;width:26px;">⚽</th>
                                            <th style="padding:8px 2px;text-align:center;width:26px;">👟</th>
                                            <th style="padding:8px 2px;text-align:center;width:26px;"><span style="display:inline-block;width:8px;height:11px;background:#fdd835;border-radius:1px;"></span></th>
                                            <th style="padding:8px 2px;text-align:center;width:26px;"><span style="display:inline-block;width:8px;height:11px;background:#d32f2f;border-radius:1px;"></span></th>
                                        }
                                        else if (_playerStatTab == "Goals")
                                        {
                                            <th style="padding:8px 2px;text-align:center;width:30px;">⚽</th>
                                            <th style="padding:8px 2px;text-align:center;width:30px;">Pen</th>
                                        }
                                        else if (_playerStatTab == "Assists")
                                        {
                                            <th style="padding:8px 2px;text-align:center;width:30px;">👟</th>
                                        }
                                        else
                                        {
                                            <th style="padding:8px 2px;text-align:center;width:30px;"><span style="display:inline-block;width:8px;height:11px;background:#fdd835;border-radius:1px;"></span></th>
                                            <th style="padding:8px 2px;text-align:center;width:30px;"><span style="display:inline-block;width:8px;height:11px;background:#d32f2f;border-radius:1px;"></span></th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (var i = 0; i < mobileRows.Count; i++)
                                    {
                                        var row = mobileRows[i];
                                        <tr style="font-size:0.8125rem;border-bottom:1px solid var(--mud-palette-lines-default);">
                                            <td style="padding:8px 2px;font-weight:600;">@(i + 1)</td>
                                            <td style="padding:8px 2px;">
                                                <div class="d-flex align-center gap-1" style="min-width:0;">
                                                    @if (row.TeamLogo is not null)
                                                    {
                                                        <img src="@row.TeamLogo" alt="" style="width:18px;height:18px;flex-shrink:0;" />
                                                    }
                                                    <span style="font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@row.PlayerName</span>
                                                </div>
                                            </td>
                                            @if (_playerStatTab == "Overall")
                                            {
                                                <td style="padding:8px 2px;text-align:center;font-weight:700;">@(row.Goals + row.PenaltyGoals)</td>
                                                <td style="padding:8px 2px;text-align:center;">@row.Assists</td>
                                                <td style="padding:8px 2px;text-align:center;">@row.YellowCards</td>
                                                <td style="padding:8px 2px;text-align:center;">@row.RedCards</td>
                                            }
                                            else if (_playerStatTab == "Goals")
                                            {
                                                <td style="padding:8px 2px;text-align:center;font-weight:700;">@(row.Goals + row.PenaltyGoals)</td>
                                                <td style="padding:8px 2px;text-align:center;color:var(--mud-palette-text-secondary);font-size:0.75rem;">@row.PenaltyGoals</td>
                                            }
                                            else if (_playerStatTab == "Assists")
                                            {
                                                <td style="padding:8px 2px;text-align:center;font-weight:700;">@row.Assists</td>
                                            }
                                            else
                                            {
                                                <td style="padding:8px 2px;text-align:center;font-weight:700;">@row.YellowCards</td>
                                                <td style="padding:8px 2px;text-align:center;font-weight:700;">@row.RedCards</td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        }
                        else
                        {
                            <MudTable Items="@SortedPlayerRows" Dense="true" Hover="true" Striped="true" Elevation="1" Style="border-radius:8px;" RowsPerPage="25">
                                <HeaderContent>
                                    <MudTh Style="width:50px;">#</MudTh>
                                    <MudTh>Player</MudTh>
                                    <MudTh>Team</MudTh>
                                    <MudTh Style="cursor:pointer;" @onclick="@(() => SortBy("Goals"))">
                                        ⚽ Goals @if (SortIcon("Goals") != "") { <MudIcon Icon="@SortIcon("Goals")" Size="Size.Small" /> }
                                    </MudTh>
                                    <MudTh Style="cursor:pointer;" @onclick="@(() => SortBy("Assists"))">
                                        👟 Assists @if (SortIcon("Assists") != "") { <MudIcon Icon="@SortIcon("Assists")" Size="Size.Small" /> }
                                    </MudTh>
                                    <MudTh Style="cursor:pointer;" @onclick="@(() => SortBy("YellowCards"))">
                                        <span style="display:inline-block;width:8px;height:11px;background:#fdd835;border-radius:1px;vertical-align:middle;"></span> Yellows
                                        @if (SortIcon("YellowCards") != "") { <MudIcon Icon="@SortIcon("YellowCards")" Size="Size.Small" /> }
                                    </MudTh>
                                    <MudTh Style="cursor:pointer;" @onclick="@(() => SortBy("RedCards"))">
                                        <span style="display:inline-block;width:8px;height:11px;background:#d32f2f;border-radius:1px;vertical-align:middle;"></span> Reds
                                        @if (SortIcon("RedCards") != "") { <MudIcon Icon="@SortIcon("RedCards")" Size="Size.Small" /> }
                                    </MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@(SortedPlayerRows.ToList().IndexOf(context) + 1)</MudTd>
                                    <MudTd Style="font-weight:600;">
                                        <div class="d-flex align-center gap-2">
                                            @if (context.PlayerImageUrl is not null)
                                            {
                                                <MudAvatar Size="Size.Medium"><MudImage Src="@context.PlayerImageUrl" /></MudAvatar>
                                            }
                                            @context.PlayerName <span style="font-weight:400;color:var(--mud-palette-text-secondary);font-size:0.8rem;">(@ScoreCast.Shared.Constants.PlayerPositions.ToShortName(context.Position))</span>
                                        </div>
                                    </MudTd>
                                    <MudTd>
                                        <div class="d-flex align-center gap-2">
                                            @if (context.TeamLogo is not null) { <img src="@context.TeamLogo" alt="" style="width:20px;height:20px;object-fit:contain;" /> }
                                            @context.TeamName
                                        </div>
                                    </MudTd>
                                    <MudTd Style="font-weight:700;">
                                        @(context.Goals + context.PenaltyGoals)
                                        @if (context.PenaltyGoals > 0) { <span style="font-size:12px;color:var(--mud-palette-text-secondary);"> (@context.PenaltyGoals pen)</span> }
                                    </MudTd>
                                    <MudTd>@context.Assists</MudTd>
                                    <MudTd>@context.YellowCards</MudTd>
                                    <MudTd>@context.RedCards</MudTd>
                                </RowTemplate>
                                <PagerContent>
                                    <MudTablePager PageSizeOptions="new[] { 25, 50, 100 }" />
                                </PagerContent>
                            </MudTable>
                        }
                    }
                    break;
            }
        </MudContainer>
    }
</div>
</PageGuard>
