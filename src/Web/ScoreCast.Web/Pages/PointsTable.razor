@page "/points-table"
@using ScoreCast.Shared.Constants
@using ScoreCast.Shared.Enums

<PageGuard>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">Points Table</MudText>

    <div class="d-flex gap-2 mb-4 flex-wrap align-end">
        <MudSelect T="string"
                   Label="Country"
                   Value="_selectedCountry"
                   Variant="Variant.Outlined"
                   Dense="true"
                   Margin="Margin.Dense"
                   Style="min-width:200px;max-width:300px;"
                   ValueChanged="OnCountryChanged">
            @foreach (var country in _countries)
            {
                <MudSelectItem T="string" Value="@country.Name">
                    <div class="d-flex align-center gap-2">
                        @if (!string.IsNullOrEmpty(country.FlagUrl))
                        {
                            <img src="@country.FlagUrl" alt="" style="width:20px;height:14px;" />
                        }
                        @country.Name
                    </div>
                </MudSelectItem>
            }
        </MudSelect>

        <MudSelect T="CompetitionResult"
                   Label="Competition"
                   Value="_selectedCompetition"
                   ToStringFunc="@(c => c?.Name ?? string.Empty)"
                   Variant="Variant.Outlined"
                   Dense="true"
                   Margin="Margin.Dense"
                   Style="min-width:200px;max-width:350px;"
                   Disabled="@(_filteredCompetitions.Count == 0)"
                   ValueChanged="OnCompetitionChanged">
            @foreach (var comp in _filteredCompetitions)
            {
                <MudSelectItem T="CompetitionResult" Value="comp">
                    <div class="d-flex align-center gap-2">
                        @if (!string.IsNullOrEmpty(comp.LogoUrl))
                        {
                            <img src="@comp.LogoUrl" alt="" style="width:20px;height:20px;" />
                        }
                        @comp.Name
                    </div>
                </MudSelectItem>
            }
        </MudSelect>

        <MudSelect T="SeasonResult"
                   Label="Season"
                   Value="_selectedSeason"
                   Variant="Variant.Outlined"
                   Dense="true"
                   Margin="Margin.Dense"
                   Style="min-width:180px;max-width:250px;"
                   Disabled="@(_seasons.Count == 0)"
                   ValueChanged="OnSeasonChanged"
                   ToStringFunc="@(s => s?.Name ?? string.Empty)">
            @foreach (var season in _seasons)
            {
                <MudSelectItem T="SeasonResult" Value="season">@season.Name</MudSelectItem>
            }
        </MudSelect>
    </div>

    @if (_result is not null && _result.Groups.Count > 0)
    {
        @if (!IsGroupFormat)
        {
            <LeagueTableView Rows="_result.Groups[0].Rows" Zones="_zones" />
        }
        else
        {
            <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" Class="mt-0">
                <MudTabPanel Text="Group Stage" Icon="@Icons.Material.Filled.Groups">
                    <GroupStageView Groups="_result.Groups" Zones="_zones" />
                </MudTabPanel>
                <MudTabPanel Text="Best 3rd Placed" Icon="@Icons.Material.Filled.EmojiEvents">
                    <BestThirdPlacedTable Rows="_result.BestThirdPlaced" />
                </MudTabPanel>
                <MudTabPanel Text="Knockout" Icon="@Icons.Material.Filled.AccountTree">
                    <KnockoutBracket Bracket="_bracket" />
                </MudTabPanel>
            </MudTabs>
        }
    }
    else if (_selectedSeason is not null)
    {
        <MudAlert Severity="Severity.Info">No match data available for this season. Sync matches first.</MudAlert>
    }
</MudContainer>
</PageGuard>
