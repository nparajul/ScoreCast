@page "/highlights"

<style>
    @@media (max-width: 959.98px) {
        .mud-appbar { display: none !important; }
        .bottom-nav { display: none !important; }
        .main-container { padding: 0 !important; margin: 0 !important; max-width: 100% !important; }
        .reels-container { height: 100vh !important; }
        .reel-card { height: 100vh !important; }
    }
    /* Kill outer page scroll when reels are active */
    html, body, .mud-layout, .main-container {
        overflow: hidden !important;
        height: 100% !important;
    }
    .main-container { padding: 0 !important; }
    .mud-layout > footer { display: none !important; }
    .reels-container {
        height: calc(100vh - var(--mud-appbar-height));
        overflow-y: scroll;
        scroll-snap-type: y mandatory;
        -webkit-overflow-scrolling: touch;
        background: #000;
        max-width: 480px;
        margin: 0 auto;
    }
    .reel-card {
        scroll-snap-align: start;
        scroll-snap-stop: always;
        height: calc(100vh - var(--mud-appbar-height));
        display: flex;
        flex-direction: column;
        background: #000;
        color: #fff;
    }
    .reel-video-wrap {
        width: 100%;
        flex: 1;
        min-height: 0;
        position: relative;
        background: #111;
    }
    .reel-video-wrap iframe {
        position: absolute;
        top: 0; left: 0;
        width: 100%;
        height: 100%;
        border: none;
    }
    .reel-placeholder {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #111;
    }
    .reel-info {
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 12px 16px;
        gap: 6px;
        text-align: center;
    }
    .reel-match-row {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .reel-team-logo { width: 32px; height: 32px; object-fit: contain; }
    .reel-team-name { font-weight: 600; font-size: 13px; }
    .reel-score { font-weight: 800; font-size: 24px; letter-spacing: 2px; }
    .reel-meta { font-size: 13px; opacity: 0.5; }
    .reel-attr { font-size: 9px; color: rgba(255,255,255,0.25); }
    .reel-empty {
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 12px;
        color: rgba(255,255,255,0.5);
    }
</style>

<div class="reels-container" @ref="_containerRef">
    @if (_items.Count == 0 && !Loading.IsLoading)
    {
        <div class="reel-card">
            <div class="reel-empty">
                <MudIcon Icon="@Icons.Material.Filled.VideoLibrary" Size="Size.Large" />
                <MudText Typo="Typo.body2">No highlights available yet</MudText>
            </div>
        </div>
    }
    else
    {
        @for (var i = 0; i < _items.Count; i++)
        {
            var item = _items[i];
            var idx = i;
            <div class="reel-card" data-index="@idx">
                <div class="reel-video-wrap">
                    @if (idx == _currentIndex)
                    {
                        @((MarkupString)(item.EmbedHtml ?? ""))
                    }
                    else
                    {
                        <div class="reel-placeholder">
                            <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Size="Size.Large" Style="color:rgba(255,255,255,0.3);" />
                        </div>
                    }
                </div>
                <div class="reel-info">
                    <a href="/matches/@item.MatchId" style="text-decoration:none;color:inherit;">
                        <div class="reel-match-row">
                            @if (item.HomeLogoUrl is not null)
                            {
                                <img src="@item.HomeLogoUrl" alt="" class="reel-team-logo" />
                            }
                            <span class="reel-team-name">@ShortName(item.HomeTeam)</span>
                            <span class="reel-score">@(item.HomeScore ?? 0) - @(item.AwayScore ?? 0)</span>
                            <span class="reel-team-name">@ShortName(item.AwayTeam)</span>
                            @if (item.AwayLogoUrl is not null)
                            {
                                <img src="@item.AwayLogoUrl" alt="" class="reel-team-logo" />
                            }
                        </div>
                    </a>
                    <div class="reel-meta">
                        @item.CompetitionName
                        @if (item.KickoffTime.HasValue)
                        {
                            <span> · @FormatLocal(item.KickoffTime.Value, "dd MMM yyyy")</span>
                        }
                    </div>
                    <div class="reel-attr">Powered by YouTube</div>
                </div>
            </div>
        }
    }
</div>

<script suppress-error="BL9992">
    window.highlightReels = {
        _observer: null,
        _dotnetRef: null,

        init(container, dotnetRef) {
            this._dotnetRef = dotnetRef;
            this._observer = new IntersectionObserver((entries) => {
                for (const e of entries) {
                    if (e.isIntersecting && e.intersectionRatio > 0.5) {
                        const idx = parseInt(e.target.dataset.index);
                        if (!isNaN(idx)) {
                            dotnetRef.invokeMethodAsync('OnScrollSnap', idx);
                        }
                    }
                }
            }, { root: container, threshold: 0.5 });

            container.querySelectorAll('.reel-card[data-index]').forEach(card => {
                this._observer.observe(card);
            });
        },

        observe(container) {
            if (!this._observer) return;
            container.querySelectorAll('.reel-card[data-index]').forEach(card => {
                this._observer.observe(card);
            });
        },

        destroy() {
            if (this._observer) this._observer.disconnect();
        }
    };
</script>
