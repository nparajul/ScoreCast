@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.WebAssembly.Hosting
@using ScoreCast.Web.Components.Helpers
@using ScoreCast.Web.Theme
@implements ScoreCast.Web.Components.Helpers.IAlertablePage
@inject IWebAssemblyHostEnvironment HostEnvironment
@inject INotifyService Notify
@inject IAlertService Alert
@inject ILoadingService Loading
@inject IRoleNavigationService RoleNav

<PageTitle>ScoreCast</PageTitle>
<MudThemeProvider Theme="AppTheme.Theme" IsDarkMode="false" />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.Medium" CloseButton="true"/>
<MudPopoverProvider />
<MudSnackbarProvider />

<MudBreakpointProvider OnBreakpointChanged="@(bp => { _isMobile = bp <= Breakpoint.Sm; StateHasChanged(); })">
<MudLayout Style="min-height:100vh; display:flex; flex-direction:column;">
    <MudAppBar Elevation="2" Color="Color.Primary">
        @if (_showBackButton)
        {
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                           Color="Color.Inherit"
                           OnClick="GoBack"
                           aria-label="Go back" />
        }

        @* Mobile: full brand logo *@
        <MudImage Src="scorecast-logo-dark.svg" Alt="ScoreCast" Height="32" Class="d-flex d-md-none" Style="object-fit:contain;" />

        @* Desktop: icon + text *@
        <MudImage Src="scorecast-icon-light.svg" Alt="ScoreCast" Width="36" Height="36" Class="mr-2 d-none d-md-flex" />
        <MudText Typo="Typo.h6" Class="mr-4 d-none d-md-flex">ScoreCast</MudText>

        <div class="d-none d-md-flex">
            @foreach (var onePage in RoleNav.Pages.Where(p => p.ParentPageId is null))
            {
                <MudButton Href="@onePage.PageUrl" Color="Color.Inherit">@onePage.PageName</MudButton>
            }
            <MudButton Href="/insights" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.AutoAwesome">Insights</MudButton>
        </div>

        <MudSpacer />

        @if (RoleNav.Roles.Count > 1)
        {
            <select @onchange="OnRoleChangedFromSelect" class="d-none d-md-inline" style="background:transparent; color:inherit; border:1px solid rgba(255,255,255,0.3); border-radius:4px; padding:4px 8px; margin-right:8px;">
                @foreach (var role in RoleNav.Roles)
                {
                    <option value="@role.Id" selected="@(role.Id == _selectedRoleId)">@role.Name</option>
                }
            </select>
        }

        <LoginDisplay Class="d-none d-md-flex" />

        @* Mobile: hamburger that opens popup (only when logged in) *@
        <AuthorizeView>
            <Authorized>
                <MudIconButton Icon="@Icons.Material.Filled.Menu"
                               Color="Color.Inherit"
                               OnClick="@(() => _menuOpen = !_menuOpen)"
                               Class="d-flex d-md-none" />
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    @* Mobile popup menu — account & extras (nav items are in BottomNav) *@
    @if (_menuOpen)
    {
        <div class="menu-overlay d-flex d-md-none" @onclick="@(() => _menuOpen = false)"></div>
        <MudPaper Elevation="8" Class="menu-popup d-flex d-md-none rounded-lg">
            <div class="d-flex justify-space-between align-center mb-3">
                <MudText Typo="Typo.h6" Style="font-weight:700;">Account</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               OnClick="@(() => _menuOpen = false)" />
            </div>

            <AuthorizeView>
                <Authorized>
                    <MudText Typo="Typo.body2" Class="mb-3" Style="opacity:0.7;">Signed in as @context.User.Identity?.Name</MudText>
                </Authorized>
            </AuthorizeView>

            @if (RoleNav.Roles.Count > 1)
            {
                <MudText Typo="Typo.caption" Class="mb-1" Style="font-weight:600; opacity:0.6;">SWITCH ROLE</MudText>
                <div class="d-flex flex-wrap gap-2 mb-3">
                    @foreach (var role in RoleNav.Roles)
                    {
                        <MudChip T="string" Color="@(role.Id == _selectedRoleId ? Color.Primary : Color.Default)"
                                 OnClick="@(async () => { await OnRoleChanged(role.Id); _menuOpen = false; })">
                            @role.Name
                        </MudChip>
                    }
                </div>
            }

            <div class="d-flex flex-wrap gap-2 justify-center">
                <MudPaper Elevation="0" Class="pa-3 rounded-lg d-flex flex-column align-center"
                          Style="width:90px; cursor:pointer; background:var(--mud-palette-background);"
                          @onclick="@(() => { _menuOpen = false; Nav.NavigateTo("/settings"); })">
                    <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Medium" Color="Color.Primary" Class="mb-1" />
                    <MudText Typo="Typo.caption" Align="Align.Center" Style="font-weight:600; font-size:0.7rem;">Settings</MudText>
                </MudPaper>
                <MudPaper Elevation="0" Class="pa-3 rounded-lg d-flex flex-column align-center"
                          Style="width:90px; cursor:pointer; background:var(--mud-palette-background);"
                          @onclick="@(() => { _menuOpen = false; Nav.NavigateTo("/logout"); })">
                    <MudIcon Icon="@Icons.Material.Filled.Logout" Size="Size.Medium" Color="Color.Error" Class="mb-1" />
                    <MudText Typo="Typo.caption" Align="Align.Center" Style="font-weight:600; font-size:0.7rem;">Log out</MudText>
                </MudPaper>
            </div>
        </MudPaper>
    }

    @* Desktop drawer (unchanged) *@
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always" Variant="DrawerVariant.Temporary" Class="d-none d-md-flex">
        <MudNavMenu>
            @foreach (var onePage in RoleNav.Pages.Where(p => p.ParentPageId is null))
            {
                <MudNavLink Match="NavLinkMatch.All" OnClick="@(() => NavigateAndCloseDrawer(onePage.PageUrl))">
                    @onePage.PageName
                </MudNavLink>
            }
            @if (RoleNav.Roles.Count > 1)
            {
                <MudDivider Class="my-2" />
                @foreach (var role in RoleNav.Roles)
                {
                    <MudNavLink OnClick="@(async () => { await OnRoleChanged(role.Id); _drawerOpen = false; })">
                        @role.Name
                    </MudNavLink>
                }
            }
        </MudNavMenu>
    </MudDrawer>

    <MudContainer Class="main-container" MaxWidth="MaxWidth.ExtraExtraLarge" Style="flex:1;">
        <CascadingValue Value="_isMobile" Name="IsMobile">
            <UserSync />
            <MudContainer MaxWidth="Alert.Width" Class="d-flex flex-column gap-4">
                @foreach (var alert in Alert.Alerts.ToList())
                {
                    <MudAlert Severity="@alert.Severity" Dense="true"
                              ShowCloseIcon="true" Variant="Variant.Filled"
                              CloseIconClicked="@(() => Alert.Remove(alert.Key))">
                        @if (alert.Content.TryPickT0(out var markup, out var renderFragment))
                        {
                            @markup
                        }
                        else
                        {
                            @renderFragment
                        }
                    </MudAlert>
                }
            </MudContainer>
            @Body
        </CascadingValue>
    </MudContainer>

    <footer class="d-flex flex-column align-center justify-center pa-4"
            style="height:80px;background:var(--mud-palette-appbar-background);color:var(--mud-palette-appbar-text);">
        <MudText Typo="Typo.body2">© @ScoreCastDateTime.Now.Value.Year ScoreCast. All rights reserved.</MudText>
        <MudText Typo="Typo.caption" Style="opacity:0.6;">Premier League Predictions</MudText>
    </footer>

    <BottomNav />

    <MudOverlay Visible="Loading.IsLoading" DarkBackground="true" ZIndex="9999">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        <MudText Typo="Typo.body1" Class="mt-4" Color="Color.Surface">
            @(Loading.LoadingMessage ?? "Loading...")
        </MudText>
    </MudOverlay>
</MudLayout>
</MudBreakpointProvider>

<script>
    window.downLoadFile = (filename, bytesBase64, contentType) => {
        const link = document.createElement('a');
        link.download = filename;
        link.href = `data:${contentType};base64,${bytesBase64}`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    }
</script>
