@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.WebAssembly.Hosting
@using ScoreCast.Web.Components.Helpers
@using ScoreCast.Web.Theme
@implements ScoreCast.Web.Components.Helpers.IAlertablePage
@inject IWebAssemblyHostEnvironment HostEnvironment
@inject INotifyService Notify
@inject IAlertService Alert
@inject ILoadingService Loading
@inject IRoleNavigationService RoleNav

<PageTitle>ScoreCast</PageTitle>
<MudThemeProvider Theme="AppTheme.Theme" IsDarkMode="false" />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.Medium" CloseButton="true"/>
<MudPopoverProvider />
<MudSnackbarProvider />

<MudBreakpointProvider OnBreakpointChanged="@(bp => { _isMobile = bp <= Breakpoint.Sm; StateHasChanged(); })">
<MudLayout Style="min-height:100vh; display:flex; flex-direction:column;">
    <MudAppBar Elevation="2" Color="Color.Primary">
        @if (_showBackButton)
        {
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                           Color="Color.Inherit"
                           OnClick="GoBack"
                           Class="d-flex d-md-none"
                           Style="background:rgba(255,255,255,0.15);border-radius:50%;width:36px;height:36px;"
                           aria-label="Go back" />
        }

        @* Mobile: full brand logo *@
        <MudImage Src="scorecast-logo-dark.svg" Alt="ScoreCast" Height="32" Class="d-flex d-md-none" Style="object-fit:contain;" />

        @* Desktop: icon + text *@
        <MudImage Src="scorecast-icon-light.svg" Alt="ScoreCast" Width="36" Height="36" Class="mr-2 d-none d-md-flex" />
        <MudText Typo="Typo.h6" Class="mr-4 d-none d-md-flex">ScoreCast</MudText>

        <AuthorizeView>
            <Authorized>
                <div class="d-none d-md-flex">
                    @foreach (var onePage in RoleNav.Pages.Where(p => p.ParentPageId is null).OrderBy(p => p.DisplayOrder))
                    {
                        <MudButton Href="@onePage.PageUrl" Color="Color.Inherit">@onePage.PageName</MudButton>
                    }
                    <MudButton Href="/insights" Color="Color.Inherit">Insights</MudButton>
                </div>
            </Authorized>
        </AuthorizeView>

        <MudSpacer />

        <AuthorizeView>
            <Authorized>
                <MudIconButton Icon="@Icons.Material.Filled.Search"
                               Color="Color.Inherit"
                               OnClick="OpenSearch"
                               aria-label="Search" />
            </Authorized>
        </AuthorizeView>

        @if (RoleNav.Roles.Count > 1)
        {
            <select @onchange="OnRoleChangedFromSelect" class="d-none d-md-inline" style="background:transparent; color:inherit; border:1px solid rgba(255,255,255,0.3); border-radius:4px; padding:4px 8px; margin-right:8px;">
                @foreach (var role in RoleNav.Roles)
                {
                    <option value="@role.Id" selected="@(role.Id == _selectedRoleId)">@role.Name</option>
                }
            </select>
        }

        <LoginDisplay Class="d-none d-md-flex" />
    </MudAppBar>

    @* Desktop drawer (unchanged) *@
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always" Variant="DrawerVariant.Temporary" Class="d-none d-md-flex">
        <MudNavMenu>
            @foreach (var onePage in RoleNav.Pages.Where(p => p.ParentPageId is null).OrderBy(p => p.DisplayOrder))
            {
                <MudNavLink Match="NavLinkMatch.All" OnClick="@(() => NavigateAndCloseDrawer(onePage.PageUrl))">
                    @onePage.PageName
                </MudNavLink>
            }
            @if (RoleNav.Roles.Count > 1)
            {
                <MudDivider Class="my-2" />
                @foreach (var role in RoleNav.Roles)
                {
                    <MudNavLink OnClick="@(async () => { await OnRoleChanged(role.Id); _drawerOpen = false; })">
                        @role.Name
                    </MudNavLink>
                }
            }
        </MudNavMenu>
    </MudDrawer>

    <MudContainer Class="main-container" MaxWidth="MaxWidth.ExtraExtraLarge" Style="flex:1;">
        <CascadingValue Value="_isMobile" Name="IsMobile">
            <UserSync />
            <div class="alert-toast-container">
                @foreach (var alert in Alert.Alerts.ToList())
                {
                    <MudAlert Severity="@alert.Severity" Dense="true"
                              ShowCloseIcon="true" Variant="Variant.Filled"
                              CloseIconClicked="@(() => Alert.Remove(alert.Key))">
                        @if (alert.Content.TryPickT0(out var markup, out var renderFragment))
                        {
                            @markup
                        }
                        else
                        {
                            @renderFragment
                        }
                    </MudAlert>
                }
            </div>
            @Body
        </CascadingValue>
    </MudContainer>

    <footer class="d-none d-md-flex flex-column align-center justify-center pa-4"
            style="height:80px;background:var(--mud-palette-appbar-background);color:var(--mud-palette-appbar-text);">
        <MudText Typo="Typo.body2">© @ScoreCastDateTime.Now.Value.Year ScoreCast. All rights reserved.</MudText>
        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.5);">Football Predictions & Insights</MudText>
    </footer>

    <BottomNav />

    <MudOverlay Visible="Loading.IsLoading" DarkBackground="true" ZIndex="9999">
        <div style="display:flex;flex-direction:column;align-items:center;">
            <img src="scorecast-icon.svg" alt="" width="56" height="56" style="animation:pulse 1.5s ease-in-out infinite;" />
            <MudText Typo="Typo.body2" Class="mt-3" Color="Color.Surface">
                @(Loading.LoadingMessage ?? "Loading...")
            </MudText>
        </div>
    </MudOverlay>
</MudLayout>
</MudBreakpointProvider>

<script>
    window.downLoadFile = (filename, bytesBase64, contentType) => {
        const link = document.createElement('a');
        link.download = filename;
        link.href = `data:${contentType};base64,${bytesBase64}`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    }
</script>
