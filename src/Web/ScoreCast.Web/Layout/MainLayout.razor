@inherits LayoutComponentBase

<MudThemeProvider @ref="_themeProvider" @bind-IsDarkMode="_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="2" Color="Color.Primary">
        <MudIcon Icon="@Icons.Material.Filled.SportsSoccer" Class="mr-2" />
        <MudText Typo="Typo.h6" Class="mr-4">ScoreCast</MudText>
        <MudSpacer />
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="ToggleDarkMode" />
        <LoginDisplay />
    </MudAppBar>
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private MudThemeProvider _themeProvider = default!;
    private bool _isDarkMode;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#37003C",
            Secondary = "#00FF87",
            AppbarBackground = "#37003C",
            AppbarText = "#FFFFFF"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#00FF87",
            Secondary = "#37003C",
            Surface = "#1E1E2E",
            Background = "#181825",
            AppbarBackground = "#1E1E2E",
            AppbarText = "#00FF87"
        }
    };

    private void ToggleDarkMode() => _isDarkMode = !_isDarkMode;
}
