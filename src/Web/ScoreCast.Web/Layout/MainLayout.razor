@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.WebAssembly.Hosting
@using ScoreCast.Web.Components.Helpers
@using ScoreCast.Web.Theme
@implements ScoreCast.Web.Components.Helpers.IAlertablePage
@inject IWebAssemblyHostEnvironment HostEnvironment
@inject INotifyService Notify
@inject IAlertService Alert
@inject ILoadingService Loading

@inject IRoleNavigationService RoleNav

<PageTitle>ScoreCast</PageTitle>
<MudThemeProvider @ref="_themeProvider" @bind-IsDarkMode="_isDarkMode" Theme="AppTheme.Theme" />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.Medium" CloseButton="true"/>
<MudPopoverProvider />
<MudSnackbarProvider />

<MudBreakpointProvider>
<MudLayout Style="min-height:100vh; display:flex; flex-direction:column;">
    <MudAppBar Elevation="2" Color="Color.Primary">
            <MudImage Src="scorecast-icon-light.svg" Alt="ScoreCast" Width="36" Height="36" Class="mr-2" />
            <MudText Typo="Typo.h6" Class="mr-4">ScoreCast</MudText>

            @foreach (var onePage in RoleNav.Pages)
            {
                <MudButton Href="@onePage.PageUrl" Color="Color.Inherit">@onePage.PageName</MudButton>
            }

            <MudSpacer />

            @if (RoleNav.Roles.Count > 1)
            {
                <select @onchange="OnRoleChangedFromSelect" style="background:transparent; color:inherit; border:1px solid rgba(255,255,255,0.3); border-radius:4px; padding:4px 8px; margin-right:8px;">
                    @foreach (var role in RoleNav.Roles)
                    {
                        <option value="@role.Id" selected="@(role.Id == _selectedRoleId)">@role.Name</option>
                    }
                </select>
            }
            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit"
                           OnClick="ToggleDarkMode" />
            <LoginDisplay />
        </MudAppBar>
        <MudContainer Class="main-container" MaxWidth="MaxWidth.ExtraExtraLarge" Style="flex:1; padding-top:80px;">
            <CascadingValue Value="_isDarkMode" Name="IsDarkMode">
                <UserSync />
                <MudContainer MaxWidth="Alert.Width" Class="d-flex flex-column gap-4">
                    @foreach (var alert in Alert.Alerts.ToList())
                    {
                        <MudAlert Severity="@alert.Severity" Dense="true"
                                  ShowCloseIcon="true" Variant="Variant.Filled"
                                  CloseIconClicked="@(() => Alert.Remove(alert.Key))">
                            @if (alert.Content.TryPickT0(out var markup, out var renderFragment))
                            {
                                @markup
                            }
                            else
                            {
                                @renderFragment
                            }
                        </MudAlert>
                    }
                </MudContainer>
                @Body
            </CascadingValue>
        </MudContainer>
    <footer class="d-flex flex-column align-center justify-center pa-4" style="background:var(--mud-palette-primary);color:var(--mud-palette-primary-text);height:80px;">
        <MudText Typo="Typo.body2">© @DateTime.Now.Year ScoreCast. All rights reserved.</MudText>
        <MudText Typo="Typo.caption" Style="opacity:0.6;">Premier League Predictions</MudText>
    </footer>

    <MudOverlay Visible="Loading.IsLoading" DarkBackground="true" ZIndex="9999">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Typo="Typo.body1" Class="mt-4" Color="Color.Surface">
                @(Loading.LoadingMessage ?? "Loading...")
            </MudText>
    </MudOverlay>
</MudLayout>
</MudBreakpointProvider>

<script>
    window.downLoadFile = (filename, bytesBase64, contentType) => {
        const link = document.createElement('a');
        link.download = filename;
        link.href = `data:${contentType};base64,${bytesBase64}`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    }
</script>

<style>
    ::deep .main-container{
        min-height:700px;
        margin-bottom:60px;
        margin-top:var(--mud-appbar-height);
        padding-top:16px;
        padding-bottom:2%;
        padding-left: 0;
        padding-right: 0;
    }
</style>
