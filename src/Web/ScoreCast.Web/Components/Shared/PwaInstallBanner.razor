@implements IAsyncDisposable

@if (_showBanner && !_isStandalone)
{
    <div class="pwa-install-banner">
        <img src="scorecast-icon.svg" alt="" style="width:32px;height:32px;flex-shrink:0;" />
        <div style="flex:1;min-width:0;">
            <div style="font-weight:700;font-size:13px;">Install ScoreCast</div>
            @if (_isIos)
            {
                <div style="font-size:11px;opacity:0.85;line-height:1.3;">
                    Tap <span style="font-weight:700;">⎙ Share</span> → <span style="font-weight:700;">Add to Home Screen</span>
                </div>
            }
            else
            {
                <div style="font-size:11px;opacity:0.85;">Get the full app experience</div>
            }
        </div>
        @if (!_isIos && _canInstall)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small" OnClick="Install"
                       Style="font-weight:700;text-transform:none;border-radius:20px;flex-shrink:0;">
                Install
            </MudButton>
        }
        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="Dismiss"
                       Style="opacity:0.7;color:#fff;flex-shrink:0;" aria-label="Dismiss" />
    </div>
}

<style>
    .pwa-install-banner {
        position: fixed;
        bottom: 70px;
        left: 8px;
        right: 8px;
        z-index: 9000;
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 12px;
        background: #FF6B35;
        color: #fff;
        border: none;
        border-radius: 14px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.15);
        animation: slideUp 0.3s ease-out;
    }
    @@keyframes slideUp {
        from { transform: translateY(100%); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }
    @@media (min-width: 960px) {
        .pwa-install-banner { bottom: 20px; left: auto; right: 20px; max-width: 380px; }
    }
</style>
