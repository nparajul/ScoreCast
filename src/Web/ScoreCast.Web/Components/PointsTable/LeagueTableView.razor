@using ScoreCast.Shared.Constants

@* ── MOBILE: tabbed views ── *@
@if (IsMobile)
{
    <div style="display:flex;background:var(--mud-palette-dark);border-radius:20px;padding:3px;margin-bottom:12px;max-width:220px;">
        @foreach (var tab in new[] { "Short", "Full", "Form" })
        {
            var isActive = _mobileTab == tab;
            <div @onclick="@(() => _mobileTab = tab)"
                 style="flex:1;text-align:center;padding:5px 0;border-radius:17px;font-size:0.75rem;font-weight:600;cursor:pointer;
                        background:@(isActive ? "var(--mud-palette-surface)" : "transparent");
                        color:@(isActive ? "var(--mud-palette-primary)" : "rgba(255,255,255,0.7)");">
                @tab
            </div>
        }
    </div>

    @if (_mobileTab == "Short")
    {
        <MudSimpleTable Dense="true" Elevation="0" Style="background:transparent;">
            <thead>
                <tr style="font-size:0.75rem;color:var(--mud-palette-text-secondary);">
                    <th style="padding:8px 2px;text-align:left;width:20px;">#</th>
                    <th style="padding:8px 2px;text-align:left;">Team</th>
                    <th style="padding:8px 2px;text-align:center;width:22px;">PL</th>
                    <th style="padding:8px 2px;text-align:center;width:26px;">GD</th>
                    <th style="padding:8px 4px 8px 2px;text-align:center;width:26px;font-weight:700;">PTS</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Rows)
                {
                    var hl = IsHighlighted(row);
                    var zone = Zones.FirstOrDefault(z => row.Position >= z.StartPosition && row.Position <= z.EndPosition);
                    var borderStyle = hl ? "border-left:3px solid var(--mud-palette-primary);" : zone is not null ? $"border-left:3px solid {zone.Color};" : "border-left:3px solid transparent;";
                    var bgStyle = hl ? "background:rgba(var(--mud-palette-primary-rgb),0.12);" : "";
                    <tr style="font-size:0.875rem;border-bottom:1px solid var(--mud-palette-lines-default);@($"{borderStyle}{bgStyle}")">
                        <td style="padding:10px 2px;font-weight:600;">@row.Position</td>
                        <td style="padding:10px 2px;">
                            <div class="d-flex align-center gap-2">
                                @if (!string.IsNullOrEmpty(row.TeamLogo))
                                {
                                    <img src="@row.TeamLogo" alt="" style="width:28px;height:28px;" />
                                }
                                <span style="font-weight:@(hl ? "700" : "600");">@(row.TeamShortName ?? row.TeamName)</span>
                            </div>
                        </td>
                        <td style="padding:10px 2px;text-align:center;">@row.Played</td>
                        <td style="padding:10px 2px;text-align:center;">@row.GoalDifference</td>
                        <td style="padding:10px 4px 10px 2px;text-align:center;font-weight:700;">@row.Points</td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
    else if (_mobileTab == "Full")
    {
        <MudSimpleTable Dense="true" Elevation="0" Style="background:transparent;">
            <thead>
                <tr style="font-size:0.75rem;color:var(--mud-palette-text-secondary);">
                    <th style="padding:8px 2px;text-align:left;width:20px;">#</th>
                    <th style="padding:8px 2px;text-align:left;">Team</th>
                    <th style="padding:8px 2px;text-align:center;width:22px;">PL</th>
                    <th style="padding:8px 2px;text-align:center;width:18px;">W</th>
                    <th style="padding:8px 2px;text-align:center;width:18px;">D</th>
                    <th style="padding:8px 2px;text-align:center;width:18px;">L</th>
                    <th style="padding:8px 2px;text-align:center;width:40px;">+/-</th>
                    <th style="padding:8px 2px;text-align:center;width:26px;">GD</th>
                    <th style="padding:8px 4px 8px 2px;text-align:center;width:26px;font-weight:700;">PTS</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Rows)
                {
                    var hl = IsHighlighted(row);
                    var zone = Zones.FirstOrDefault(z => row.Position >= z.StartPosition && row.Position <= z.EndPosition);
                    var borderStyle = hl ? "border-left:3px solid var(--mud-palette-primary);" : zone is not null ? $"border-left:3px solid {zone.Color};" : "border-left:3px solid transparent;";
                    var bgStyle = hl ? "background:rgba(var(--mud-palette-primary-rgb),0.12);" : "";
                    <tr style="font-size:0.875rem;border-bottom:1px solid var(--mud-palette-lines-default);@($"{borderStyle}{bgStyle}")">
                        <td style="padding:10px 2px;font-weight:600;">@row.Position</td>
                        <td style="padding:10px 2px;">
                            <div class="d-flex align-center gap-2">
                                @if (!string.IsNullOrEmpty(row.TeamLogo))
                                {
                                    <img src="@row.TeamLogo" alt="" style="width:28px;height:28px;" />
                                }
                                <span style="font-weight:@(hl ? "700" : "600");">@(row.TeamShortName ?? row.TeamName)</span>
                            </div>
                        </td>
                        <td style="padding:10px 2px;text-align:center;">@row.Played</td>
                        <td style="padding:10px 2px;text-align:center;">@row.Won</td>
                        <td style="padding:10px 2px;text-align:center;">@row.Drawn</td>
                        <td style="padding:10px 2px;text-align:center;">@row.Lost</td>
                        <td style="padding:10px 2px;text-align:center;">@row.GoalsFor-@row.GoalsAgainst</td>
                        <td style="padding:10px 2px;text-align:center;">@row.GoalDifference</td>
                        <td style="padding:10px 4px 10px 2px;text-align:center;font-weight:700;">@row.Points</td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
    else
    {
        <MudSimpleTable Dense="true" Elevation="0" Style="background:transparent;">
            <thead>
                <tr style="font-size:0.75rem;color:var(--mud-palette-text-secondary);">
                    <th style="padding:8px 2px;text-align:left;width:20px;">#</th>
                    <th style="padding:8px 2px;text-align:left;">Team</th>
                    <th style="padding:8px 4px 8px 2px;text-align:center;">Form</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Rows)
                {
                    var hl = IsHighlighted(row);
                    var zone = Zones.FirstOrDefault(z => row.Position >= z.StartPosition && row.Position <= z.EndPosition);
                    var borderStyle = hl ? "border-left:3px solid var(--mud-palette-primary);" : zone is not null ? $"border-left:3px solid {zone.Color};" : "border-left:3px solid transparent;";
                    var bgStyle = hl ? "background:rgba(var(--mud-palette-primary-rgb),0.12);" : "";
                    <tr style="font-size:0.875rem;border-bottom:1px solid var(--mud-palette-lines-default);@($"{borderStyle}{bgStyle}")">
                        <td style="padding:10px 2px;font-weight:600;">@row.Position</td>
                        <td style="padding:10px 2px;">
                            <div class="d-flex align-center gap-2">
                                @if (!string.IsNullOrEmpty(row.TeamLogo))
                                {
                                    <img src="@row.TeamLogo" alt="" style="width:28px;height:28px;" />
                                }
                                <span style="font-weight:@(hl ? "700" : "600");">@(row.TeamShortName ?? row.TeamName)</span>
                            </div>
                        </td>
                        <td style="padding:10px 4px 10px 2px;">
                            <div class="d-flex gap-1">
                                @foreach (var r in row.RecentForm)
                                {
                                    <span style="display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:50%;font-size:11px;font-weight:700;color:#fff;background:@(r.Result == MatchResultCodes.Win ? "#4caf50" : r.Result == MatchResultCodes.Loss ? "#f44336" : "#9e9e9e");">@r.Result</span>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@* ── DESKTOP: full table ── *@
else
{
    <MudTable Items="Rows" Dense="true" Hover="true" Elevation="1" RowStyleFunc="RowStyleFunc" FixedHeader="true" Breakpoint="Breakpoint.None">
        <HeaderContent>
            <MudTh Style="width:30px;">#</MudTh>
            <MudTh>Team</MudTh>
            <MudTh Style="text-align:center;"><MudTooltip Text="Played" Placement="Placement.Top" ShowOnClick="true">PL</MudTooltip></MudTh>
            <MudTh Style="text-align:center;"><MudTooltip Text="Won" Placement="Placement.Top" ShowOnClick="true">W</MudTooltip></MudTh>
            <MudTh Style="text-align:center;"><MudTooltip Text="Drawn" Placement="Placement.Top" ShowOnClick="true">D</MudTooltip></MudTh>
            <MudTh Style="text-align:center;"><MudTooltip Text="Lost" Placement="Placement.Top" ShowOnClick="true">L</MudTooltip></MudTh>
            <MudTh Style="text-align:center;"><MudTooltip Text="Goals For" Placement="Placement.Top" ShowOnClick="true">GF</MudTooltip></MudTh>
            <MudTh Style="text-align:center;"><MudTooltip Text="Goals Against" Placement="Placement.Top" ShowOnClick="true">GA</MudTooltip></MudTh>
            <MudTh Style="text-align:center;"><MudTooltip Text="Goal Difference" Placement="Placement.Top" ShowOnClick="true">GD</MudTooltip></MudTh>
            <MudTh Style="text-align:center;font-weight:700;"><MudTooltip Text="Points" Placement="Placement.Top" ShowOnClick="true">Pts</MudTooltip></MudTh>
            <MudTh Style="text-align:center;"><MudTooltip Text="Last 5 matches (oldest first)" Placement="Placement.Top" ShowOnClick="true">Form</MudTooltip></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="#">@context.Position</MudTd>
            <MudTd DataLabel="Team">
                <div class="d-flex align-center gap-2">
                    @if (!string.IsNullOrEmpty(context.TeamLogo))
                    {
                        <img src="@context.TeamLogo" alt="" style="width:24px;height:24px;" />
                    }
                    <MudText>@context.TeamName</MudText>
                </div>
            </MudTd>
            <MudTd DataLabel="PL" Style="text-align:center;">@context.Played</MudTd>
            <MudTd DataLabel="W" Style="text-align:center;">@context.Won</MudTd>
            <MudTd DataLabel="D" Style="text-align:center;">@context.Drawn</MudTd>
            <MudTd DataLabel="L" Style="text-align:center;">@context.Lost</MudTd>
            <MudTd DataLabel="GF" Style="text-align:center;">@context.GoalsFor</MudTd>
            <MudTd DataLabel="GA" Style="text-align:center;">@context.GoalsAgainst</MudTd>
            <MudTd DataLabel="GD" Style="text-align:center;">@context.GoalDifference</MudTd>
            <MudTd DataLabel="Pts" Style="text-align:center;font-weight:700;">@context.Points</MudTd>
            <MudTd DataLabel="Form" Style="text-align:center;">
                <div class="d-flex gap-1 justify-center">
                    @foreach (var r in context.RecentForm)
                    {
                        var homeGoals = string.Join(", ", r.Goals.Where(g => g.IsHome).Select(g =>
                            $"{g.PlayerName}{(g.Count > 1 ? $" x{g.Count}" : "")}{(g.IsOwnGoal ? " (OG)" : "")}"));
                        var awayGoals = string.Join(", ", r.Goals.Where(g => !g.IsHome).Select(g =>
                            $"{g.PlayerName}{(g.Count > 1 ? $" x{g.Count}" : "")}{(g.IsOwnGoal ? " (OG)" : "")}"));
                        <MudTooltip Arrow="true" Placement="Placement.Top" Color="Color.Dark">
                            <TooltipContent>
                                <div style="text-align:center;padding:4px 2px;">
                                    <div style="font-weight:700;font-size:13px;letter-spacing:0.5px;">
                                        @(r.IsHome ? "🏠" : "✈️") @r.HomeScore - @r.AwayScore vs @r.Opponent
                                    </div>
                                    @if (!string.IsNullOrEmpty(homeGoals))
                                    {
                                        <div style="margin-top:4px;font-size:12px;">⚽ @homeGoals</div>
                                    }
                                    @if (!string.IsNullOrEmpty(awayGoals))
                                    {
                                        <div style="font-size:12px;">⚽ @awayGoals</div>
                                    }
                                </div>
                            </TooltipContent>
                            <ChildContent>
                                <span style="display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:50%;font-size:11px;font-weight:700;color:#fff;background:@(r.Result == MatchResultCodes.Win ? "#4caf50" : r.Result == MatchResultCodes.Loss ? "#f44336" : "#9e9e9e");cursor:pointer;">@r.Result</span>
                            </ChildContent>
                        </MudTooltip>
                    }
                </div>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

<div class="d-flex gap-4 mt-3 flex-wrap">
    @foreach (var zone in Zones)
    {
        <div class="d-flex align-center gap-1">
            <span style="width:12px;height:12px;border-radius:2px;background:@zone.Color;display:inline-block;"></span>
            <MudText Typo="Typo.caption">@zone.Name</MudText>
        </div>
    }
</div>
