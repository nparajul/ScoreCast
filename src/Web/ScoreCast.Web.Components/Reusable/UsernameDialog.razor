@using ScoreCast.Models.V1.Requests.UserManagement

<MudDialog Class="welcome-dialog">
    <DialogContent>
        <div class="onboard-hero">
            <div class="onboard-icon-ring">
                <MudImage Src="scorecast-icon-light.svg" Alt="ScoreCast" Width="44" Height="44" />
            </div>
            <MudText Typo="Typo.h5" Style="color:#fff;font-weight:800;letter-spacing:-0.02em;">Pick a Username</MudText>
            <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.55);margin-top:2px;">This is how others will see you</MudText>
        </div>

        <div class="pa-6">
            <MudTextField @bind-Value="_username"
                          Label="Username"
                          Placeholder="e.g. niteshp"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          AutoFocus="true"
                          HelperText="3–20 characters, letters, numbers, underscores only"
                          Error="@(!string.IsNullOrEmpty(_error))"
                          ErrorText="@_error"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.AlternateEmail"
                          Class="mb-4" />

            <MudButton OnClick="Submit"
                       Variant="Variant.Filled"
                       Color="Color.Tertiary"
                       Disabled="@(_submitting || string.IsNullOrWhiteSpace(_username))"
                       FullWidth="true"
                       Style="border-radius:14px;text-transform:none;font-weight:700;">
                @if (_submitting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Confirm
            </MudButton>
        </div>
    </DialogContent>
</MudDialog>
