@using Microsoft.JSInterop
@inject IJSRuntime JS

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@GetIcon()" Color="@GetColor()" />
            <MudText Typo="Typo.h6">@GetTitle()</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity" Variant="Variant.Filled" Class="mb-4">
            @GetUserFriendlyMessage()
        </MudAlert>

        @if (ShowDetails)
        {
            <MudExpansionPanels MultiExpansion="true">
                @if (!string.IsNullOrEmpty(Exception.StackTrace))
                {
                    <MudExpansionPanel Text="Stack Trace">
                        <div style="position:relative;">
                            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                           Size="Size.Small"
                                           Style="position:absolute;right:8px;top:8px;z-index:1;"
                                           OnClick="CopyStackTrace" />
                            <pre class="sc-stacktrace">@Exception.StackTrace</pre>
                        </div>
                    </MudExpansionPanel>
                }
                @if (Exception.InnerException is not null)
                {
                    <MudExpansionPanel Text="Inner Exception">
                        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true" Class="mb-2">
                            @Exception.InnerException.Message
                        </MudAlert>
                        @if (!string.IsNullOrEmpty(Exception.InnerException.StackTrace))
                        {
                            <pre class="sc-stacktrace" style="font-size:0.7rem;">@Exception.InnerException.StackTrace</pre>
                        }
                    </MudExpansionPanel>
                }
            </MudExpansionPanels>
        }
    </DialogContent>
    <DialogActions>
        @if (!ShowDetails)
        {
            <MudButton OnClick="@(() => ShowDetails = true)"
                       StartIcon="@Icons.Material.Filled.BugReport"
                       Color="Color.Default" Size="Size.Small">
                Show Details
            </MudButton>
        }
        <MudSpacer />
        <MudButton OnClick="CopyAllDetails"
                   StartIcon="@Icons.Material.Filled.ContentCopy"
                   Color="Color.Default" Size="Size.Small">
            Copy
        </MudButton>
        <MudButton OnClick="Close" Variant="Variant.Filled" Color="@GetColor()">
            OK
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .sc-stacktrace {
        background: var(--mud-palette-background);
        color: var(--mud-palette-text-primary);
        padding: 1rem;
        padding-top: 2.5rem;
        border-radius: 4px;
        font-size: 0.75rem;
        line-height: 1.5;
        white-space: pre-wrap;
        word-break: break-all;
        overflow-x: auto;
        font-family: 'Courier New', Courier, monospace;
        margin: 0;
        max-height: 300px;
        overflow-y: auto;
    }
</style>
