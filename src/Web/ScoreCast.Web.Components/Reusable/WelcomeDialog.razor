@using ScoreCast.Models.V1.Responses.Football

<MudDialog Options="@(new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, NoHeader = true })" Class="welcome-dialog">
    <DialogContent>
        <div class="d-flex flex-column align-center"
             style="background:linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); margin:-24px -24px 0; padding:40px 24px 28px; border-radius:28px 28px 0 0;">
            <div style="background:rgba(255,255,255,0.12); border-radius:20px; padding:14px; margin-bottom:12px;">
                <MudImage Src="scorecast-icon-light.svg" Alt="ScoreCast" Width="40" Height="40" />
            </div>
            <MudText Typo="Typo.h5" Style="color:#FFFFFF; font-weight:700;">Welcome, @Username! 👋</MudText>
            <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.6); margin-top:4px;">One last thing — pick your team</MudText>
        </div>

        <div class="pa-6">
            <div class="d-flex align-center gap-3 mb-5">
                @if (!string.IsNullOrWhiteSpace(_selectedTeam?.LogoUrl))
                {
                    <MudImage Src="@_selectedTeam.LogoUrl" Width="32" Height="32" ObjectFit="ObjectFit.Contain" />
                }
                <MudAutocomplete T="TeamResult"
                                 Label="Favourite Team"
                                 Placeholder="Search any team..."
                                 @bind-Value="_selectedTeam"
                                 SearchFunc="SearchTeams"
                                 ToStringFunc="@(t => t?.Name ?? "")"
                                 Variant="Variant.Outlined"
                                 Clearable="true"
                                 CoerceValue="false"
                                 MinCharacters="0"
                                 MaxItems="50"
                                 AutoFocus="true"
                                 Style="flex:1;">
                    <ItemTemplate Context="team">
                        <div class="d-flex align-center gap-2">
                            @if (!string.IsNullOrWhiteSpace(team.LogoUrl))
                            {
                                <MudImage Src="@team.LogoUrl" Width="24" Height="24" ObjectFit="ObjectFit.Contain" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Shield" Size="Size.Small" />
                            }
                            <MudText Typo="Typo.body2">@team.Name</MudText>
                        </div>
                    </ItemTemplate>
                </MudAutocomplete>
            </div>

            <div class="d-flex gap-3">
                <MudButton OnClick="Skip" Variant="Variant.Text" Color="Color.Default"
                           Style="border-radius:14px; flex:1;">Skip</MudButton>
                <MudButton OnClick="Save" Variant="Variant.Filled" Color="Color.Tertiary"
                           StartIcon="@Icons.Material.Filled.RocketLaunch"
                           Disabled="@(_selectedTeam is null)"
                           Style="border-radius:14px; flex:2;">
                    Let's Go!
                </MudButton>
            </div>
        </div>
    </DialogContent>
</MudDialog>
