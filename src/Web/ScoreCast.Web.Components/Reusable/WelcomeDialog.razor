@using ScoreCast.Models.V1.Responses.Football

<MudDialog Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, NoHeader = true })">
    <DialogContent>
        <div class="d-flex flex-column align-center"
             style="background:linear-gradient(135deg, #0A1929 0%, #37003C 100%); margin:-24px; padding:28px 24px 20px;">
            <MudImage Src="scorecast-icon-light.svg" Alt="ScoreCast" Width="48" Height="48" Class="mb-2" />
            <MudText Typo="Typo.h5" Style="color:#FFFFFF; font-weight:700;">Welcome, @Username!</MudText>
            <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.65);">Set up your profile</MudText>
        </div>

        <div class="pa-4 pt-5" style="margin:0 -24px -24px;">

            <MudTextField @bind-Value="DisplayName"
                          Label="Display Name"
                          Placeholder="What should others call you?"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          MaxLength="30"
                          Counter="30"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person"
                          AutoFocus="true"
                          Class="mb-4 px-2" />

            <MudAutocomplete T="TeamResult"
                             Label="Favourite Team"
                             Placeholder="Search any team..."
                             @bind-Value="_selectedTeam"
                             SearchFunc="SearchTeams"
                             ToStringFunc="@(t => t?.Name ?? "")"
                             Variant="Variant.Outlined"
                             Adornment="Adornment.Start"
                             AdornmentIcon="@Icons.Material.Filled.Shield"
                             Clearable="true"
                             CoerceValue="false"
                             MinCharacters="1"
                             MaxItems="20"
                             Class="mb-4 px-2">
                <ItemTemplate Context="team">
                    <div class="d-flex align-center gap-2">
                        @if (!string.IsNullOrWhiteSpace(team.LogoUrl))
                        {
                            <MudImage Src="@team.LogoUrl" Width="24" Height="24" ObjectFit="ObjectFit.Contain" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Shield" Size="Size.Small" />
                        }
                        <MudText Typo="Typo.body2">@team.Name</MudText>
                    </div>
                </ItemTemplate>
            </MudAutocomplete>

            <div class="d-flex justify-end gap-2 px-2 pb-2">
                <MudButton OnClick="Skip" Variant="Variant.Text" Color="Color.Default">Skip</MudButton>
                <MudButton OnClick="Save" Variant="Variant.Filled" Color="Color.Tertiary"
                           StartIcon="@Icons.Material.Filled.RocketLaunch"
                           Disabled="@(string.IsNullOrWhiteSpace(DisplayName) && _selectedTeam is null)">
                    Let's Go!
                </MudButton>
            </div>
        </div>
    </DialogContent>
</MudDialog>
