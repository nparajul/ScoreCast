@using Microsoft.AspNetCore.Components.Authorization

<AuthorizeView>
    <Authorized>
        <div class="d-flex d-md-none bottom-nav">
            @foreach (var tab in Tabs)
            {
                <button class="@TabClass(tab.Url)" @onclick="@(() => OnTabClick(tab))">
                    <span class="bottom-nav-icon-wrap">
                        @if (tab.Emoji is not null)
                        {
                            <span class="bottom-nav-emoji">@tab.Emoji</span>
                        }
                        else
                        {
                            <MudIcon Icon="@tab.Icon" Size="Size.Small" Style="@($"color:{tab.Color}")" />
                        }
                    </span>
                    <span class="bottom-nav-label">@tab.Label</span>
                </button>
            }
        </div>

        @if (_menuOpen)
        {
            <div class="more-menu-overlay" @onclick="@(() => { _menuOpen = false; })"></div>
            <div class="more-menu">
                <button class="more-menu-item" @onclick='() => Navigate("/points-table")'>
                    <MudIcon Icon="@Icons.Material.Filled.TableChart" Size="Size.Small" />
                    <span>Tables</span>
                </button>
                <button class="more-menu-item" @onclick='() => Navigate("/teams")'>
                    <span>🛡️</span>
                    <span>Teams</span>
                </button>
                <button class="more-menu-item" @onclick='() => Navigate("/player-stats")'>
                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                    <span>Players</span>
                </button>
                <button class="more-menu-item" @onclick='() => Navigate("/insights")'>
                    <MudIcon Icon="@Icons.Material.Filled.Psychology" Size="Size.Small" />
                    <span>Insights</span>
                </button>
                <button class="more-menu-item" @onclick='() => Navigate("/how-to-play")'>
                    <MudIcon Icon="@Icons.Material.Filled.HelpOutline" Size="Size.Small" />
                    <span>How To Play</span>
                </button>
                <button class="more-menu-item" @onclick='() => Navigate("/settings")'>
                    <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" />
                    <span>Profile & Settings</span>
                </button>
            </div>
        }
    </Authorized>
</AuthorizeView>
