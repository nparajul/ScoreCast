@using Microsoft.AspNetCore.Components.Authorization

<AuthorizeView>
    <Authorized>
        <div class="d-flex d-md-none bottom-nav">
            @foreach (var tab in Tabs)
            {
                <button class="@TabClass(tab.Url)" @onclick="@(() => OnTabClick(tab))">
                    <span class="bottom-nav-icon-wrap">
                        @if (tab.Emoji is not null)
                        {
                            <span class="bottom-nav-emoji">@tab.Emoji</span>
                        }
                        else
                        {
                            <MudIcon Icon="@tab.Icon" Size="Size.Small" Style="@($"color:{tab.Color}")" />
                        }
                    </span>
                    <span class="bottom-nav-label">@tab.Label</span>
                </button>
            }
        </div>

        @if (_menuOpen)
        {
            <div class="more-menu-overlay" @onclick="@(() => { _menuOpen = false; })"></div>
            <div class="more-menu">
                <button class="more-menu-item" @onclick='() => Navigate("/settings")'>
                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                    <span>Profile</span>
                </button>
                <button class="more-menu-item more-menu-logout" @onclick='() => Navigate("/logout")'>
                    <MudIcon Icon="@Icons.Material.Filled.Logout" Size="Size.Small" />
                    <span>Log Out</span>
                </button>
            </div>
        }
    </Authorized>
</AuthorizeView>
