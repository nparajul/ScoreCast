<MudDialog Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, NoHeader = true, FullScreen = true })" Class="global-search-dialog">
    <DialogContent>
        <div style="padding:16px 16px 8px;">
            <div class="d-flex align-center gap-2 mb-3">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Dialog.Close())" Size="Size.Small" />
                <MudTextField @bind-Value="_query"
                              Placeholder="Search competitions, teams..."
                              Variant="Variant.Outlined"
                              Immediate="true"
                              AutoFocus="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              TextChanged="OnSearchChanged"
                              Style="flex:1;" />
            </div>

            @if (!_loaded)
            {
                <div class="d-flex justify-center pa-4">
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                </div>
            }
            else if (string.IsNullOrWhiteSpace(_query))
            {
                <MudText Typo="Typo.body2" Align="Align.Center" Style="color:var(--mud-palette-text-secondary);padding:32px 0;">
                    Start typing to search
                </MudText>
            }
            else if (_filtered.Count == 0)
            {
                <MudText Typo="Typo.body2" Align="Align.Center" Style="color:var(--mud-palette-text-secondary);padding:32px 0;">
                    No results for "@_query"
                </MudText>
            }
            else
            {
                string? lastCategory = null;
                @foreach (var item in _filtered)
                {
                    @if (item.Category != lastCategory)
                    {
                        lastCategory = item.Category;
                        <MudText Typo="Typo.overline" Class="mt-2 mb-1 px-2" Style="font-weight:700;letter-spacing:0.1em;">@item.Category</MudText>
                    }
                    <div @onclick="@(() => Navigate(item))"
                         style="display:flex;align-items:center;gap:12px;padding:10px 8px;cursor:pointer;border-radius:8px;"
                         class="mud-ripple hover-highlight">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="" style="width:28px;height:28px;object-fit:contain;" />
                        }
                        else
                        {
                            <span style="font-size:20px;width:28px;text-align:center;">@item.Emoji</span>
                        }
                        <MudText Typo="Typo.body1" Style="font-weight:500;">@item.Name</MudText>
                    </div>
                }
            }
        </div>
    </DialogContent>
</MudDialog>
