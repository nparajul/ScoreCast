<AuthorizeView>
    <Authorized>
        <MudText Typo="Typo.body1" Class="mr-4">@context.User.Identity?.Name</MudText>
        <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="BeginLogout">Log out</MudButton>
    </Authorized>
    <NotAuthorized>
        <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/login">Log in</MudButton>
    </NotAuthorized>
</AuthorizeView>
