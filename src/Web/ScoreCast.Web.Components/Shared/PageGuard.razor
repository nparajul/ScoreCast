@inject IRoleNavigationService RoleNav
@inject NavigationManager Navigation

@if (_authorized)
{
    @ChildContent
}
else if (_checked)
{
    <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8 d-flex flex-column align-center">
        <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Color="Color.Error" />
        <MudText Typo="Typo.h5" Class="mt-4">Access Denied</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">You don't have permission to view this page.</MudText>
    </MudContainer>
}
