@using Microsoft.AspNetCore.Components.Authorization

<AuthorizeView>
    <Authorized>
        @if (IsOpen)
        {
            <div class="side-drawer-overlay" @onclick="Close"></div>
        }
        <div class="side-drawer @(IsOpen ? "open" : "")">
            <div class="side-drawer-header">
                <MudImage Src="scorecast-logo-dark.svg" Alt="ScoreCast" Height="28" Style="object-fit:contain;" />
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="Close"
                               Style="color:rgba(255,255,255,0.7);" />
            </div>

            <nav class="side-drawer-menu">
                <button class="side-drawer-item" @onclick='() => Navigate("/settings")'>
                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                    <span>Profile</span>
                </button>
                <button class="side-drawer-item" @onclick='() => Navigate("/how-to-play")'>
                    <MudIcon Icon="@Icons.Material.Filled.HelpOutline" Size="Size.Small" />
                    <span>How to Play</span>
                </button>
                <button class="side-drawer-item" @onclick='() => Navigate("/insights")'>
                    <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" />
                    <span>Insights</span>
                </button>
                <button class="side-drawer-item" @onclick='() => Navigate("/player-stats")'>
                    <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" />
                    <span>Players</span>
                </button>

                <div class="side-drawer-divider"></div>

                <button class="side-drawer-item side-drawer-logout" @onclick='() => Navigate("/logout")'>
                    <MudIcon Icon="@Icons.Material.Filled.Logout" Size="Size.Small" />
                    <span>Log Out</span>
                </button>
            </nav>
        </div>
    </Authorized>
</AuthorizeView>
