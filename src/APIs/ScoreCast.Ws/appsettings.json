{
  "ConnectionStrings": {
    "ScoreCastDb": ""
  },
  "Keycloak": {
    "Authority": "",
    "Audience": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/scorecast-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "CorsSettings": {
    "AllowedOrigins": ["http://localhost:5000", "https://localhost:5001", "http://localhost:5200"]
  },
  "ApiSettings": {
    "FootballDataApi": {
      "BaseUrl": "https://api.football-data.org/v4/",
      "ApiKey": ""
    },
    "FplApi": {
      "BaseUrl": "https://fantasy.premierleague.com/api/"
    }
  },
  "AllowedHosts": "*"
}
