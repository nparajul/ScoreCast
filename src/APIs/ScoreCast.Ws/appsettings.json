{
  "ConnectionStrings": {
    "ScoreCastDb": ""
  },
  "Keycloak": {
    "Authority": "",
    "Audience": ""
  },
  "ApiKeySettings": {
    "Clients": [
      { "Name": "ScoreCast.Jobs", "Key": "" },
      { "Name": "ExternalPartner", "Key": "" }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/api/scorecast-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": 10485760,
          "rollOnFileSizeLimit": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "CorsSettings": {
    "AllowedOrigins": ["http://localhost:5000", "https://localhost:5001", "http://localhost:5200"]
  },
  "ApiSettings": {
    "FootballDataApi": {
      "BaseUrl": "https://api.football-data.org/v4/",
      "ApiKey": ""
    },
    "FplApi": {
      "BaseUrl": "https://fantasy.premierleague.com/api/"
    },
    "PulseApi": {
      "BaseUrl": "https://footballapi.pulselive.com/"
    }
  },
  "AI": {
    "Endpoint": "https://models.inference.ai.azure.com",
    "Model": "gpt-4o-mini",
    "GitHubToken": ""
  },
  "AllowedHosts": "*"
}
