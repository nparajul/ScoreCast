{
  "ConnectionStrings": {
    "HangfireDb": ""
  },
  "ScoreCastApi": {
    "BaseUrl": "http://localhost:5100",
    "ApiKey": ""
  },
  "Competitions": ["PL", "BL1", "SA", "PD"],
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Hangfire": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/scorecast-jobs-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ]
  }
}
