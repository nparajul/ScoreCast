{
  "realm": "scorecast",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      {
        "name": "sc_admin",
        "description": "ScoreCast administrator"
      },
      {
        "name": "sc_user",
        "description": "ScoreCast regular user"
      }
    ]
  },
  "defaultRoles": ["sc_user"],
  "clients": [
    {
      "clientId": "scorecast-api",
      "name": "ScoreCast API",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true
    },
    {
      "clientId": "scorecast-web",
      "name": "ScoreCast Web App",
      "enabled": true,
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "protocol": "openid-connect",
      "rootUrl": "http://localhost:5000",
      "baseUrl": "/",
      "redirectUris": [
        "http://localhost:5000/*",
        "http://localhost:5105/*"
      ],
      "webOrigins": [
        "http://localhost:5000",
        "http://localhost:5105"
      ],
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "roles",
      "description": "Realm roles in the token",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "multivalued": "true",
            "claim.name": "roles",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "email": "admin@scorecast.local",
      "firstName": "ScoreCast",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["sc_admin", "sc_user"]
    },
    {
      "username": "testuser",
      "enabled": true,
      "emailVerified": true,
      "email": "testuser@scorecast.local",
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "testuser",
          "temporary": false
        }
      ],
      "realmRoles": ["sc_user"]
    }
  ]
}
